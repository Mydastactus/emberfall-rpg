/* ============================================================
   THE SMALL DEBTS — folk quests: the city, one person at a time
   ============================================================ */
function folkState() { flags.folk = flags.folk || {}; return flags.folk; }
function folkHelpedCount() { const f = folkState(); return ["cat", "bake", "tessa", "voss", "corin"].filter(k => f[k] === "done").length; }
function folkOpenCount() {
  const f = folkState(), ch = flags.chapter;
  let n = 0;
  if (ch >= 8 && !["done"].includes(f.cat)) n++;
  if (ch >= 8 && !["done"].includes(f.bake)) n++;
  if (ch >= 9 && !["done", "lost"].includes(f.tessa)) n++;
  if (ch >= 9 && !["done", "lost"].includes(f.voss)) n++;
  if (ch >= 10 && !["done", "lost"].includes(f.corin)) n++;
  return n;
}
function folkRow(icon, title, sub, sceneId, state) {
  if (state === "done") return `<button disabled>✓ ${icon} ${title} <span class="req">— ${sub}</span></button>`;
  if (state === "lost") return `<button disabled>🕯 ${icon} ${title} <span class="req">— ${sub}</span></button>`;
  return `<button onclick="goScene('${sceneId}')">${icon} ${title} <span class="req">${sub}</span></button>`;
}
function folkBoard() {
  const f = folkState(), ch = flags.chapter;
  const rows = [];
  if (ch >= 8) {
    rows.push(folkRow("🐈", "Widow Ottley's cat", f.cat === "done" ? "Maribel sleeps on the widow's sill again" : "an old woman in the bread line keeps calling a name into alleys", "folk_cat", f.cat));
    rows.push(folkRow("🍞", "Tammis the baker", f.bake === "done" ? "the Ember eats real bread now" : "his ovens seized for 'hoarding' — he was feeding the bread lines", "folk_bake", f.bake));
  }
  if (ch >= 9) {
    rows.push(folkRow("🎀", "Anna Brooke's daughter", f.tessa === "done" ? "Tessa is home, and her mother has stopped standing at the window" : f.tessa === "lost" ? "the convoy went east. Anna still sets two plates." : f.tessa === "lastchance" ? "TESSA IS ON THE EAST CONVOY — it hasn't cleared the hills yet" : "taken in a curfew sweep; the holding yard ships 'resettlement labor' east", "folk_tessa", f.tessa));
    rows.push(folkRow("🗝", "The locksmith's widow", f.voss === "done" ? "Dain Voss is buried honestly, and a sergeant is not sleeping well" : f.voss === "lost" ? "Mara Voss left the city by night. The canal keeps its story." : f.voss === "guard" ? "KRELL KNOWS — Mara Voss's door will be visited tonight" : "they say Dain Voss fell drunk into the canal. His widow says Dain didn't drink.", "folk_voss", f.voss));
  }
  if (ch >= 10) {
    rows.push(folkRow("🪖", "Widow Hessa's son", f.corin === "done" ? "Corin's black cloak hangs on the Ember's wall, stripped of its pins" : f.corin === "lost" ? "Corin re-upped. Hessa still sets his place." : "Corin took Blackpike coin for his mother's sake. She wants him home before he's blooded.", "folk_corin", f.corin));
  }
  if (ch === 9) rows.push(`<div class="card-tag" style="padding:4px 2px">Sera will have more names as the city trusts you further.</div>`);
  scene("🏮", "Word From the Streets",
    [ `Sera doesn't look up from the charcoal map. "Operations win the war table. This wins the war." She nods at a scrap of paper weighted with a pistol crossbow bolt — names, in her small exact hand.`,
      `"Nobody's paying. Most of them can't. That's rather the point."` ],
    [], `<div class="choices">${rows.join("")}<button onclick="goScene('town')">🕯 Back to the Ember</button></div>`);
}

/* --- 1. THE CAT (ch8) --- */
function folk_cat() {
  scene("🐈", "The Name Called Into Alleys",
    [ `Widow Ottley has held her place in the bread line for six hours, and spends the waiting calling "Maribel" at every shadow. Her husband is four years dead; the tabby is what answered the silence. Maribel bolted at the siege bells and has not come home.`,
      `"She's all the family the Protectorate left me," the widow says, and straightens like it costs her something. "I've nothing to pay heroes with."`,
      `<i>That's rather the point.</i>` ],
    [ { txt: "🔍 Read the alley signs and find one small cat in an occupied city", req: `(Survival, DC 11) <span class="win">✓ Maribel comes home (+2 Hearts)</span> · <span class="lose">✗ a fistful of scratches (1d4) — but you can try again</span>`, onclick: "folkCatTry()" },
      { txt: "🏮 Not now — back to the board", onclick: "goScene('folkboard')" } ]);
}
function folkCatTry() {
  const res = sceneCheck("Survival", 11);
  if (res.success) {
    folkState().cat = "done";
    addTruth(2, "the widow's cat, carried home");
    grantXp(80, "Maribel");
    scene("🐈", "Maribel, Repatriated",
      [ `The trail of feather-ends and outraged mice leads, of course, to the one place with food to spare: the Blackpike stable, where Maribel has been mousing for the occupation. You lift her off a saddle blanket mid-yawn. She does not resist. Traitor.`,
        `Widow Ottley takes the cat like something rescued from a fire, and stands very straight, and doesn't cry, and cries. The bread line pretends not to watch. The whole street knows by nightfall who brought her home — <b>and whose side that someone is on.</b>` ],
      [ { txt: "🏮 Back to the board", onclick: "goScene('folkboard')" } ]);
  } else {
    const d4 = d(4); C.hp = Math.max(1, C.hp - d4);
    scene("🐈", "Negotiations Break Down",
      [ `You find A cat. Whether it is THE cat becomes academic when it redesigns the back of your hand. <b>(−${d4} HP)</b> A lamplighter watches you lose a fight to four pounds of tabby and says, kindly, "That one's Maribel all right. She'll come to sardines."`,
        `<i>Sardines. Noted. She's still out there.</i>` ],
      [ { txt: "🐟 Try again, wiser", onclick: "goScene('folk_cat')" },
        { txt: "🏮 Back to the board", onclick: "goScene('folkboard')" } ]);
  }
}

/* --- 2. THE BAKERY (ch8) --- */
function folk_bake() {
  scene("🍞", "The Crime of Baking",
    [ `Tammis fed the bread lines out of his own flour until an enforcer did the arithmetic and called generosity "hoarding." They took his ovens' iron doors, his pans — and his mother's recipe book, four generations of marginalia now sitting in the requisition depot as "evidence."`,
      `"The ovens I can rebuild," he says, hands still dusted with flour out of pure habit. "The book is my family."` ],
    [ { txt: "🌫 Slip into the depot after curfew", req: `(Stealth, DC 12) <span class="win">✓ the book and his pans, quietly (+3 Hearts)</span> · <span class="lose">✗ the alarm — Blackpikes come, and it gets loud</span>`, onclick: "folkBakeTry()" },
      { txt: "💰 Buy it back through Zephyrine's channels — 80 gold, no questions", req: C.gold < 80 ? `<span class="lose">(you don't have 80 gold)</span>` : `<span class="win">✓ the book, ransomed (+3 Hearts)</span>`, onclick: C.gold >= 80 ? "folkBakePay()" : "goScene('folk_bake')" },
      { txt: "🏮 Not now — back to the board", onclick: "goScene('folkboard')" } ]);
}
function folkBakeTry() {
  const res = sceneCheck("Stealth", 12);
  if (res.success) {
    folkState().bake = "done";
    addTruth(3, "a baker's inheritance, returned");
    grantXp(150, "the recipe book");
    C.items.push("Tammis' Seedcake");
    scene("🍞", "Four Generations, Recovered",
      [ `The depot clerk files by candlelight and never hears you. The book is in a crate marked CONTRABAND — LITERARY, which would make Tammis' mother laugh, wherever she is. You take the pans too, and, on principle, the crate.`,
        `By dawn the Ember smells of real bread for the first time. Tammis presses a seedcake on you — dense as a brick, sweet as a held grudge — and starts baking for the resistance outright. <i>(Tammis' Seedcake added: restores 2d4+4 HP when eaten.)</i>` ],
      [ { txt: "🏮 Back to the board", onclick: "goScene('folkboard')" } ]);
  } else {
    scene("🍞", "The Alarm",
      [ `A stack of requisitioned kettles goes over like a carillon. Whistles answer whistles. You have the book in one hand and a decision in the other — because two Blackpikes are already in the doorway, and they are not readers.` ],
      [ { txt: "⚔ Fight your way out with the book", onclick: "startCombat(['blackpike','thug'], 'folk_bake_loud', { noFlee: true, intro: 'The doorway is narrow. That is the only good news.' })" } ]);
  }
}
function folkBakePay() {
  C.gold -= 80;
  folkState().bake = "done";
  addTruth(3, "a baker's inheritance, ransomed");
  grantXp(100, "the recipe book, bought");
  C.items.push("Tammis' Seedcake");
  scene("🍞", "No Questions Asked",
    [ `Zephyrine's channels produce the book in two days, smelling faintly of the Otherworld and someone else's tobacco. Tammis doesn't ask how. He bakes. The Ember eats real bread, and a seedcake finds its way into your pack with your name burnt into the crust. <i>(Tammis' Seedcake added: restores 2d4+4 HP.)</i>` ],
    [ { txt: "🏮 Back to the board", onclick: "goScene('folkboard')" } ]);
}
function folk_bake_loud() {
