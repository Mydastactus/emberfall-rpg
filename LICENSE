/* ---------- CHAPTER 11 — THE BARONS' MOOT ---------- */
function c11_moot() {
  flags.checkpoint = "c11_moot";
  if (!flags.mootDone) { flags.mootDone = []; flags.baronsWon = 0; flags.m = {}; } // first entry: fresh moot (also heals saves inflated by the old bug)
  flags.m = flags.m || {};
  if (flags.mootDone.length >= 3) return goScene("c11_strike");
  const p = proofCount();
  scene("🏰", "The Moot of Three Banners",
    [ `Wrenhall's great barn — neutral ground by ancient custom — holds three banners and three cold-eyed magnates: <b>Baron Hallowmere</b> of the grain lands, <b>Baroness Wrenfield</b> of the iron hills, and <b>Baron Coldbrook</b> of the counting-houses. Each received Thorne's poisoned letters months ago. Each watches the returned "coward King" with carefully hedged faces.`,
      `Alden speaks first, plainly, taking the coward's letter apart line by line. Then it's your turn — the case lives in your satchel. Win them one by one. <i>(Proofs in hand: ${p}/3. Barons won: ${flags.baronsWon}/3.)</i>` ],
    [ !flags.mootDone.includes("hallowmere") ? { txt: "🌾 Baron Hallowmere — a decent man made cautious by burnt granaries. He wants to believe; he needs a REASON.", req: `(Persuasion, DC 12 — easier with proofs${hasFalseEvidence() ? ", HARDER with unverified papers" : ""}) <span class="win">✓ the grain banner dips to the King</span> · <span class="lose">✗ he hedges — "bring the city first"</span>`, onclick: "c11_baron('hallowmere')" } : null,
      !flags.mootDone.includes("wrenfield") ? { txt: "⚔ Baroness Wrenfield — iron-country blunt. Words bore her; spines don't.", req: C.origin.id === "soldier" ? bkReq("Soldier's Camp — she knows drill-yard iron when she hears it") : "(Intimidation, DC 13)", onclick: "c11_baron('wrenfield')" } : null,
      !flags.mootDone.includes("coldbrook") ? { txt: "💰 Baron Coldbrook — the counting-house. Sentiment is not a currency he accepts.", req: flags.evidence.includes("zargaLedger") ? "(Zarga's ledger speaks his native tongue)" : "(needs hard proof — or 200 gold of 'surety')", onclick: "c11_baron('coldbrook')" } : null
    ].filter(Boolean));
}
function c11_baron(who) {
  if (!flags.mootDone) flags.mootDone = [];
  if (flags.mootDone.includes(who)) return goScene("c11_moot");
  flags.mootDone.push(who);
  let won = false, text = "";
  const p = proofCount();
  if (who === "hallowmere") {
    const res = sceneCheck("Persuasion", Math.max(8, 12 - p * 2 + (hasFalseEvidence() ? 2 : 0)));
    won = res.success;
    text = won
      ? `You give Hallowmere the scout's dispatch case and let him read a dead man's chained-wrist orders for himself. He is quiet a long time. "My granaries burned while my levies chased ghosts," he says at last. "I would very much like to be angry at the correct person." The grain banner dips to the King.`
      : `Hallowmere wavers, agonized — and hedges. "Bring the city, and Hallowmere follows the city." Not a no. Not a banner, either.`;
  } else if (who === "wrenfield") {
    const auto = C.origin.id === "soldier";
    const res = auto ? { success: true } : sceneCheck("Intimidation", 13);
    won = res.success;
    text = won
      ? (auto ? `You talk to Wrenfield the way sergeants talked around your childhood fires — supply lines, muster counts, and which particular hill she'll die holding when Zarga's horde comes back UNDER PROTECTORATE PAY next spring. She barks one laugh. "Camp-raised. Thought so." The iron banner dips. <i>(Soldier's Camp)</i>` : `You put it to Wrenfield the only way she respects: the Protector bought one siege already, owns the forge-marks on the horde's steel, and iron country is the next thing worth squeezing. "At least the goblins ROB you honestly," you finish. She grins like a cliff-face cracking — and the iron banner dips.`)
      : `Wrenfield folds her arms. "Words. My smiths beat better arguments out of bar stock daily." The iron banner stays level — watching.`;
  } else {
    if (flags.evidence.includes("zargaLedger")) {
      won = true;
      text = `You don't argue with Coldbrook at all. You simply set Zarga's ledger-copies on his table, open to the page pricing the Protectorate's grain contracts — and the page pricing a baron's "harvest-time accident." He reads in silence, twice, the way counting-men do. "He priced ME at less than the granary contract," Coldbrook says finally, genuinely offended, and calls for his seal. The coin banner dips.`;
    } else if (C.gold >= 200) {
      C.gold -= 200; won = true;
      text = `Without the hard ledger, Coldbrook requires what he delicately terms "surety against inconvenience" — 200 gold, held in escrow against your cause's success. It is extortion with excellent manners, and it buys the coin banner's dip. <b>(−200 gold)</b>`;
    } else {
      text = `Without hard ledgers or hard gold, Coldbrook gives you a counting-man's smile. "Return when your cause has collateral." The coin banner stays level.`;
    }
  }
  if (won) flags.baronsWon++;
  scene("🏰", "The Moot of Three Banners", [ text, `<i>(Barons won: ${flags.baronsWon}/3.)</i>` ],
    [ { txt: "→ Continue the moot", onclick: "goScene('c11_moot')" } ]);
}
function c11_strike() {
  flags.baronsWon = Math.min(flags.baronsWon || 0, 3);
  scene("🗡", "Knives at the Moot",
    [ `The moot breaks for the night with ${flags.baronsWon} banner${flags.baronsWon === 1 ? "" : "s"} dipped to the King — and the Gray Web's answer arrives before the candles are out. They come through the barn's high loft, silent as falling dust: not for the barons. For <b>Alden</b>. A dead King at a moot he called would end everything neatly.`,
      `But this time the King is not alone, not deceived, and not — as the first assassin discovers upon meeting a thrown warhammer — remotely in the mood.` ],
    [ { txt: "⚔ Defend the King!", onclick: "startCombat(['assassin2','assassin2','blackpike','assassin'], 'c11_end', { ally: { name: 'King Alden & Wrenfield', atk: 11, dmg: [2, 8, 6] }, intro: 'Wrenfield fights bare-handed with a bench until she reaches her axe, bellowing happily about honest robbery.' })" } ]);
}
function c11_end() {
  const bonus = flags.baronsWon >= 2 ? `The barons see the Web's knives with their own eyes — sent to silence a moot called under ancient right. Whatever hedging survived the evening dies with the assassins. By dawn, ${flags.baronsWon === 3 ? "all three banners" : "the dipped banners"} are raising levies.` : `Even the hedging barons saw the knives. None will march for Thorne now — and Hallowmere quietly sends grain north to the vanguard "against the King's return."`;
  scene("🌅", "Banners in the Morning",
    [ `The last assassin carries the usual purse of sunburst coin — Thorne has literally never changed his tells — and something better: a Gray Web dispatch naming the moot's date and floor plan. Only the Protectorate's inner council knew both.`,
      bonus,
      `Alden watches the baron levies muster in the gray dawn light, and for the first time since the wilderness, something that is almost peace crosses his face. "Now," he says. "My city. And my friend." <b>(+500 XP)</b>` ],
    [ { txt: "🏰 March on Ironvale", onclick: "addTruth(12,'word of the moot outruns the criers — banners raised, knives seen'); grantXp(500,'Chapter 11: the Moot'); C.gold += 120; flags.chapter = 12; goScene('town')" } ]);
}

/* ---------- CHAPTER 12 — THE RETAKING OF IRONVALE ---------- */
function c12_stage() {
  flags.m = {}; flags.checkpoint = "c12_stage"; flags.inFinale2 = true;
  const truth = flags.truth || 0;
  scene("🏰", "Before the Walls",
    [ `The King's host — vanguard, baron levies, and every Ember blade — stands before Ironvale under the old royal banner. On the walls: Blackpike companies, thin and nervous. In the city behind them: a hundred thousand people who have spent a season deciding what they believe.`,
      `Sera returns from the postern gates at dusk with the answer. <i>(Hearts of the City: ${truth}/100.)</i>`,
      truth >= 65
        ? `"They're OURS." Her grin could light the camp. "The broadsheet questions, the empty gallows, the manifest whispers — the city's been doing arithmetic all season. The watch won't fire on the King. The gate wards say: come at the midnight bell, and the gates will simply... open."`
        : `"Split," she reports grimly. "The Protector's bread bought more hearts than our truth freed. The gates stay shut — we go in the hard way, and pray the city doesn't fight us street by street."` ],
    [ truth >= 65
        ? { txt: "🌙 The midnight bell. Walk through gates opened by the people themselves.", onclick: "goScene('c12_open_gates')" }
        : { txt: "⚔ Storm the east gate — again", onclick: "startCombat(['palaceElite','blackpike'], 'c12_palace', { ally: { name: 'King Alden', atk: 9, dmg: [1, 10, 6] }, intro: 'The wall fight is brutal and brief — most Blackpikes surrender the moment the vanguard banner crests the parapet. Most.' })" } ]);
}
function c12_open_gates() {
  addTruth(10, "the city opens its own gates");
  scene("🌙", "The Midnight Bell",
    [ `At the twelfth stroke, Ironvale's east gates swing wide from WITHIN — hauled by bakers and fletchers and a one-armed granary clerk, by the widow who lost her crossbow and the miller's boy who learned which end of a spear matters.${folkGateLines()} No assault. No storm. The King walks into his city through a corridor of silent, weeping citizens, and the Blackpikes on the walls look at the crowd, do the arithmetic themselves, and ground their pikes.`,
      `The corridor of people leads all the way to the palace steps — where the last loyal remnant of the Protectorate waits, because some contracts specify to the end.` ],
    [ { txt: "🏛 To the palace steps", onclick: "startCombat(['palaceElite','blackpike'], 'c12_palace', { surprise: true, ally: { name: 'King Alden', atk: 9, dmg: [1, 10, 6] }, intro: 'The remnant fights with the grimness of men whose employer is watching from a balcony.' })" } ]);
}
function c12_palace() {
  scene(pArt("vail"), "The Last Door",
    [ `The palace stairs, the long gallery, the doors of the balcony chamber — and before them, alone, unhurried, stands <b>Lord-Blade Vail</b>, sword still sheathed, watching your approach like the final line of a contract.`,
      `"He's on the balcony," she says conversationally. "Rehearsing, if you can believe it. The 'noble surrender' speech. It's quite good." She draws — one smooth whisper of steel. "I took his coin. This is where coin like that gets spent. You understand — you're the same breed. Loyal to something even when it ruins you."`,
      `She levels the blade — at you alone. "The duel, hero. Your friends pass either way; my contract names YOU. Give me an ending worth the wage."` ],
    [ { txt: "🤺 Honor the duel — alone, blade to blade", req: `(she yields if beaten — and a yielded Vail talks) <span class="lose">✗ the hardest fight of your life: she strikes twice a round, and drinking or binding wounds gives her a free thrust</span>`, onclick: "startCombat(['vail2'], 'c12_vail_yield', { intro: 'The gallery empties around you both. Vail salutes — and becomes several places at once. Every opening you give her — every bottle, every bandage — will be answered in steel.' })" },
      { txt: "⚔ No duels. No theater. Take her together.", onclick: "startCombat(['vailGate','palaceElite'], 'c12_vail_dead', { ally: { name: 'King Alden', atk: 9, dmg: [1, 10, 6] }, intro: 'Vail sighs — \"Prose it is\" — and her reserve steps from the alcoves.' })" } ]);
}
function c12_vail_yield() {
  flags.vailYielded = true;
  scene(pArt("vail"), "The Blade Yields",
    [ `The duel is the hardest fight of your life — Vail is water and razors — but at the end it's her blade that rings on the marble, and the Lord-Blade goes to one knee, breathing hard, grinning like a woman finally released from a bad debt.`,
      `"WORTH the wage," she declares. "I yield — witnessed, formal." Then, rising: "Yielded blades testify, hero. It's in the old code, and I am suddenly VERY fond of the old code. Ask me on a balcony, in front of everyone, who hired the gala knife-man. Ask me who carried the gray man's letters east." A pause, and something almost like relief: "He was going to retire me 'after harvest' anyway. I read the ledger too."`,
      `<b>(Vail yields — and her testimony joins your case.)</b>` ],
    [ { txt: "🚪 The balcony doors", onclick: "grantXp(900,'the Lord-Blade yields'); goScene('c12_balcony')" } ]);
}
function c12_vail_dead() {
  scene("🤺", "The Blade Broken",
    [ `Vail dies as she lived — professionally, without complaint, and very nearly taking you with her. Her last act is to flick a blood-slicked signet ring across the floor to your feet: the Gray Web's master-seal. "Expenses," she manages, and is gone.`,
      `<b>(The Gray Web's master-seal — its couriers and safehouses are yours to unravel.)</b>` ],
    [ { txt: "🚪 The balcony doors", onclick: "grantXp(900,'the Lord-Blade falls'); goScene('c12_balcony')" } ]);
}
function c12_balcony() {
  const truth = flags.truth || 0, p = proofCount();
  const score = (truth >= 65 ? 1 : 0) + (flags.baronsWon >= 2 ? 1 : 0) + (p >= 3 ? 1 : 0) + (flags.zargaDeal ? 1 : 0) + (flags.vailYielded ? 1 : 0);
  scene(pArt("thorne"), "The Balcony",
    [ `The doors open on dawn. Thaddeus Thorne stands at the balcony rail where he read a forged king's confession to ten thousand people — hair combed, robes immaculate, watching the crowd fill the square below like a man reviewing his life's work. He does not run. He turns, and gives you the smile from the Gilded Griffin, the one that remembers your name, and it is only a little tired at the edges.`,
      `"The hero. Of course — it was always going to be you. Do you know, I meant every kindness? That's what none of you will ever understand. The drinks, the orphanages, the worry — all TRUE. A realm is just a ledger, friend, and I am the only one who ever loved it enough to balance it." He glances at the crowd, then back. "Well. You've brought an audience. Shall we give them an ending?"`,
      `<i>The case in your satchel: ${p}/3 proofs. The city: ${truth}/100. The banners: ${flags.baronsWon}/3. ${flags.zargaDeal ? "And east of the walls, a warchief awaits her invoice." : ""} ${flags.vailYielded ? "Beside you, a yielded Lord-Blade waits to testify." : ""}</i>` ],
    [ score >= 3
        ? { txt: "📖 Give them the whole truth — proofs, testimony, and the man himself. End it in daylight.", onclick: "c2_ending('daylight')" }
        : null,
      flags.baronsWon >= 2 && p >= 2
        ? { txt: "⚖ Arrest him for the King's justice — a true trial, with true evidence, before the realm", onclick: "c2_ending('trial')" }
        : null,
      { txt: "😠 Say nothing. Let him see the King walk through the door behind you.", onclick: "c2_ending('" + (score >= 3 ? "daylight" : (flags.baronsWon >= 2 && p >= 2) ? "trial" : "catacombs") + "')" }
    ].filter(Boolean));
}
function c2_ending(kind) {
  flags.thorneFate2 = kind;
  flags.chapter = 13;
  goScene("epilogue2");
}

/* ---------- EPILOGUE 2 ---------- */
function epilogue2Scene() {
  const kind = flags.thorneFate2 || "trial";
  const fate = {
    daylight: `You give the square everything, in daylight, from his own balcony: the scout's chained-wrist orders. The depot manifest. Zarga's priced letters${flags.vailYielded ? ". And then Lord-Blade Vail, formally yielded, names the gala knife-man's hiring hand in a voice trained to carry over battlefields" : ""}. The crowd that booed its King in this square hears the arithmetic of its own starvation itemized — and when Thorne finally raises his hands to speak, ten thousand people turn their backs in a single rustling motion. It is the only verdict that was ever going to reach him. The King's justice follows — trial, conviction, the long walk — but Thorne is already gone by then, in every way that mattered to him. ${flags.zargaDeal ? "Zarga attends the trial's final day in full war-paint, presents her invoice to the crown with terrifying courtesy, and is paid from the traitor's estates — the exact gold, to the ounce, that he stole to buy his miracle. She calls it, with evident satisfaction, 'closing the family account.'" : ""}`,
    trial: `The King takes him without a blade drawn — "LAWFULLY," as promised, before the assembled banners. The trial lasts a month and unmakes the Protectorate stone by stone: the true orders read into record, the manifest traced ounce by ounce, the insurance letters deciphered by three independent hands${flags.vailYielded ? ", the Lord-Blade's testimony delivered with a duelist's precision" : ""}. Thorne conducts his own defense, brilliantly, right up until the moment the coward's letter is proven forged by his own commissioned experts — recalled, under oath, and suddenly very talkative. The verdict is unanimous. He thanks the court for its thoroughness. He would have appreciated the bookkeeping.`,
    catacombs: `He is Thorne to the last: mid-sentence, smiling, he steps backward off the balcony's edge — onto the mason's ledge he had cut there years ago, against exactly this dawn — and is gone into the palace's bones, down passages only he ever mapped. They hunt him through the catacombs for three days. It is Sera who finds the end of the trail: the last passage flooded by winter's rains, and the realm's greatest liar drowned in the dark beneath the city he almost owned, his pockets full of sunburst coin and a forged passport to everywhere. The dark, at least, he could not charm.`
  }[kind];
  const realm = [];
  realm.push(`<b>King Alden</b> retakes his throne changed — slower to trust, quicker to listen, and quietly ferocious about paper: the realm's new Charter of Open Ledgers requires every council account audited in public, annually. "The gray man's monument," he calls it.`);
  if ((flags.truth || 0) >= 65) realm.push(`The city that opened its own gates never quite goes back to being governed FROM above — Ironvale's new citizen assemblies argue endlessly, gloriously, and no one can ever again read them a letter and simply be believed.`);
  if (flags.bramSaved) realm.push(`<b>Ser Bram</b> rebuilds the vanguard from the branded and the pardoned, and drills the Ember's baker's boys into the realm's strangest, proudest company.`);
  realm.push(`<b>Sera</b> — huntmaster, spymaster, kingmaker, technically still discharged — refuses every title until Alden simply names the new rangers "Sera's" in the founding charter, which she pretends to hate.`);
  if (flags.zargaDeal && kind !== "daylight") realm.push(`<b>Zarga's</b> invoice is honored to the ounce. The horde winters east, trading instead of raiding, and border children grow up thinking of orc merchants as ordinary — her father's true monument.`);
  const helped = folkHelpedCount();
  if (helped >= 3) realm.push(`And in the small streets, the war has other monuments: Tammis' ovens never cool now, Maribel owns a windowsill in the sun, and the people you helped one by one — the ones nobody paid you for — tell the story of the Ember not as an army, but as <b>a neighbor</b>. That version outlives every ballad.`);
  else if (helped >= 1) realm.push(`And in one small street at least, someone tells the story of the Ember not as an army but as a neighbor — because when nobody was paying, you helped anyway.`);

  const ep = {
    revenge: `Two conspiracies unmasked. Two puppet-masters balanced against their own ledgers. You sit with that for a long while on the palace steps — and find, to your surprise, that the old name carved in your heart weighs almost nothing now. Not because the debt is gone. Because you finally know, twice over and beyond argument, that you are the kind of person who collects. Whoever they are — they should settle up before you come looking.`,
    glory: `They sing both campaigns now — "The Serpent's Fall" and "The Coward King," verse and answer — and yours is the only name in both. When the criers announce the songs in the square where Thorne once framed a king, the crowd doesn't cheer. They go quiet, the way people do for true things. That, you have learned, is the better ending. Louder ones are for villains' speeches.`,
    knowledge: `You keep both ciphers, the forged letter, and — with the court's uneasy permission — Thorne's private notebooks. The design is all there: forty years of kindness laid like masonry, every virtue of a good man load-tested and mapped. You are writing it up properly. Not to admire it — to INOCULATE against it. The next gray man is already being kind to someone, somewhere, and your book intends to be on that someone's shelf.`,
    wealth: `Final accounting, two campaigns: bounties, salvage, baronial gratitude, a crown consultancy on the new audit charter, and a finder's percentage on recovered treasury gold that made Coldbrook himself blink. But the asset that compounds is the reputation: the one who audited a kingdom and balanced it. Coldbrook offers you a partnership. Zarga offers you a job. You are considering — seriously — founding the realm's first honest bank. Fortune favors the bold. Fortunes ENDURE for the audited.`,
    protector: `The widow has her crossbow. The miller's boy holds a spear in Bram's strange proud company. The refugee camps are villages now, with granaries of their own and no one's kindness as their only wall. You stay through the first honest harvest — mending, drilling, teaching arithmetic of the useful kinds — and then you shoulder your pack, because somewhere down the road someone kind is working a quiet ruin on people who trust him. There always is. And now — twice proven — there is also you.`,
    wanderlust: `You leave on the third morning after the trial, when the road-itch wins, carrying the King's open letter of passage — "to every gate in the realm: this one opens things" — and Zarga's safe-conduct through lands no southern boot has trod. East, past the drowned city, they say the sky touches down at the world's rim. You are walking before the palace bells finish ringing. Ironvale waves until you're out of sight. The horizon, as always and forever, waves you onward.`
  }[C.motive.id];

  scene("🌄", "Epilogue — The Coward King, Uncrowned",
    [ `<i>${fate}</i>`, realm.join(" "), `<i>${ep}</i>`,
      `Among Thorne's effects, the clerks catalogue one item no one can place: an unopened letter, sealed in <b>gray wax</b> with the device of a chair. Inside, a single line in a courtly cipher the crown's readers crack in an afternoon — and wish they hadn't:`,
      `<i>"To our brother in Ironvale — the Second Chair grows impatient with your theater. The nation has other cities. The Circle has other chairs. — V."</i>`,
      `<b>Other cities. Other chairs.</b> Thaddeus Thorne, it turns out, was not a spider. He was a strand. <i>The story of the nation continues in the campaigns to come.</i>` ],
    [],
    `<div class="panel epilogue center" style="margin-top:14px">
      <h3>⚔ ${esc(C.name)}'s Legend, Complete ⚔</h3>
      <p>Level ${C.level} ${C.race.name} ${C.cls.name} · ${C.origin.name} · ${C.event.name} · ${C.motive.name}</p>
      <p><b>XP:</b> ${C.xp} &nbsp; <b>Gold:</b> ${C.gold} &nbsp; <b>Hearts of the City:</b> ${flags.truth || 0}/100 &nbsp; <b>Banners:</b> ${flags.baronsWon || 0}/3</p>
      <p class="flavor">Two campaigns. Two conspiracies. One hero the gray men of the world now warn each other about. The dice rest — until Emberfall needs them again.</p>
      <div class="action-row" style="margin-top:10px">
        <button onclick="showSaveScreen()">🪶 Keep this legend's save code</button>
        <button class="primary" onclick="restartAll()">📖 Forge a New Hero</button>
      </div>
    </div>`);
}

