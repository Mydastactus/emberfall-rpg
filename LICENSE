  () => patrolFightIntro("Roadside Ambush", "Two goblins burst from the ditch-brush with the confidence of creatures who have not yet met you.", ["goblin", "goblin2"], "Jagged blades, bad intentions, worse judgment."),
  () => patrolFightIntro("A Winter-Hungry Wolf", "A lone wolf pacing the treeline decides you look slower than a deer. It is mistaken about several things.", ["wolf"], "It circles once, twice — then commits."),
  () => { // overturned cart
    const res = sceneCheck("Athletics", 12);
    if (res.success) { const xp = patrolXp(60); C.gold += 25;
      scene("🛞", "The Overturned Cart", [ `A grain cart lies wheels-up in the ditch, its carter pinned and hollering. You set your back under the frame and heave it upright. He presses <b>25 gold</b> on you and refuses to take no. <b>(+${xp} XP)</b>` ],
        [ { txt: "🏙 Back to the city", onclick: `grantXp(${xp},'a good deed with leverage'); goScene('town')` } ]);
    } else { const dmg = d(4); C.hp = Math.max(1, C.hp - dmg);
      scene("🛞", "The Overturned Cart", [ `The cart shifts wrong and takes a bite of your shoulder before settling. <b>(−${dmg} HP)</b> The carter wriggles free on his own and shares his lunch by way of thanks. <b>(+${patrolXp(25)} XP)</b>` ],
        [ { txt: "🏙 Back to the city", onclick: `grantXp(${patrolXp(25)},'an honest attempt'); goScene('town')` } ]);
    }
  },
  () => { // lost child
    const res = sceneCheck("Survival", 11);
    const xp = patrolXp(res.success ? 70 : 30);
    flags.citizenRep = (flags.citizenRep || 0) + (res.success ? 1 : 0);
    scene("🏮", "The Miller's Girl", [ res.success
      ? `A frantic mother, a missing daughter, and a cold trail into the pinewood. You read the broken bracken like a letter and find the girl asleep in a hollow log, furious at being rescued. The mill district will remember this. <b>(+${xp} XP, reputation grows)</b>`
      : `You search the pinewood until dusk and find nothing — but your shouting flushes the girl out of hiding on its own, indignant and perfectly fine. Less heroic than intended. Still counts. <b>(+${xp} XP)</b>` ],
      [ { txt: "🏙 Back to the city", onclick: `grantXp(${xp},'the miller\\'s girl'); goScene('town')` } ]);
  }
];
