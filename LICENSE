/* ---------------- STATE ---------------- */
let C = null; // the character
let creation = { step: 0, name: "", race: null, cls: null, scores: {}, pool: [], method: null, origin: null, event: null, motive: null };
const STEPS = ["Name", "Race", "Class", "Abilities", "Origin", "Defining Event", "Motivation", "Review"];
let diceLogEntries = [];
let flags = {}; // adventure flags: usedGrimResolve, usedTruesight, usedFeyCharm, amuletUsed, relentlessUsed, rescuedPrisoner, etc.

const $ = id => document.getElementById(id);
const main = () => $("main");
const esc = s => String(s).replace(/[&<>"']/g, c => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));

function diceFloat(text) {
  sfx("dice");
  const el = document.createElement("div");
  el.className = "dice-float"; el.textContent = text;
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 950);
}

function logRoll(label, detail, cls) {
  diceLogEntries.unshift({ label, detail, cls });
  if (diceLogEntries.length > 40) diceLogEntries.pop();
  const el = $("dice-log");
  if (el) el.innerHTML = diceLogEntries.map(e =>
    `<div class="roll-entry ${e.cls || ""}"><b>${esc(e.label)}</b><div class="roll-detail">${esc(e.detail)}</div></div>`).join("");
}

/* d20 with halfling luck + advantage support */
function d20(adv) {
  let r = d(20), note = "";
  if (C && C.lucky && r === 1) { const rr = d(20); note = ` (Lucky! rerolled 1 → ${rr})`; r = rr; }
  if (adv) {
    let r2 = d(20);
    if (C && C.lucky && r2 === 1) r2 = d(20);
    note += ` (advantage: ${r}, ${r2})`;
    r = Math.max(r, r2);
  }
  return { r, note };
}

/* Skill/ability check */
function check(skillOrAbil, dc, opts = {}) {
  const abil = SKILLS[skillOrAbil] || skillOrAbil;
  let bonus = mod(C.scores[abil]);
  let profNote = "";
  if (SKILLS[skillOrAbil] && C.profs.includes(skillOrAbil)) { bonus += profBonus(); profNote = " +prof"; }
  if (skillOrAbil === "Stealth" && C.cls.id === "rogue" && C.armorId && ["medium", "heavy"].includes(curArmor().weight)) { bonus -= 2; profNote += " −2 heavy armor"; }
  if (C.motive.id === "knowledge" && (abil === "INT" || abil === "WIS")) bonus += 1;
  if (C.motive.id === "wanderlust" && abil === "DEX" && !SKILLS[skillOrAbil]) bonus += 1;
  const { r, note } = d20(opts.adv);
  const total = r + bonus;
  const success = total >= dc || r === 20;
  const crit = r === 20;
  diceFloat("🎲 " + r);
  logRoll(
    `${skillOrAbil} check ${success ? "✓" : "✗"}`,
    `d20(${r})${note} ${fmtMod(bonus)}${profNote} = ${total} vs DC ${dc}`,
    crit ? "crit" : success ? "success" : "fail"
  );
  return { success, total, r, crit };
}

/* ============================================================
   CHARACTER CREATION WIZARD
   ============================================================ */
function stepBar() {
  return `<div class="step-bar">` + STEPS.map((s, i) =>
    `<span class="step-pip ${i === creation.step ? "active" : i < creation.step ? "done" : ""}">${i < creation.step ? "✓ " : ""}${s}</span>`).join("") + `</div>`;
}

function navRow(canNext, nextLabel) {
  return `<div class="nav-row">
    <button onclick="prevStep()" ${creation.step === 0 ? "disabled" : ""}>← Back</button>
    <button class="primary" onclick="nextStep()" ${canNext ? "" : "disabled"}>${nextLabel || "Continue →"}</button>
  </div>`;
}

function prevStep() { if (creation.step > 0) { creation.step--; renderCreation(); } }
function nextStep() { creation.step++; if (creation.step >= STEPS.length) return; renderCreation(); }

function pickCard(kind, idx) {
  const src = { race: RACES, cls: CLASSES, origin: ORIGINS, event: EVENTS, motive: MOTIVES }[kind];
  creation[kind] = src[idx];
  renderCreation();
}

function rollRandom(kind) {
  const src = { race: RACES, cls: CLASSES, origin: ORIGINS, event: EVENTS, motive: MOTIVES }[kind];
  const i = rand(src.length);
  diceFloat("🎲 " + (i + 1));
  creation[kind] = src[i];
  renderCreation();
}

function cardGrid(kind, list) {
  return `<div class="choice-grid">` + list.map((o, i) => `
    <div class="card ${creation[kind] && creation[kind].id === o.id ? "selected" : ""}" onclick="pickCard('${kind}',${i})">
      <div class="card-name">${o.icon} ${o.name}</div>
      <div class="card-tag">${o.tag}</div>
      <div class="card-desc">${o.desc}</div>
      <div class="card-perk">${o.perk}</div>
    </div>`).join("") + `</div>`;
}

function rollBtn(kind, label) {
  return `<div class="center" style="margin-top:8px"><button onclick="rollRandom('${kind}')">🎲 ${label || "Let the dice decide"}</button></div>`;
}

/* --- ability scores --- */
function rollPool() {
  creation.method = "rolled";
  creation.pool = [];
  for (let i = 0; i < 6; i++) {
    const rolls = [d(6), d(6), d(6), d(6)].sort((a, b) => b - a);
    creation.pool.push(rolls[0] + rolls[1] + rolls[2]);
  }
  creation.pool.sort((a, b) => b - a);
  diceFloat("🎲🎲🎲");
  logRoll("Ability scores rolled", "4d6 drop lowest × 6 → " + creation.pool.join(", "), "success");
  autoAssign();
}
function useArray() {
  creation.method = "array";
  creation.pool = [15, 14, 13, 12, 10, 8];
  autoAssign();
}
function autoAssign() {
  const prio = (creation.cls ? creation.cls.statPriority : ["STR","DEX","CON","INT","WIS","CHA"]);
  const sorted = [...creation.pool].sort((a, b) => b - a);
  creation.scores = {};
  prio.forEach((abil, i) => creation.scores[abil] = sorted[i]);
  renderCreation();
}
function swapAssign(abil, val) {
  val = parseInt(val);
  // swap with whichever ability currently holds val (keeps the pool consistent)
  const holder = ABILITIES.find(a => creation.scores[a] === val && a !== abil);
  const old = creation.scores[abil];
  creation.scores[abil] = val;
  if (holder !== undefined) creation.scores[holder] = old;
  renderCreation();
}

function finalScores() {
  const s = {};
  ABILITIES.forEach(a => {
    s[a] = (creation.scores[a] || 8)
      + (creation.race.bonus[a] || 0)
      + ((creation.origin.bonus && creation.origin.bonus[a]) || 0);
  });
  return s;
}

function surpriseMe() {
  creation.race = RACES[rand(RACES.length)];
  creation.cls = CLASSES[rand(CLASSES.length)];
  creation.origin = ORIGINS[rand(ORIGINS.length)];
  creation.event = EVENTS[rand(EVENTS.length)];
  creation.motive = MOTIVES[rand(MOTIVES.length)];
  rollPool(); // also auto-assigns + renders
  creation.step = 7;
  renderCreation();
}

const NAME_SEEDS = ["Kaelen","Brynna","Thorvald","Seraphine","Dorn","Elowen","Garrick","Isolde","Fenwick","Mira","Aldric","Tamsin","Osric","Lyra","Baldric","Wren"];

function renderCreation() {
  const c = creation;
  let body = "";
  switch (c.step) {
    case 0:
      body = `<div class="panel fade-in"><h2>Who Are You?</h2>
        <p class="flavor">Every legend begins with a name whispered in a tavern.</p>
        <input type="text" id="name-input" placeholder="Enter your hero's name..." value="${esc(c.name)}" maxlength="24"
          oninput="creation.name=this.value; document.getElementById('btn-next-name').disabled = !this.value.trim()">
        <div style="margin-top:10px"><button onclick="creation.name = NAME_SEEDS[rand(NAME_SEEDS.length)]; renderCreation()">🎲 Random name</button></div>
        <div class="nav-row">
          <button onclick="surpriseMe()" title="Randomize everything">✨ Surprise me — random everything</button>
          <button class="primary" id="btn-next-name" onclick="if(!creation.name.trim())creation.name=NAME_SEEDS[rand(NAME_SEEDS.length)];nextStep()" ${c.name.trim() ? "" : "disabled"}>Continue →</button>
        </div></div>`;
      break;
    case 1:
      body = `<div class="panel fade-in"><h2>Choose Your Race</h2>
        <p class="flavor">Blood remembers, even when the mind forgets.</p>
        ${cardGrid("race", RACES)}${rollBtn("race")}${navRow(!!c.race)}</div>`;
      break;
    case 2:
      body = `<div class="panel fade-in"><h2>Choose Your Class</h2>
        <p class="flavor">The world will test you. How will you answer?</p>
        ${cardGrid("cls", CLASSES)}${rollBtn("cls")}${navRow(!!c.cls)}</div>`;
      break;
    case 3: {
      let poolHtml = "";
      if (c.pool.length) {
        poolHtml = `<div class="pool">` + c.pool.map(v => `<div class="die-score">${v}</div>`).join("") + `</div>
        <h3>Assign your scores</h3>
        <p class="flavor">Swap freely — or trust the recommended layout for a ${esc(c.cls.name)}.</p>
        <div class="stat-grid">` + ABILITIES.map(a => {
          const raw = c.scores[a], racial = (c.race.bonus[a] || 0);
          return `<div class="stat-box"><div class="stat-name">${ABILITY_NAMES[a]}</div>
            <select onchange="swapAssign('${a}', this.value)">${[...new Set(c.pool)].sort((x,y)=>y-x).map(v => `<option value="${v}" ${v === raw ? "selected" : ""}>${v}</option>`).join("")}</select>
            <div class="stat-mod">${racial ? `+${racial} racial → <b>${raw + racial}</b> (${fmtMod(mod(raw + racial))})` : `mod ${fmtMod(mod(raw))}`}</div>
          </div>`;
        }).join("") + `</div>
        <div class="center"><button onclick="autoAssign()">⚖ Recommended for ${esc(c.cls.name)}</button></div>`;
      }
      body = `<div class="panel fade-in"><h2>Forge Your Abilities</h2>
        <p class="flavor">Fate deals the hand; you choose how to play it.</p>
        <div class="action-row">
          <button class="${c.method === "rolled" ? "primary" : ""}" onclick="rollPool()">🎲 Roll 4d6, drop lowest ${c.method === "rolled" ? "(reroll)" : ""}</button>
          <button class="${c.method === "array" ? "primary" : ""}" onclick="useArray()">📋 Standard array (15,14,13,12,10,8)</button>
        </div>
        ${poolHtml}${navRow(c.pool.length > 0)}</div>`;
      break;
    }
    case 4:
      body = `<div class="panel fade-in"><h2>Your Origin</h2>
        <p class="flavor">Before the sword, before the spell — where did your story begin?</p>
        ${cardGrid("origin", ORIGINS)}${rollBtn("origin")}${navRow(!!c.origin)}</div>`;
      break;
    case 5:
      body = `<div class="panel fade-in"><h2>Your Defining Event</h2>
        <p class="flavor">One moment split your life into before and after.</p>
        ${cardGrid("event", EVENTS)}${rollBtn("event")}${navRow(!!c.event)}</div>`;
      break;
    case 6:
      body = `<div class="panel fade-in"><h2>Your Motivation</h2>
        <p class="flavor">Why do you sharpen the blade? Why do you open the book?</p>
        ${cardGrid("motive", MOTIVES)}${rollBtn("motive")}${navRow(!!c.motive)}</div>`;
      break;
    case 7: {
      const s = finalScores();
      const hp = previewHP(s);
      body = `<div class="panel fade-in"><h2>The Ledger of Fate</h2>
        <p class="flavor">Read it well, hero. The ink dries when you sign.</p>
        <div class="sheet-block"><b>${esc(c.name)}</b> — ${c.race.icon} ${c.race.name} ${c.cls.icon} ${c.cls.name}<br>
        <span class="card-tag">${c.origin.name} · ${c.event.name} · driven by ${c.motive.name}</span></div>
        <div class="stat-grid">` + ABILITIES.map(a =>
          `<div class="stat-box"><div class="stat-name">${a}</div><div class="stat-val">${s[a]}</div><div class="stat-mod">${fmtMod(mod(s[a]))}</div></div>`).join("") + `</div>
        <div class="sheet-block"><b>HP:</b> ${hp} &nbsp; <b>AC:</b> ${c.cls.ac} &nbsp; <b>Weapon:</b> ${c.cls.weapon.name} (1d${c.cls.weapon.dmg[1]})<br>
        <b>Your story:</b> ${buildBackstoryProse()}</div>
        <div class="sheet-block"><b>Perks:</b><br>
          <span class="tag">${c.race.perk}</span><span class="tag">${c.cls.perk}</span><span class="tag">${c.origin.perk}</span><span class="tag">${c.event.perk}</span><span class="tag">${c.motive.perk}</span></div>
        <div class="nav-row">
          <button onclick="prevStep()">← Back</button>
          <button class="primary" onclick="finalizeCharacter()">✒ Sign the Ledger — Begin the Adventure</button>
        </div></div>`;
      break;
    }
  }
  main().innerHTML = stepBar() + body;
  if (c.step === 0) { const inp = $("name-input"); if (inp) { inp.focus(); inp.setSelectionRange(inp.value.length, inp.value.length); } }
}

function previewHP(s) {
  const c = creation;
  return c.cls.hitDie + mod(s.CON)
    + (c.race.hpBonus || 0) + (c.origin.hpBonus || 0) + (c.motive.hpBonus || 0);
}

function buildBackstoryProse() {
  const c = creation;
  const originProse = {
    noble: "raised among silk and scheming in a noble house", urchin: "raised by the cold charity of city alleys",
    farm: "raised on honest soil and harder work", temple: "raised in candlelight and quiet prayer",
    soldier: "raised amid the drums and dust of a war camp", scholar: "raised in the ink-scented stacks of a great library" };
  const eventProse = {
    dragonfire: "you walked alive out of dragonfire that claimed everything else", betrayed: "a trusted friend's betrayal taught you to read the truth in people's eyes",
    tournament: "you once took a champion's wreath before a roaring crowd", greatfire: "a single night of fire took all you had — and forged something harder in its place",
    stranger: "a nameless stranger once pulled you back from death and left only an amulet behind", fey: "the fey touched your fate in a mushroom ring and never quite let go" };
  const motiveProse = {
    revenge: "Now a debt of vengeance drives you forward.", glory: "Now you chase a name that will outlive you.",
    knowledge: "Now every secret in the world calls to you.", wealth: "Now fortune itself is your compass.",
    protector: "Now you stand wherever the weak cannot.", wanderlust: "Now the horizon owns your heart." };
  return `${esc(c.name)} was ${originProse[c.origin.id]}. One day, ${eventProse[c.event.id]}. ${motiveProse[c.motive.id]}`;
}

function finalizeCharacter() {
  const cr = creation;
  const s = finalScores();
  const profs = [...new Set([...(cr.race.skills || []), ...cr.cls.skills, ...(cr.origin.skills || []), ...(cr.event.skills || []), ...(cr.motive.skills || [])])];
  const maxHp = previewHP(s);
  const items = ["Healing potion", ...(cr.origin.items || []), ...(cr.event.items || [])];
  C = {
    name: cr.name.trim(), race: cr.race, cls: cr.cls, origin: cr.origin, event: cr.event, motive: cr.motive,
    scores: s, profs, maxHp, hp: maxHp, ac: cr.cls.ac,
    gold: 25 + (cr.origin.gold || 0) + (cr.motive.gold || 0),
    xp: 0, level: 1, items,
    atkBonus: (cr.origin.atkBonus || 0), dmgBonus: (cr.event.dmgBonus || 0),
    weaponTier: 0, armorTier: 0, initBonus: 0, ward: false, luckyCharm: false,
    skillsTrained: 0, statsTrained: 0,
    lucky: !!cr.race.lucky, relentless: !!cr.race.relentless, breath: !!cr.race.breath,
    backstoryProse: buildBackstoryProse()
  };
  C.weaponId = DEFAULT_WEAPON[cr.cls.id];
  C.armorId = DEFAULT_ARMOR[cr.cls.id];
  C.shield = cr.cls.id === "cleric";
  C.spells = [];
  C.ownedWeapons = [C.weaponId];
  C.ownedArmors = [C.armorId];
  C.weaponMats = { [C.weaponId]: "bronze" }; C.weaponDurs = { [C.weaponId]: MATERIALS.bronze.dur };
  C.armorMats = { [C.armorId]: "bronze" }; C.armorDurs = { [C.armorId]: MATERIALS.bronze.dur };
  C.perks = [];
  C.pendingPerks = [1];
  recomputePerkFx();
  flags = { m: {}, evidence: [], chapter: 1, thorneTrust: 0, citizenRep: 0 };
  diceLogEntries = [];
  recomputeAC();
  goScene("prologue");
}

/* ============================================================
   GAME LAYOUT & SIDEBAR
   ============================================================ */
function hpBarClass() {
  const pct = C.hp / C.maxHp;
  return pct > 0.6 ? "healthy" : pct > 0.3 ? "wounded" : "";
}

function sidebar() {
  return `
  <div class="side-panel">
    <h3><span class="side-mini">${PORTRAITS[C.cls.id] || C.race.icon}</span>${esc(C.name)} · Lv ${C.level}</h3>
    <div class="card-tag">${C.race.name} ${C.cls.name} · ${C.origin.name}</div>
    <div style="font-size:.78em;color:var(--ink-dim);margin-top:2px">${esc(weaponName())} · ${esc(armorDisplayName())}</div>
    ${durChip()}
    <div style="font-size:.85em; margin-top:6px">HP ${C.hp}/${C.maxHp}</div>
    <div class="hp-bar-wrap"><div class="hp-bar ${hpBarClass()}" style="width:${Math.max(0, C.hp / C.maxHp * 100)}%"></div></div>
    ${xpToNext() ? `<div style="font-size:.78em;color:var(--ink-dim)">XP ${C.xp} / ${xpToNext()} to Lv ${C.level + 1}</div>
    <div class="hp-bar-wrap" style="height:8px"><div class="hp-bar" style="width:${Math.min(100, (C.xp - XP_LEVELS[C.level]) / (xpToNext() - XP_LEVELS[C.level]) * 100)}%; background: linear-gradient(90deg,#6d5518,#c9a227)"></div></div>` : `<div style="font-size:.78em;color:var(--gold)">Max level · XP ${C.xp}</div>`}
    <div class="mini-stats">
      ${ABILITIES.map(a => `<div><div class="lbl">${a}</div><b>${C.scores[a]}</b> ${fmtMod(mod(C.scores[a]))}</div>`).join("")}
    </div>
    <div class="mini-stats" style="margin-top:6px">
      <div><div class="lbl">AC</div><b>${C.ac}</b></div>
      <div><div class="lbl">Gold</div><b>${C.gold}</b></div>
      <div><div class="lbl">Tier</div><b style="font-size:.8em">${weaponAtkBonus() ? "+" + weaponAtkBonus() : "—"}</b></div>
    </div>
  </div>
  ${(flags.evidence && flags.evidence.length) ? `<div class="side-panel"><h3>🧾 ${flags.chapter >= 7 ? "Proofs" : "Evidence"}</h3>
    <ul class="inv-list">${flags.evidence.map(e => `<li>${esc(EVIDENCE[e].name)}</li>`).join("")}</ul>
    ${flags.chapter <= 6 ? `<div class="card-tag" style="margin-top:4px">Weight: ${evidenceWeight()} — to convince the King outright, 5+</div>` : ""}
  </div>` : ""}
  ${(flags.chapter >= 8 && flags.chapter <= 12 && typeof flags.truth === "number") ? `<div class="side-panel"><h3>🗣 Hearts of the City</h3>
    <div class="hp-bar-wrap"><div class="hp-bar" style="width:${Math.min(100, flags.truth)}%; background: linear-gradient(90deg,#4a6d8c,#8ab4d8)"></div></div>
    <div class="card-tag">Truth believed: ${flags.truth}/100 — at 65+, Ironvale rises with you</div>
  </div>` : ""}
  <div class="side-panel"><h3>🎒 Inventory</h3>
    <ul class="inv-list">${C.items.length ? C.items.map(i => `<li>${esc(i)}</li>`).join("") : "<li>Empty pockets</li>"}</ul>
    ${(!combat || combat.over) && C.hp < C.maxHp && hasPotion()
      ? `<div class="center" style="margin-top:8px"><button style="font-size:.85em;padding:6px 12px" onclick="sidebarPotion()">🧪 Drink a healing potion</button></div>` : ""}
    ${(!combat || combat.over) && C.hp < C.maxHp && C.items.includes("Field Bandages")
      ? `<div class="center" style="margin-top:6px"><button style="font-size:.85em;padding:6px 12px" onclick="sidebarBandage()">🩹 Apply bandages</button></div>` : ""}
    ${(!combat || combat.over) && C.items.includes("Smith's Kit") && gearNeedsKit()
      ? `<div class="center" style="margin-top:6px"><button style="font-size:.85em;padding:6px 12px" onclick="useSmithKit()">🧰 Smith's Kit (+5 durability)</button></div>` : ""}
    ${(!combat || combat.over) && C.hp < C.maxHp && C.items.includes("Tammis' Seedcake")
      ? `<div class="center" style="margin-top:6px"><button style="font-size:.85em;padding:6px 12px" onclick="useSeedcake()">🍞 Eat Tammis' seedcake</button></div>` : ""}
  </div>
  <div class="side-panel"><h3>🎲 Dice Log</h3><div id="dice-log">${diceLogEntries.map(e =>
    `<div class="roll-entry ${e.cls || ""}"><b>${esc(e.label)}</b><div class="roll-detail">${esc(e.detail)}</div></div>`).join("") || '<span class="card-tag">The dice await...</span>'}</div>
  </div>`;
}

function renderGame(contentHtml) {
  updateSheetBtn();
  main().innerHTML = `<div id="game-layout" class="fade-in">
    <div>${contentHtml}</div>
    <div id="sidebar-col">${sidebar()}</div>
  </div>`;
}

function sidebarPotion() {
  if (combat && !combat.over) return;
  if (usePotion()) { const sc = $("sidebar-col"); if (sc) sc.innerHTML = sidebar(); }
}

function heal(amount, label) {
  sfx("heal");
  const before = C.hp;
  C.hp = Math.min(C.maxHp, C.hp + amount);
  logRoll(label || "Healing", `+${C.hp - before} HP (${C.hp}/${C.maxHp})`, "success");
}

function hasPotion() { return C.items.includes("Healing potion") || C.items.includes("Greater healing potion") || C.items.includes("Superior healing potion"); }
function usePotion() {
  const pm = pfx().potionMult || 1;
  const si = C.items.indexOf("Superior healing potion");
  if (si !== -1) {
    C.items.splice(si, 1);
    heal(Math.round((roll(3, 8).total + 9) * pm), "🧪 Superior healing potion" + (pm > 1 ? " (perked!)" : ""));
    return true;
  }
  const gi = C.items.indexOf("Greater healing potion");
  if (gi !== -1) {
    C.items.splice(gi, 1);
    heal(Math.round((roll(2, 8).total + 6) * pm), "🧪 Greater healing potion" + (pm > 1 ? " (perked!)" : ""));
    return true;
  }
  const i = C.items.indexOf("Healing potion");
  if (i === -1) return false;
  C.items.splice(i, 1);
  heal(Math.round((roll(2, 4).total + 4) * pm), "🧪 Healing potion" + (pm > 1 ? " (perked!)" : ""));
  return true;
}

/* ============================================================
   COMBAT ENGINE
   ============================================================ */
let combat = null;

function startCombat(monsterIds, victoryScene, opts = {}) {
  const foes = monsterIds.map((id, i) => {
    const m = MONSTERS[id];
    return { ...m, id: id + "_" + i, hp: m.hp, maxHp: m.hp };
  });
  let abilityMax = (C.cls.ability.id === "cure" ? 2 : 1) + (C.level >= 4 ? 1 : 0) + (C.level >= 8 ? 1 : 0) + (pfx().abilityUse || 0);
  combat = {
    foes, victoryScene, log: [], over: false,
    playerTurn: true, round: 1,
    usedAbility: 0, abilityMax,
    usedBreath: false, marked: false, surprise: !!opts.surprise, fled: false, spellsUsed: {}, noFlee: !!opts.noFlee,
    fleeScene: opts.fleeScene || null, intro: opts.intro || "",
    ally: opts.ally || null,
    spellFree: (pfx().spellExtra ? 1 : 0) + (pfx().spellExtra2 ? 1 : 0)
  };
  C.status = { stunned: 0, slowed: 0, shaken: 0, poison: 0, stunImmune: 0, defending: false };
  sfx("sting");
  try { AudioSys.setAmbient(foes.some(f => f.maxHp >= 40) ? "boss" : "battle"); } catch (e) {}
  // initiative
  let initBonus = mod(C.scores.DEX) + (C.motive.id === "glory" ? 2 : 0) + (C.initBonus || 0) + (pfx().init || 0);
  const { r } = d20();
  const init = r + initBonus;
  const foeInit = d(20) + 2;
  combat.playerTurn = opts.surprise ? true : init >= foeInit;
  logRoll("Initiative", `You: d20(${r})${fmtMod(initBonus)} = ${init} vs foes: ${foeInit}${opts.surprise ? " — you strike from surprise!" : ""}`, combat.playerTurn ? "success" : "fail");
  clog(`⚔ Combat begins! ${combat.playerTurn ? "You act first." : "The enemy acts first!"}`, "sys");
  renderCombat();
  if (!combat.playerTurn) setTimeout(enemyTurn, 700);
}

function clog(msg, cls) {
  combat.log.push({ msg, cls });
  if (combat.log.length > 30) combat.log.shift();
}

function livingFoes() { return combat.foes.filter(f => f.hp > 0); }

function renderCombat() {
  const foesHtml = combat.foes.map(f => `
    <div class="combatant ${f.hp <= 0 ? "dead" : ""}" id="foe-${f.id}">
      <div class="portrait">${PORTRAITS[f.pkey] || f.icon}</div>
      <b>${esc(f.name)}</b>
      <div class="hp-bar-wrap"><div class="hp-bar" style="width:${Math.max(0, f.hp / f.maxHp * 100)}%"></div></div>
      <div class="card-tag">${f.hp > 0 ? f.hp + "/" + f.maxHp + " HP" : f.fled ? "🏃 fled" : "☠ slain"}</div>
      ${f.hp > 0 ? foeStatusChips(f) : ""}
    </div>`).join("");

  const logHtml = combat.log.map(l => `<p class="${l.cls || ""}">${l.msg}</p>`).join("");

  let actions = "";
  if (!combat.over) {
    if (combat.playerTurn && C.status && C.status.stunned > 0) {
      actions = `<div class="action-row"><button class="danger" onclick="stunRecover()">😵 Stunned — fight to clear your head (lose this turn)</button></div>`;
    } else if (combat.playerTurn) {
      const targets = livingFoes();
      const targetBtns = targets.length > 1
        ? targets.map(f => `<button onclick="playerAttack('${f.id}')">⚔ Attack ${esc(f.name)}</button>`).join("")
        : `<button onclick="playerAttack('${targets[0].id}')">⚔ Attack with ${esc(weaponName())}</button>`;
      actions = `<div class="action-row">
        ${targetBtns}
        <button onclick="useClassAbility()" ${(combat.usedAbility >= combat.abilityMax || (C.cls.ability.id === "mark" && combat.marked)) ? "disabled" : ""}>✨ ${C.cls.ability.name} ${combat.abilityMax > 1 ? `(${combat.abilityMax - combat.usedAbility} left)` : combat.usedAbility ? "(used)" : ""}</button>
        ${C.breath ? `<button onclick="useBreath()" ${combat.usedBreath ? "disabled" : ""}>🔥 Fire Breath ${combat.usedBreath ? "(used)" : ""}</button>` : ""}
        ${C.cls.id === "wizard" ? C.spells.map(k => {
          const s = WIZ_SPELLS[k];
          const used = combat.spellsUsed && combat.spellsUsed[k];
          const noTarget = k === "sleep" && !livingFoes().some(f => f.maxHp < 50 && !f.asleep);
          return `<button onclick="castSpell('${k}')" ${used || noTarget ? "disabled" : ""}>🪄 ${s.name}${used ? " (used)" : noTarget ? " (no valid target)" : ""}</button>`;
        }).join("") : ""}
        ${C.items.includes("Scroll of Fireball") ? `<button onclick="useFireballScroll()">📜 Fireball Scroll (${C.items.filter(i => i === "Scroll of Fireball").length})</button>` : ""}
        ${C.items.includes("Alchemist's Fire") ? `<button onclick="useAlchFire()">🔥 Alchemist's Fire (${C.items.filter(i => i === "Alchemist's Fire").length})</button>` : ""}
        ${C.items.includes("Field Bandages") && C.hp < C.maxHp ? `<button onclick="useBandageCombat()">🩹 Bandages (${C.items.filter(i => i === "Field Bandages").length})</button>` : ""}
        <button onclick="combatPotion()" ${hasPotion() ? "" : "disabled"}>🧪 Potion (${C.items.filter(i => i.includes("healing potion") || i === "Healing potion").length})</button>
        <button onclick="playerDefend()">🛡 Defend <span class="req">(+3 AC, halves heavy blows)</span></button>
        ${combat.fleeScene ? `<button class="danger" onclick="tryFlee()">🏃 Flee</button>` : ""}
      </div>`;
    } else {
      actions = `<div class="center card-tag">The enemy is acting...</div>`;
    }
  }

  renderGame(`<div class="panel">
    <h2>⚔ Battle — Round ${combat.round}</h2>
    ${combat.intro ? `<p class="flavor">${combat.intro}</p>` : ""}
    <div class="combat-arena">
      <div class="combatant ${C.hp <= 0 ? "dead" : ""}" id="pc-portrait">
        <div class="portrait">${PORTRAITS[C.cls.id] || C.race.icon}</div><b>${esc(C.name)}</b>
        <div class="hp-bar-wrap"><div class="hp-bar ${hpBarClass()}" style="width:${Math.max(0, C.hp / C.maxHp * 100)}%"></div></div>
        <div class="card-tag">${C.hp}/${C.maxHp} HP · AC ${playerEffAC()}</div>
        ${playerStatusChips()}
      </div>
      <div class="vs">VS</div>
      ${foesHtml}
    </div>
    <div class="combat-log" id="clog">${logHtml}</div>
    ${actions}
  </div>`);
  const cl = $("clog"); if (cl) cl.scrollTop = cl.scrollHeight;
}

function weaponAtkBonus() { return [0, 1, 2, 3][C.weaponTier || 0]; }
function weaponDmgBonus() { return [0, 1, 1, 2][C.weaponTier || 0]; }
function weaponName() {
  const base = (weaponWears() && !curWeapon().magic ? MATERIALS[weaponMat()].name + " " : "") + curWeapon().name;
  const n = C.weaponTier === 3 ? "Kingsteel " + curWeapon().name : C.weaponTier === 2 ? "Emberforged " + base : C.weaponTier === 1 ? "Masterwork " + base : base;
  return weaponDulled() ? n + " (dull)" : n;
}
function playerDmgBonus() {
  let b = C.dmgBonus + weaponDmgBonus() + (pfx().dmg || 0);
  if (C.motive.id === "revenge" && C.hp < C.maxHp / 2) b += 2;
  if (pfx().bloodiedDmg && C.hp < C.maxHp / 2) b += pfx().bloodiedDmg;
  return b;
}
function foeImpaired(f) { return !!(f.asleep || f._frost || f._bleed); }

function attackRoll(foe, adv, extraDice) {
  const w = curWeapon();
  const stat = w.stat;
  const atkB = mod(C.scores[stat]) + profBonus() + C.atkBonus + weaponAtkBonus() + w.atk + (C.cls.id === "ranger" && w.tag === "ranged" ? 2 : 0) - (C.status && C.status.shaken ? 2 : 0)
    + (pfx().atk || 0) + (pfx().atkVsImpaired && foeImpaired(foe) ? pfx().atkVsImpaired : 0) - (weaponDulled() ? 2 : 0);
  const { r, note } = d20(adv);
  const foeAc = foe.ac + (foe.stance ? 3 : 0) + (foe.guard ? 3 : 0);
  const total = r + atkB;
  const crit = r >= (pfx().critMin || 20);
  const hit = crit || (r !== 1 && total >= foeAc);
  diceFloat("🎲 " + r);
  logRoll(`Attack ${hit ? (crit ? "CRIT!" : "hits") : "misses"}`, `d20(${r})${note} ${fmtMod(atkB)} = ${total} vs AC ${foeAc}${foe.stance || foe.guard ? " (guarded)" : ""}${C.status && C.status.shaken ? " (shaken −2)" : ""}${weaponDulled() ? " (dull −2)" : ""}`, crit ? "crit" : hit ? "success" : "fail");
  if (!hit) return { hit: false };
  let [n, s] = w.dmg;
  if (crit) n *= 2;
  let dmgRoll = roll(n, s);
  let dmg = dmgRoll.total + mod(C.scores[stat]) + w.dmgB + playerDmgBonus();
  let detail = `${n}d${s}(${dmgRoll.rolls.join("+")}) ${fmtMod(mod(C.scores[stat]) + w.dmgB + playerDmgBonus())}`;
  if (extraDice) {
    const ex = roll(crit ? extraDice[0] * 2 : extraDice[0], extraDice[1]);
    dmg += ex.total; detail += ` + ${ex.rolls.length}d${extraDice[1]}(${ex.total})`;
  }
  if (C.weaponTier >= 2) {
    const fs = C.weaponTier === 3 ? 6 : 4;
    const fire = roll(1, fs); dmg += fire.total; detail += ` + 🔥1d${fs}(${fire.total})`;
  }
  if (w.rider && RIDER_FX[w.rider]) {
    const rd = roll(crit ? 2 : 1, 4); dmg += rd.total; detail += ` + ${RIDER_FX[w.rider].emoji}${crit ? 2 : 1}d4(${rd.total})`;
  }
  if (combat.marked) {
    const mkDice = (C.level >= 9 ? 3 : C.level >= 5 ? 2 : 1) + (pfx().abilityPower && C.cls.id === "ranger" ? 1 : 0);
    const mk = roll(mkDice, 6); dmg += mk.total; detail += ` + mark ${mkDice}d6(${mk.total})`;
  }
  if (crit) combat.pcCrit = true;
  if (crit && foe.hp > 0) {
    if (pfx().shredCrit && !foe._shredded) { foe._shredded = true; foe.ac = Math.max(5, foe.ac - 2); clog(`🛡✂ The critical hit <b>shreds ${esc(foe.name)}'s armor</b> — −2 AC for the rest of the fight!`, "sys"); }
    if ((pfx().bleedCrit || w.bleedCrit) && !foe._bleed) { foe._bleed = 3; clog(`🩸 The wound <b>bleeds</b> — ${esc(foe.name)} takes 1d4 at the start of its turns (3 rounds).`, "sys"); }
    if (pfx().frostCrit && (foe._frost || 0) < 3) { foe._frost = (foe._frost || 0) + 1; foe.atk--; clog(`❄ The crit chills ${esc(foe.name)}'s limbs (−1 to its attacks).`, "sys"); }
  }
  return { hit: true, dmg: Math.max(1, dmg), detail, crit };
}

function dealToFoe(foe, dmg, srcLabel) {
  sfx("hit");
  if (foe.asleep) { foe.asleep = 0; clog(`💤→😠 ${esc(foe.name)} jolts awake!`, "sys"); }
  foe.hp -= dmg;
  const el = $("foe-" + foe.id);
  if (el) { el.classList.add("shake"); }
  clog(`<span class="player-act">${srcLabel} — <b>${dmg}</b> damage to ${esc(foe.name)}.</span>`);
  if (foe.hp <= 0) {
    foe.hp = 0;
    if (combat) combat.slewFoe = true;
    clog(`<b>${esc(foe.name)} is slain!</b>`, "sys");
    if (pfx().killRefund && combat && !combat.over && combat.usedAbility > 0) {
      combat.usedAbility--;
      clog(`♻ The kill steadies you — <b>one use of ${C.cls.ability.name} restored!</b>`, "sys");
    }
    grantXp(foe.xp);
  }
}

function playerAttack(foeId, opts = {}) {
  if (!combat.playerTurn || combat.over || (C.status && C.status.stunned)) return;
  const foe = combat.foes.find(f => f.id === foeId && f.hp > 0) || livingFoes()[0];
  if (!foe) return;
  const res = attackRoll(foe, opts.adv || combat.surprise || !!foe.asleep, opts.extraDice);
  combat.surprise = false;
  if (res.hit) {
    dealToFoe(foe, res.dmg, `${res.crit ? "💥 CRITICAL! " : ""}Your ${curWeapon().name.toLowerCase()} strikes (${res.detail})`);
    if ((curWeapon().effect === "frost" || (C.cls.id === "wizard" && pfx().frostAll)) && foe.hp > 0) {
      foe._frost = foe._frost || 0;
      if (foe._frost < 3) { foe._frost++; foe.atk--; clog(`❄ Frost stiffens ${esc(foe.name)}'s limbs (−1 to its attacks).`, "sys"); }
    }
  }
  else {
    sfx("miss");
    clog(`<span class="player-act">Your attack misses ${esc(foe.name)}.</span>`);
    if (foe.stance && foe.hp > 0) {
      const cd = roll(1, 8).total + Math.max(3, foe.atk - 2);
      clog(`🤺 <b>Riposte!</b> ${esc(foe.name)} answers your miss with a flickering counter.`, "sys");
      if (applyDamageToPlayer(cd, foe.name, { msg: `<span class="enemy-act">The counter-cut takes you for <b>{d}</b> damage.</span>` }) === "dead") return;
    }
  }
  endPlayerTurn();
}

function useClassAbility() {
  if (!combat.playerTurn || combat.over || combat.usedAbility >= combat.abilityMax || (C.status && C.status.stunned)) return;
  const a = C.cls.ability.id;
  combat.usedAbility++;
  if (pfx().healOnAbility && C.hp < C.maxHp) heal(Math.max(1, Math.floor(C.maxHp * 0.05)), "♻ Conditioned Recovery");
  if (a === "secondwind") {
    const h = d(10) + 2 * C.level; heal(h, "Second Wind");
    clog(`<span class="player-act">🛡 Second Wind — you steady your breath and recover <b>${h}</b> HP.</span>`);
    endPlayerTurn();
  } else if (a === "missile") {
    const foe = livingFoes()[0];
    const darts = 3 + (C.level >= 3 ? 1 : 0) + (C.level >= 5 ? 1 : 0) + (C.level >= 7 ? 1 : 0) + (C.level >= 9 ? 1 : 0) + (pfx().abilityPower ? 1 : 0);
    const m = roll(darts, 4); const dmg = m.total + darts;
    diceFloat("✨");
    logRoll("Magic Missile", `${darts}d4(${m.rolls.join("+")})+${darts} = ${dmg} (auto-hit)`, "success");
    dealToFoe(foe, dmg, `✨ ${darts} darts of force slam home (${dmg})`);
    endPlayerTurn();
  } else if (a === "sneak") {
    const foe = livingFoes()[0];
    const dice = 2 + (C.level >= 3 ? 1 : 0) + (C.level >= 5 ? 1 : 0) + (C.level >= 7 ? 1 : 0) + (C.level >= 9 ? 1 : 0) + (curWeapon().sneakDie || 0) + (pfx().abilityPower ? 1 : 0);
    const res = attackRoll(foe, true, [dice, 6]);
    if (res.hit) dealToFoe(foe, res.dmg, `${res.crit ? "💥 CRITICAL! " : ""}🗡 Your blade finds the gap (${res.detail})`);
    else clog(`<span class="player-act">Your cunning strike misses!</span>`);
    endPlayerTurn();
  } else if (a === "cure") {
    const h = d(8) + 3 + C.level + (pfx().abilityPower ? d(8) : 0); heal(h, "Cure Wounds");
    clog(`<span class="player-act">⛪ Golden light knits your wounds — <b>+${h}</b> HP.</span>`);
    endPlayerTurn();
  } else if (a === "mark") {
    if (combat.marked) { combat.usedAbility--; return; }
    combat.marked = true;
    clog(`<span class="player-act">🏹 You mark your quarry (bonus action — you can still attack). All your hits deal +1d6 damage this battle.</span>`, "player-act");
    renderCombat(); // free action: the turn continues
  }
}

function useBreath() {
  if (!combat.playerTurn || combat.over || combat.usedBreath || (C.status && C.status.stunned)) return;
  combat.usedBreath = true;
  sfx("fire");
  const br = roll(C.level >= 7 ? 4 : C.level >= 4 ? 3 : 2, 6);
  diceFloat("🔥");
  logRoll("Fire Breath", `2d6(${br.rolls.join("+")}) = ${br.total} to all foes`, "success");
  livingFoes().forEach(f => dealToFoe(f, br.total, "🔥 Dragonfire washes over the field"));
  endPlayerTurn();
}

function castSpell(k) {
  if (!combat.playerTurn || combat.over || (C.status && C.status.stunned) || !C.spells.includes(k) || (combat.spellsUsed && combat.spellsUsed[k])) return;
  combat.spellsUsed[k] = true;
  let overch = false;
  if ((combat.spellFree || 0) > 0) { combat.spellFree--; combat.spellsUsed[k] = false; overch = true; }
  if (k === "burning") {
    if (overch) clog(`♻ <b>Overcharge!</b> The spell is not expended.`, "sys");
    sfx("fire");
    const dice = (C.level >= 7 ? 4 : 3) + (pfx().abilityPower ? 1 : 0);
    const b = roll(dice, 6);
    diceFloat("🔥");
    logRoll("Burning Hands", `${dice}d6(${b.rolls.join("+")}) = ${b.total} to all foes`, "crit");
    livingFoes().forEach(f => dealToFoe(f, b.total, "🔥 A fan of flame roars across the field"));
    endPlayerTurn();
  } else if (k === "sleep") {
    const target = livingFoes().filter(f => f.maxHp < 50 && !f.asleep).sort((a, b) => a.hp - b.hp)[0];
    if (!target) { combat.spellsUsed[k] = false; if (overch) combat.spellFree++; return; }
    if (overch) clog(`♻ <b>Overcharge!</b> The spell is not expended.`, "sys");
    target.asleep = 2;
    sfx("sleep");
    diceFloat("💤");
    logRoll("Sleep", `${target.name} falls into an enchanted slumber (2 rounds; attacks against it have advantage)`, "success");
    clog(`💤 ${esc(target.name)} sways, drops, and begins — impossibly — to snore.`, "sys");
    endPlayerTurn();
  } else if (k === "lightning") {
    if (overch) clog(`♻ <b>Overcharge!</b> The spell is not expended.`, "sys");
    sfx("fire");
    const foe = livingFoes().sort((a, b) => b.hp - a.hp)[0];
    const b = roll(8, 6);
    diceFloat("⚡");
    logRoll("Lightning Bolt", `8d6(${b.rolls.join("+")}) = ${b.total}`, "crit");
    dealToFoe(foe, b.total, "⚡ Lightning stitches the air");
    endPlayerTurn();
  }
}

function useAlchFire() {
  if (!combat.playerTurn || combat.over || (C.status && C.status.stunned)) return;
  const i = C.items.indexOf("Alchemist's Fire");
  if (i === -1) return;
  C.items.splice(i, 1);
  sfx("fire");
  const foe = livingFoes()[0];
  const b = roll(2, 4);
  diceFloat("🔥");
  logRoll("Alchemist's Fire", `2d4(${b.rolls.join("+")})+2 = ${b.total + 2} (auto-hit)`, "success");
  dealToFoe(foe, b.total + 2, "🔥 The vial shatters — clinging fire");
  endPlayerTurn();
}

function useBandage() {
  const i = C.items.indexOf("Field Bandages");
  if (i === -1) return false;
  C.items.splice(i, 1);
  heal(Math.round((d(4) + 2) * (pfx().potionMult || 1)), "🩹 Field Bandages");
  return true;
}
function useSeedcake() {
  if (combat && !combat.over) return;
  const i = C.items.indexOf("Tammis' Seedcake");
  if (i === -1) return;
  C.items.splice(i, 1);
  heal(Math.round((roll(2, 4).total + 4) * (pfx().potionMult || 1)), "🍞 Tammis' Seedcake");
  const sc = $("sidebar-col"); if (sc) sc.innerHTML = sidebar();
}
function useBandageCombat() {
  if (!combat.playerTurn || combat.over || (C.status && C.status.stunned)) return;
  if (useBandage()) {
    clog(`<span class="player-act">🩹 You bind the worst of it mid-fight. (${C.hp}/${C.maxHp} HP)</span>`);
    if (punishOpening("your busy hands") === "dead") return;
    endPlayerTurn();
  }
}
function sidebarBandage() {
  if (combat && !combat.over) return;
  if (useBandage()) { const sc = $("sidebar-col"); if (sc) sc.innerHTML = sidebar(); }
}

function useFireballScroll() {
  if (!combat.playerTurn || combat.over || (C.status && C.status.stunned)) return;
  const i = C.items.indexOf("Scroll of Fireball");
  if (i === -1) return;
  C.items.splice(i, 1);
  const fb = roll(6, 6);
  sfx("fire");
  diceFloat("🔥");
  logRoll("Scroll of Fireball", `6d6(${fb.rolls.join("+")}) = ${fb.total} to all foes`, "crit");
  clog(`📜 The scroll ignites — a bead of flame streaks out and <b>detonates</b>!`, "sys");
  livingFoes().forEach(f => dealToFoe(f, fb.total, "🔥 The fireball engulfs the field"));
  endPlayerTurn();
}

function combatPotion() {
  if (!combat.playerTurn || combat.over || (C.status && C.status.stunned)) return;
  if (usePotion()) {
    clog(`<span class="player-act">🧪 You gulp a healing potion. (${C.hp}/${C.maxHp} HP)</span>`);
    if (punishOpening("the bottle at your lips") === "dead") return;
    endPlayerTurn();
  }
}

/* Duelists punish openings — drinking or binding wounds in front of them costs a free attack. */
function punishOpening(what) {
  if (!combat || combat.over) return "ok";
  const foe = livingFoes().find(f => f.tr && f.tr.moves.includes("punish"));
  if (!foe) return "ok";
  clog(`🤺 <b>${esc(foe.name)} does not wait</b> — the blade darts in at ${what}!`, "sys");
  return foeAttack(foe, { label: "punishing thrust" }) === "dead" ? "dead" : "ok";
}

function tryFlee() {
  if (!combat.playerTurn || combat.over || (C.status && C.status.stunned)) return;
  const res = check("Athletics", 12);
  if (res.success) {
    combat.over = true; combat.fled = true;
    clog("🏃 You break away and escape into the shadows!", "sys");
    wearGear();
    renderCombat();
    setTimeout(() => goScene(combat.fleeScene), 1100);
  } else {
    clog(`<span class="enemy-act">You try to flee, but they cut off your escape!</span>`);
    endPlayerTurn();
  }
}

function endPlayerTurn() {
  if (checkCombatEnd()) return;
  combat.playerTurn = false;
  renderCombat();
  setTimeout(enemyTurn, 800);
}

/* ============================================================
   COMBAT CORE v2 — saves, statuses, enemy AI, boss moves
   ============================================================ */
function saveRoll(abil, dc, opts = {}) {
  let bonus = mod(C.scores[abil]);
  let adv = !!opts.adv;
  if (pfx()["saveAdv" + abil]) adv = true;
  if (abil === "CON" && opts.poison && C.race.id === "dwarf") { adv = true; }
  if (C.status && C.status.defending && (abil === "CON" || abil === "WIS")) adv = true;
  const { r, note } = d20(adv);
  const total = r + bonus;
  const ok = total >= dc || r === 20;
  logRoll(`${ABILITY_NAMES[abil]} save ${ok ? "✓" : "✗"}`, `d20(${r})${note} ${fmtMod(bonus)} = ${total} vs DC ${dc}`, ok ? "success" : "fail");
  return ok;
}

function playerEffAC() {
  return C.ac + (C.status.defending ? 3 : 0) - (C.status.slowed > 0 ? 2 : 0);
}

/* All damage to the player funnels through here (shields, wards, phoenix, relentless, death). */
function applyDamageToPlayer(dmg, srcName, opts = {}) {
  if (!opts.bypassWards) {
    if (C.cls.id === "wizard" && !combat.wizShieldUsed) {
      combat.wizShieldUsed = true;
      dmg = Math.max(1, Math.floor(dmg / 2));
      clog(`🛡 A shimmering Shield spell flashes — the blow is half-turned!`, "sys");
    } else if (C.ward && !combat.wardUsed) {
      combat.wardUsed = true;
      dmg = Math.max(1, Math.floor(dmg / 2));
      clog(`🧿 Your Amulet of Warding flares — the blow is half-turned!`, "sys");
    } else if (pfx().ward && !combat.perkWardUsed) {
      combat.perkWardUsed = true;
      dmg = Math.max(1, Math.floor(dmg / 2));
      clog(`🌀 You are simply not quite where the blow lands — <b>halved!</b>`, "sys");
    } else if (pfx().ward2 && !combat.perkWard2Used) {
      combat.perkWard2Used = true;
      dmg = Math.max(1, Math.floor(dmg / 2));
      clog(`🌀 Again you slip the worst of it — <b>halved!</b>`, "sys");
    }
    if (C.event.id === "stranger" && !flags.amuletUsed && (C.hp - dmg) < C.maxHp / 2 && C.hp >= C.maxHp / 2) {
      dmg = Math.ceil(dmg / 2); flags.amuletUsed = true;
      clog(`🌟 Your strange amulet flares — the blow is half-turned aside!`, "sys");
    }
    if (pfx().flatDR) dmg = Math.max(1, dmg - pfx().flatDR);
  }
  C.hp -= dmg;
  sfx("thud");
  const pc = $("pc-portrait"); if (pc) pc.classList.add("shake");
  if (opts.msg) clog(opts.msg.replace("{d}", dmg));
  if (C.hp <= 0) {
    const pa = C.items.indexOf("Phoenix Ash");
    if (pa !== -1) {
      C.items.splice(pa, 1);
      C.hp = Math.max(1, Math.floor(C.maxHp / 2));
      clog(`🪶 The Phoenix Ash ignites in your pack — fire wreathes you, and your wounds close. You rise (${C.hp} HP)!`, "sys");
    } else if (C.relentless && !flags.relentlessUsed) {
      C.hp = 1; flags.relentlessUsed = true;
      clog(`💪 Relentless Endurance! You refuse to fall — 1 HP remains.`, "sys");
    } else {
      C.hp = 0;
      playerDeath();
      return "dead";
    }
  }
  return "alive";
}

function playerDefend() {
  if (!combat.playerTurn || combat.over || C.status.stunned) return;
  C.status.defending = true;
  clog(`<span class="player-act">🛡 You set your feet and raise your guard (+3 AC; heavy blows halved; braced against stuns).</span>`);
  endPlayerTurn();
}
function stunRecover() {
  if (!combat.playerTurn || combat.over || !C.status.stunned) return;
  C.status.stunned--;
  clog(`<span class="enemy-act">😵 Your ears ring — the round is lost to getting your feet back.</span>`);
  endPlayerTurn();
}

/* One enemy attack (with rally, guard states, poison riders, multipliers). */
function foeAttack(foe, opts = {}) {
  const atkBonus = foe.atk + (foe.rally > 0 ? 2 : 0);
  let { r, note } = { r: d(20), note: "" };
  if (opts.adv) { const r2 = d(20); note = ` (advantage: ${r}, ${r2})`; r = Math.max(r, r2); }
  const effAc = playerEffAC();
  const total = r + atkBonus;
  const crit = r === 20;
  const hit = crit || (r !== 1 && total >= effAc);
  logRoll(`${foe.name}${opts.label ? " — " + opts.label : ""} ${hit ? "— HIT" : "— miss"}`, `d20(${r})${note} ${fmtMod(atkBonus)} = ${total} vs your AC ${effAc}`, crit ? "crit" : hit ? "fail" : "success");
  if (!hit) {
    clog(`<span class="enemy-act">${esc(foe.name)}${opts.label ? "'s " + opts.label : "'s attack"} ${opts.heavy ? "crashes down where you WERE — you read it coming" : C.status.defending ? "rings off your raised guard" : "misses you"}.</span>`);
    return;
  }
  let dmg;
  if (opts.dmgOverride) dmg = roll(opts.dmgOverride[0], opts.dmgOverride[1]).total + opts.dmgOverride[2];
  else {
    let [n, s, b] = foe.dmg;
    if (crit) n *= 2;
    if (opts.heavy) n *= 2;
    dmg = roll(n, s).total + b;
  }
  if (opts.heavy && C.status.defending) {
    dmg = Math.max(1, Math.floor(dmg / 2));
    clog(`🛡 Your braced guard takes the worst of the massive blow — damage halved!`, "sys");
  }
  const res = applyDamageToPlayer(dmg, foe.name, { msg: `<span class="enemy-act">${crit ? "💥 " : ""}${opts.heavy ? "💥 " : ""}${esc(foe.name)}${opts.label ? "'s " + opts.label : ""} hits you for <b>{d}</b> damage!</span>` });
  if (res === "dead") return "dead";
  // perk ripostes — shards, holy light, or a defender's counter-gash
  if (foe.hp > 0 && (pfx().thornsAlways || (pfx().thorns && C.status.defending))) {
    const td = d(pfx().thornsAlways || pfx().thorns);
    dealToFoe(foe, td, pfx().thornsAlways ? `⚡ Striking you has a price — a lash of retribution` : `🗡 Your braced riposte gashes the attacker`);
  }
  // riders
  if (opts.stun && pfx().stunImmune) {
    clog(`🛡 The blow that should have rung your skull finds nothing to rattle — <b>you cannot be stunned.</b>`, "sys");
  } else if (opts.stun && !C.status.stunImmune) {
    if (!saveRoll("CON", opts.stunDc || 12)) {
      C.status.stunned = 1; C.status.stunImmune = 3;
      sfx("clang");
      clog(`😵 <b>The blow rings your skull like a bell — you are STUNNED!</b> (You'll lose your next turn.)`, "sys");
    } else clog(`You shake off the worst of the impact — no stun.`, "sys");
  }
  if (opts.slow) {
    if (!saveRoll("DEX", 12)) {
      C.status.slowed = pfx().statusShrug ? 1 : 2;
      clog(`🦵 <b>Hamstrung!</b> Your footwork falters — −2 AC for ${C.status.slowed} round${C.status.slowed > 1 ? "s" : ""}.${pfx().statusShrug ? " <i>(Your footwork shrugs it off faster.)</i>" : ""}`, "sys");
    } else clog(`You twist away from the crippling cut.`, "sys");
  }
  if (foe.tr && foe.tr.moves.includes("poison") && pfx().poisonImmune) {
    if (!C.status.poisonImmuneNoted) { C.status.poisonImmuneNoted = true; clog(`🧪 The venom meets a body that has drunk worse on purpose — <b>poison cannot take hold in you.</b>`, "sys"); }
  } else if (foe.tr && foe.tr.moves.includes("poison") && !C.status.poison) {
    if (!saveRoll("CON", 11, { poison: true })) {
      C.status.poison = 3;
      clog(`🩸 <b>Poison!</b> The blade was slick with something vile — 1d4 damage at the start of your turns (CON save each turn to purge).`, "sys");
    } else clog(`${C.race.id === "dwarf" ? "Dwarven blood laughs at the toxin." : "The venom fails to take hold."}`, "sys");
  }
  return "ok";
}

function enemyTurn() {
  if (!combat || combat.over) return;
  for (const foe of combat.foes) {
    if (foe.hp <= 0) continue;
    const tr = foe.tr || { morale: "steady", moves: [] };
    // bleeding wounds bite at the start of the foe's turn
    if (foe._bleed > 0) {
      foe._bleed--;
      const bd = d(4);
      dealToFoe(foe, bd, `🩸 ${esc(foe.name)}'s wound bleeds freely`);
      if (foe.hp <= 0) continue;
    }
    // wake / stance expiry at own turn start
    if (foe.stance) foe.stance = 0;
    if (foe.guard) foe.guard = 0;
    if (foe.asleep && foe.asleep > 0) {
      foe.asleep--;
      clog(`💤 ${esc(foe.name)} snores through the round${foe.asleep ? "" : " — and begins to stir"}.`, "sys");
      continue;
    }
    // 1. unleash a charged heavy blow
    if (foe.charging) {
      foe.charging = false; foe.cleaveCd = 3;
      if (foeAttack(foe, { heavy: true, label: "massive blow" }) === "dead") return;
      continue;
    }
    if (foe.cleaveCd) foe.cleaveCd--;
    // 2. morale — the badly wounded may break and run
    if (!combat.noFlee && tr.morale !== "fearless" && foe.hp <= foe.maxHp * 0.3 && !foe.moraleHeld) {
      const alone = livingFoes().length === 1;
      const m = d(20) + (tr.morale === "craven" ? -6 : 0) + (alone ? -4 : 0);
      if (m < 8) {
        foe.fled = true; foe.hp = 0;
        sfx("flee");
        clog(`🏃 <b>${esc(foe.name)} breaks!</b> It hurls its weapon aside and flees the field!`, "sys");
        grantXp(Math.floor(foe.xp * 0.75));
        continue;
      } else foe.moraleHeld = true; // steadied — won't test again
    }
    // 3. war cry — rally allies, shake the hero
    if (tr.moves.includes("warcry") && !foe.cried && (combat.round === 1 || foe.hp < foe.maxHp / 2)) {
      foe.cried = true;
      livingFoes().forEach(f => f.rally = 2);
      sfx("growl");
      clog(`📢 <b>${esc(foe.name)} bellows a war cry!</b> The enemy surges (+2 to their attacks, 2 rounds).`, "sys");
      if (C.event.id === "dragonfire") {
        clog(`🔥 You walked out of dragonfire once. This noise is nothing. <i>(Fearless — immune.)</i>`, "sys");
      } else if (!saveRoll("WIS", 12)) {
        C.status.shaken = 2;
        clog(`😨 The cry rattles you — <b>Shaken:</b> −2 on your attacks for 2 rounds.`, "sys");
      }
      // a war cry is a free action — the attack still comes
    }
    // 4. duelist stance (riposte)
    if (tr.moves.includes("riposte") && d(3) === 1) {
      foe.stance = 1;
      clog(`🤺 <b>${esc(foe.name)} flows into a parrying stance</b> (+3 AC — and a missed strike will be answered). <i>Spells and thrown fire ignore the guard.</i>`, "sys");
      continue;
    }
    // 5. telegraphed cleave
    if (tr.moves.includes("cleave") && !(foe.cleaveCd > 0) && d(3) === 1) {
      foe.charging = true;
      clog(`⚠ <b>${esc(foe.name)} winds up a MASSIVE blow</b> — it lands next round. <i>(Defend to halve it!)</i>`, "sys");
      continue;
    }
    // 6. shield bash — once per fight
    if (tr.moves.includes("shieldbash") && !foe.bashUsed && d(3) === 1) {
      foe.bashUsed = true;
      if (foeAttack(foe, { label: "shield bash", dmgOverride: [1, 4, 2], stun: true, stunDc: foe.maxHp >= 35 ? 13 : 12 }) === "dead") return;
      continue;
    }
    // 6b. paralyzing touch (ghouls) — once per fight
    if (tr.moves.includes("paralyze") && !foe.bashUsed && d(3) === 1) {
      foe.bashUsed = true;
      if (foeAttack(foe, { label: "paralyzing claws", stun: true, stunDc: 12 }) === "dead") return;
      continue;
    }
    // 7. hamstring — once per fight
    if (tr.moves.includes("hamstring") && !foe.hamUsed && d(3) === 1) {
      foe.hamUsed = true;
      if (foeAttack(foe, { label: "hamstring cut", dmgOverride: [1, 4, 1], slow: true }) === "dead") return;
      continue;
    }
    // 8. defensive guard when hurt (disciplined foes)
    if (tr.morale === "steady" && foe.hp < foe.maxHp * 0.4 && d(4) === 1) {
      foe.guard = 1;
      clog(`🛡 ${esc(foe.name)} falls back behind its guard (+3 AC until its next turn).`, "sys");
      continue;
    }
    // 9. normal attack (pack tactics: advantage beside a living packmate; flurry: wounded duelists strike twice)
    const packAdv = tr.moves.includes("pack") && livingFoes().some(f => f !== foe && f.tr && f.tr.moves.includes("pack"));
    if (packAdv) clog(`🐺 The pack circles — they strike as one.`, "sys");
    const swings = (tr.moves.includes("flurry") && foe.hp < foe.maxHp * (foe.flurryAt || 0.5)) ? 2 : 1;
    if (swings === 2 && !foe.flurryTold) { foe.flurryTold = true; clog(`⚔⚔ <b>${esc(foe.name)} stops holding back</b> — the blade blurs into a flurry (two strikes a round)!`, "sys"); }
    for (let sw = 0; sw < swings; sw++) {
      if (foe.hp <= 0) break;
      if (foeAttack(foe, { adv: packAdv, label: sw ? "flurry" : undefined }) === "dead") return;
    }
    if (foe.rally > 0) foe.rally--;
  }
  if (checkCombatEnd()) return;
  // ally acts after the enemy
  if (combat.ally) {
    const target = livingFoes()[0];
    if (target) {
      const ar = d(20), atotal = ar + combat.ally.atk + (pfx().allyAtk || 0);
      const tAc = target.ac + (target.stance ? 3 : 0) + (target.guard ? 3 : 0);
      if (ar !== 1 && atotal >= tAc) {
        const [an, as, ab] = combat.ally.dmg;
        const adm = roll(an, as).total + ab;
        dealToFoe(target, adm, `🗡 ${combat.ally.name} strikes from the flank`);
      } else {
        clog(`<span class="player-act">${combat.ally.name}'s blade is turned aside.</span>`);
      }
      if (checkCombatEnd()) return;
    }
  }
  combat.round++;
  combat.playerTurn = true;
  startPlayerRound();
}

/* Start-of-player-round upkeep: defending expires, statuses tick, poison bites. */
function startPlayerRound() {
  C.status.defending = false;
  if (pfx().regenBelow && C.hp > 0 && C.hp < C.maxHp * pfx().regenBelow) {
    heal(d(4), "💗 Regeneration");
    clog(`💗 Your wounds knit at the edges — you refuse to stay down.`, "sys");
  }
  if (C.status.slowed) C.status.slowed--;
  if (C.status.shaken) C.status.shaken--;
  if (C.status.stunImmune) C.status.stunImmune--;
  if (C.status.poison > 0) {
    const pd = d(4);
    clog(`🩸 The poison burns through your veins — <b>${pd}</b> damage.`, "sys");
    const res = applyDamageToPlayer(pd, "poison", { bypassWards: true });
    if (res === "dead") return;
    if (saveRoll("CON", 11, { poison: true })) {
      C.status.poison = 0;
      clog(`You sweat the venom out. <b>Poison purged.</b>`, "sys");
    } else {
      C.status.poison--;
      if (C.status.poison === 0) clog(`The poison runs its course.`, "sys");
    }
  }
  renderCombat();
}

function playerStatusChips() {
  const s = C.status || {};
  const chips = [];
  if (s.stunned) chips.push("😵 Stunned");
  if (s.poison) chips.push(`🩸 Poisoned (${s.poison})`);
  if (s.slowed) chips.push(`🦵 Slowed (${s.slowed})`);
  if (s.shaken) chips.push(`😨 Shaken (${s.shaken})`);
  if (s.defending) chips.push("🛡 Defending");
  return chips.length ? `<div class="card-tag" style="color:#d4a017">${chips.join(" · ")}</div>` : "";
}
function foeStatusChips(f) {
  const chips = [];
  if (f.charging) chips.push("⚠ WINDING UP");
  if (f.stance) chips.push("🤺 parrying");
  if (f.guard) chips.push("🛡 guarding");
  if (f.asleep) chips.push("💤 asleep");
  if (f.rally > 0) chips.push("😤 rallied");
  if (f._frost) chips.push(`❄ chilled (−${f._frost})`);
  if (f._bleed) chips.push(`🩸 bleeding (${f._bleed})`);
  if (f._shredded) chips.push("🛡✂ armor shredded");
  return chips.length ? `<div class="card-tag" style="color:${f.charging ? "#e88" : "#a48ad4"}">${chips.join(" · ")}</div>` : "";
}

function checkCombatEnd() {
  if (combat.over) return true;
  if (livingFoes().length === 0) {
    combat.over = true;
    sfx("victory");
    clog("🏆 <b>Victory!</b>", "sys");
    rollMagicDrop();
    rollLootDrop();
    wearGear();
    renderCombat();
    setTimeout(() => goScene(combat.victoryScene), 1200);
    return true;
  }
  return false;
}

function playerDeath() {
  sfx("death");
  combat.over = true;
  renderCombat();
  setTimeout(() => {
    renderGame(`<div class="panel center fade-in">
      <div class="scene-art">💀</div>
      <h2>Darkness Takes You</h2>
      <p class="flavor">${esc(C.name)} falls. But as the cold closes in, a warm golden light intrudes — the Dawnmother's priests have found you, and death, it seems, is negotiable. For a price.</p>
      <p><b>XP:</b> ${C.xp} &nbsp; <b>Gold carried:</b> ${C.gold}</p>
      <div class="action-row" style="margin-top:14px">
        <button class="primary" onclick="templeRevival()">🕯 Wake at the Temple (lose half your gold, try again)</button>
        <button class="danger" onclick="restartAll()">💀 Accept death — forge a new hero</button>
      </div>
    </div>`);
  }, 1300);
}

function templeRevival() {
  C.gold = Math.floor(C.gold / 2);
  C.hp = C.maxHp;
  combat = null;
  autosave();
  logRoll("🕯 Revived", "The Dawnmother's priests demand a donation. Half your purse, to be exact.", "fail");
  if (flags.inFinale2) goScene("c12_stage");
  else if (flags.inFinale && flags.chapter <= 6) goScene("m6_stage");
  else goScene("town");
}

function restartAll() {
  creation = { step: 0, name: "", race: null, cls: null, scores: {}, pool: [], method: null, origin: null, event: null, motive: null };
  C = null; flags = {}; diceLogEntries = [];
  try { updateSheetBtn(); closeHeroSheet(); } catch (e) {}
  renderTitle();
}

/* ============================================================
   ADVENTURE — The Shadow Over Thornbrook
   ============================================================ */

/* scene check with Grim Resolve (greatfire event: one failed roll becomes a success) */
function sceneCheck(skill, dc, opts = {}) {
  // Fey Charm: advantage on one CHA check per mission
  const abil = SKILLS[skill] || skill;
  if (abil === "CHA" && C.event.id === "fey" && !flags.m.feyUsed) {
    opts.adv = true; flags.m.feyUsed = true;
    logRoll("🦋 Fey Charm", "Otherworldly grace grants advantage on this Charisma check.", "success");
  }
  let res = check(skill, dc, opts);
  if (!res.success && C.event.id === "greatfire" && !flags.m.grimUsed) {
    flags.m.grimUsed = true;
    logRoll("🏚️ Grim Resolve", "You have lost too much to fail here. The failure becomes a success.", "crit");
    res.success = true; res.grim = true;
  }
  if (!res.success && C.luckyCharm && !flags.m.charmUsed) {
    flags.m.charmUsed = true;
    logRoll("🍀 Lucky Charm", "The charm grows warm — fate reconsiders. The failure becomes a success.", "crit");
    res.success = true;
  }
  return res;
}

function startMission(briefScene) {
  flags.m = {}; // reset per-mission perk uses & temp state
  flags.checkpoint = briefScene;
  if (missionWaylay(briefScene)) return;
  goScene(briefScene);
}

function scene(art, title, paras, choices, extraHtml) {
  const choiceHtml = (choices || []).map((ch, i) => `
    <button class="${ch.backstory ? "backstory-choice" : ""}" onclick="${(ch.onclick || "").replace(/"/g, "&quot;")}" ${ch.disabled ? "disabled" : ""}>
      ${ch.txt}${ch.req ? ` <span class="req">${ch.req}</span>` : ""}
    </button>`).join("");
  renderGame(`<div class="panel">
    <div class="scene-art">${art}</div>
    <h2>${title}</h2>
    <div class="scene-text">${paras.map(p => `<p>${p}</p>`).join("")}</div>
    ${extraHtml || ""}
    <div class="choices">${choiceHtml}</div>
  </div>`);
}

function goScene(id) { SCENES[id](); setAmbientForScene(id); flags.lastScene = id; autosave(); if (C && C.pendingPerks && C.pendingPerks.length && (!combat || combat.over)) openPerkChoice(); }

function bkReq(label) { return `— ${label}`; }

/* ============================================================
   EVIDENCE SYSTEM
   ============================================================ */
const EVIDENCE = {
  coin:      { name: "Thorne's sunburst coin — matched to goblin loot", weight: 2 },
  forgemark: { name: "Goblin steel bearing the Ironvale forge-mark", weight: 1 },
  routeNote: { name: "Your patrol route, copied under a council seal", weight: 1 },
  testimony: { name: "Merchant Elsbeth's sworn testimony", weight: 1 },
  ledger:    { name: "Gar'Thok's ledger of payments — in Thorne's cipher", weight: 3 }
};
function addEvidence(id) {
  if (!flags.evidence.includes(id)) {
    sfx("chime");
    flags.evidence.push(id);
    logRoll("🧾 EVIDENCE GAINED", EVIDENCE[id].name, "crit");
  }
}
function evidenceWeight() { return flags.evidence.reduce((t, e) => t + EVIDENCE[e].weight, 0); }

/* ============================================================
   SAVE / LOAD (copyable save codes — no browser storage)
   ============================================================ */
function makeSaveCode() {
  const data = {
    v: 6, perks: C.perks || [], pendingPerks: C.pendingPerks || [],
    name: C.name, raceId: C.race.id, clsId: C.cls.id, originId: C.origin.id,
    eventId: C.event.id, motiveId: C.motive.id, scores: C.scores, maxHp: C.maxHp, hp: C.hp,
    gold: C.gold, xp: C.xp, level: C.level, items: C.items, profs: C.profs,
    ac: C.ac, atkBonus: C.atkBonus, dmgBonus: C.dmgBonus, weaponTier: C.weaponTier,
    weaponId: C.weaponId, armorId: C.armorId, shield: !!C.shield, spells: C.spells || [],
    ownedWeapons: C.ownedWeapons || [], ownedArmors: C.ownedArmors || [],
    weaponMats: C.weaponMats || {}, weaponDurs: C.weaponDurs || {},
    armorMats: C.armorMats || {}, armorDurs: C.armorDurs || {},
    armorTier: C.armorTier, initBonus: C.initBonus, ward: C.ward, luckyCharm: C.luckyCharm,
    skillsTrained: C.skillsTrained, statsTrained: C.statsTrained,
    flags: { evidence: flags.evidence, chapter: flags.chapter, thorneTrust: flags.thorneTrust,
      citizenRep: flags.citizenRep, coinKept: !!flags.coinKept, grayLoyal: !!flags.grayLoyal,
      grayDefied: !!flags.grayDefied, graySubverted: !!flags.graySubverted,
      accusedEarly: !!flags.accusedEarly, seraFriend: !!flags.seraFriend, wyrmCharm: !!flags.wyrmCharm,
      thorneFate: flags.thorneFate || null, kingBelieved: !!flags.kingBelieved, garthokTold: !!flags.garthokTold,
      truth: flags.truth || 0, lordProtector: !!flags.lordProtector, sawStaging: !!flags.sawStaging,
      opsDone: flags.opsDone || [], bramSaved: !!flags.bramSaved, zargaDeal: !!flags.zargaDeal,
      baronsWon: flags.baronsWon || 0, kingRestored: !!flags.kingRestored, decoyRefused: !!flags.decoyRefused,
      herring1Done: !!flags.herring1Done, herring1Solved: !!flags.herring1Solved, herringWidowDone: !!flags.herringWidowDone,
      mootDone: flags.mootDone || null, folk: flags.folk || {},
      embarrassed: !!flags.embarrassed, patrolC: flags.patrolC || 0, lastPatrolChapter: flags.lastPatrolChapter || 0,
      uniquesFound: flags.uniquesFound || [], wlDone: flags.wlDone || {} }
  };
  return btoa(unescape(encodeURIComponent(JSON.stringify(data))));
}
function loadSaveCode(code) {
  try {
    const dta = JSON.parse(decodeURIComponent(escape(atob(code.trim()))));
    if (![2, 3, 4, 5, 6].includes(dta.v)) throw new Error("version");
    const race = RACES.find(r => r.id === dta.raceId), cls = CLASSES.find(c => c.id === dta.clsId);
    const origin = ORIGINS.find(o => o.id === dta.originId), event = EVENTS.find(e => e.id === dta.eventId);
    const motive = MOTIVES.find(m => m.id === dta.motiveId);
    if (!race || !cls || !origin || !event || !motive) throw new Error("data");
    C = {
      name: dta.name, race, cls, origin, event, motive, scores: dta.scores,
      maxHp: dta.maxHp, hp: dta.hp, ac: dta.ac, gold: dta.gold, xp: dta.xp, level: dta.level,
      items: dta.items, profs: dta.profs, atkBonus: dta.atkBonus, dmgBonus: dta.dmgBonus,
      weaponTier: dta.weaponTier, armorTier: dta.armorTier, initBonus: dta.initBonus,
      ward: dta.ward, luckyCharm: dta.luckyCharm, skillsTrained: dta.skillsTrained || 0,
      statsTrained: dta.statsTrained || 0,
      lucky: !!race.lucky, relentless: !!race.relentless, breath: !!race.breath,
      backstoryProse: ""
    };
    creation = { step: 0, name: C.name, race, cls, origin, event, motive, scores: {}, pool: [], method: null };
    C.backstoryProse = buildBackstoryProse();
    flags = Object.assign({ m: {}, evidence: [], chapter: 1, thorneTrust: 0, citizenRep: 0 }, dta.flags, { m: {} });
    if (!flags.mootDone && (flags.baronsWon || 0) > 3) { flags.baronsWon = 0; } // heal saves from the moot-loop bug: replay the moot cleanly
    if (flags.mootDone && flags.mootDone.length >= 3) flags.baronsWon = Math.min(flags.baronsWon || 0, 3);
    C.weaponId = dta.weaponId || DEFAULT_WEAPON[cls.id];
    C.armorId = dta.armorId || DEFAULT_ARMOR[cls.id];
    C.shield = dta.shield !== undefined ? dta.shield : cls.id === "cleric";
    C.spells = dta.spells || [];
    C.ownedWeapons = dta.ownedWeapons && dta.ownedWeapons.length ? dta.ownedWeapons : [C.weaponId];
    C.ownedArmors = dta.ownedArmors && dta.ownedArmors.length ? dta.ownedArmors : [C.armorId];
    // materials & durability — heroes from before the forge learned metallurgy get iron, full
    C.weaponMats = dta.weaponMats || {}; C.weaponDurs = dta.weaponDurs || {};
    C.armorMats = dta.armorMats || {}; C.armorDurs = dta.armorDurs || {};
    C.ownedWeapons.forEach(id => { if (!C.weaponMats[id]) { C.weaponMats[id] = "iron"; C.weaponDurs[id] = MATERIALS.iron.dur; } });
    C.ownedArmors.forEach(id => { if (!C.armorMats[id]) { C.armorMats[id] = "iron"; C.armorDurs[id] = MATERIALS.iron.dur; } });
    C.perks = (dta.perks || []).filter(id => perkDefById(id));
    C.pendingPerks = dta.pendingPerks || [];
    // retroactive catch-up: heroes from before the perk era owe themselves one pick per level earned
    for (let lv = C.perks.length + C.pendingPerks.length + 1; lv <= C.level; lv++) C.pendingPerks.push(lv);
    recomputePerkFx();
    recomputeAC();
    diceLogEntries = [];
    combat = null;
    logRoll("📜 Save loaded", `${C.name}, level ${C.level} — Chapter ${flags.chapter}`, "success");
    goScene("town");
    return true;
  } catch (e) {
    return false;
  }
}
function showSaveScreen() {
  const code = makeSaveCode();
  renderGame(`<div class="panel">
    <div class="scene-art">🪶</div><h2>The Chronicler's Quill</h2>
    <p class="flavor">Copy this save code somewhere safe. On the title screen, choose "Continue a saved tale" and paste it to resume exactly where you left off — level, gold, gear, evidence and all.</p>
    <textarea readonly style="width:100%;height:110px;background:#0f0c08;color:var(--parchment);border:1px solid var(--border);border-radius:8px;padding:10px;font-family:monospace;font-size:.78em" onclick="this.select()">${code}</textarea>
    <div class="choices"><button onclick="goScene('town')">← Back to Ironvale</button></div>
  </div>`);
}
function showLoadScreen() {
  main().innerHTML = `<div class="panel fade-in">
    <div class="scene-art">📜</div><h2>Continue a Saved Tale</h2>
    <p class="flavor">Paste your save code below.</p>
    <textarea id="load-code" style="width:100%;height:110px;background:#0f0c08;color:var(--parchment);border:1px solid var(--border);border-radius:8px;padding:10px;font-family:monospace;font-size:.78em" placeholder="Paste save code here..."></textarea>
    <div id="load-err" style="color:#e88;margin-top:6px"></div>
    <div class="nav-row">
      <button onclick="renderTitle()">← Back</button>
      <button class="primary" onclick="if(!loadSaveCode(document.getElementById('load-code').value)) document.getElementById('load-err').textContent='That code could not be read. Check that you copied the whole thing.'">📖 Resume the Tale</button>
    </div>
  </div>`;
}

/* ============================================================
   IRONVALE — TOWN HUB, SHOPS & TRAINING
   ============================================================ */
const CHAPTER_NAMES = {
  1: "Ch. 1 — The Medicine Train", 2: "Ch. 2 — The Warren of Craghollow",
  3: "Ch. 3 — Gray Orders", 4: "Ch. 4 — The Poisoned Gift",
  5: "Ch. 5 — The Warlord's Ledger", 6: "Ch. 6 — The Breaking Point", 7: "Epilogue"
};

function townScene() {
  if (flags.lordProtector) return emberTownScene();
  const ch = flags.chapter;
  const mood = ch <= 2
    ? `Ironvale bustles uneasily — market stalls still full, but every conversation circles back to the raids.`
    : ch <= 4
    ? `Ironvale has changed. Prices chalked on the market boards climb weekly. Refugees from the outer villages sleep under the aqueduct arches, and the bread lines start before dawn. On every corner, someone mutters that the King's kindness will starve them all.`
    : `Ironvale is a city holding its breath. Half the stalls stand empty. Blackpike mercenaries — Thorne's "donated" security — watch the squares in matched black cloaks. The city no longer feels like it belongs to its people.`;
  scene("🏰", "Ironvale — " + (CHAPTER_NAMES[ch] || ""),
    [ mood,
      ch === 7 ? `The bells are ringing. It's over.` : `The Council Hall's mission board awaits — and the city's tradespeople are at your service.` ],
    [ { txt: `🏛 Council Hall — ${ch === 7 ? "the aftermath" : "your next assignment"} <b>(${CHAPTER_NAMES[ch] || ""})</b>`, onclick: "goScene('council')" },
      { txt: "⚒ Brannock's Forge — weapons & armor", onclick: "goScene('forge')" },
      { txt: "🔮 Zephyrine's Curiosities — potions & wonders", onclick: "goScene('curiosities')" },
      { txt: "🎯 The Training Yard — learn new skills", onclick: "goScene('training')" },
      { txt: "🍺 The Gilded Griffin — rest & rumors (5 gold, full heal)", onclick: "tavernRest()" },
      { txt: "🐎 Patrol the roads (5 gold supplies) — trouble, leads, and experience find those who look", onclick: "patrolRoll()" },
      { txt: "🪶 Chronicler's Quill — save your tale", onclick: "showSaveScreen()" } ]);
}

function tavernRest() {
  if (C.gold >= 5) { C.gold -= 5; C.hp = C.maxHp; logRoll("🍺 Rest", "A hot meal, a real bed. Fully healed (−5 gold).", "success"); }
  else { C.hp = Math.min(C.maxHp, C.hp + 5); logRoll("🍺 Rest", "No coin for a room — you doze by the hearth. +5 HP.", "success"); }
  restMend();
  const rumors = {
    1: `A carter swears the goblins that hit the medicine train "moved like soldiers, not vermin." The barkeep laughs it off. Nobody else does.`,
    2: `Two farmers argue about the Westmill granary fire. "Whole harvest, gone — and where was the garrison? Off chasing shadows." An old woman mutters that Councilor Thorne paid for her family's bread out of his own purse. "That man's the only one holding this city together."`,
    3: `A pale-faced merchant — Elsbeth, someone calls her — sits alone, drinking with shaking hands. She keeps saying her caravan permit was revoked the day before her wagons burned. "Only the council office knew my route. Only them."`,
    4: `Soldiers' talk: the King rides out again next week, chasing another report of Gar'Thok's main camp. "Third time," grunts a veteran. "Third empty camp. Somebody's feeding His Majesty moonshine and calling it intelligence."`,
    5: `Nobody talks in the Griffin anymore. Blackpike mercenaries drink free at the corner table, and everyone else studies their own mugs. On your way out, a beggar presses close: "Sera says: the wolf's camp, two nights, come armed."`,
    6: `The Griffin is shuttered. War is at the gates.`,
    7: `The Griffin has never been louder. They're singing about YOU, and the verses are only half-wrong.`,
    8: `The Griffin whispers now. The commission's verdict sits wrong with everyone who can count — "forged, was it? Then who paid Grukk in NEW coin?" — but the man who says it aloud checks the door first.`,
    9: `A Truth-Warden sits by the Griffin's fire "off duty." Conversation has become a careful art. Still, someone has chalked ten small questions inside the privy door, and someone else keeps re-chalking them after the wardens scrub it.`,
    10: `The barkeep pours you one on the house, silently, which under the Protectorate is practically a manifesto. On your way out he murmurs: "Whatever you're doing — the empty gallows, the questions — my boy can read, and he reads them out loud to the whole lane."`,
    11: `The Griffin's talk is all of the north: banners raised at Wrenhall, the coward King "not so cowardly after all, they say." A Blackpike sergeant drinks alone, and no one — no one at all — joins him.`,
    12: `The Griffin is packed and silent, the way rooms are before storms. Everyone knows the host is at the walls. Everyone is deciding, right now, quietly, what they'll do when the bell rings.`,
    13: `The Griffin has invented three new songs, a commemorative pie, and a house rule that the hero of both campaigns drinks free forever. The barkeep would like you to know the rule is ENFORCED.`
  };
  scene("🍺", "The Gilded Griffin",
    [ `You take a table under the low beams. ${C.gold >= 0 ? "The stew is hot, the bread is honest, and for an hour the world is simple." : ""}`,
      `<i>${rumors[flags.chapter] || rumors[6]}</i>` ],
    [ (flags.chapter === 3 && !flags.evidence.includes("testimony"))
        ? { backstory: C.event.id === "betrayed", txt: C.event.id === "betrayed" ? "🗡️ Talk to Elsbeth — you know the sound of the honestly betrayed" : "🗣 Sit with the merchant Elsbeth and hear her out", req: "(Persuasion, DC 11 — or it comes free to the once-betrayed)", onclick: "talkElsbeth()" } : null,
      { txt: "← Back to the city", onclick: "goScene('town')" } ].filter(Boolean));
}

function talkElsbeth() {
  const auto = C.event.id === "betrayed";
  const res = auto ? { success: true } : sceneCheck("Persuasion", 11);
  if (res.success) {
    addEvidence("testimony");
    scene("🍺", "Elsbeth's Story",
      [ auto ? `You don't say much. You don't have to — she looks up and recognizes something in your face, the particular stillness of someone who has also been sold by a friend. It all comes out.` : `You buy her a drink and let the silence do the asking.`,
        `"Eleven years I've run the Duskway route. I file my manifest with the council office — routes, cargo, guard count, all of it, that's the law. The day before my wagons burned, my permit was pulled. 'Rescheduling,' the clerk said." Her knuckles whiten around the cup. "The goblins hit the exact mile my manifest listed. The exact one. You tell me how."`,
        `She'll swear it before a magistrate — or a King. <b>(Evidence gained: Elsbeth's testimony)</b>` ],
      [ { txt: "← Back to the city", onclick: "goScene('town')" } ]);
  } else {
    scene("🍺", "A Closed Door",
      [ `Elsbeth looks at you a long moment — then at the Blackpike table in the corner — and pulls her hood up. "I don't know you. I don't know anything." Maybe later, when fewer eyes are on her.` ],
      [ { txt: "← Back to the city", onclick: "goScene('town')" } ]);
  }
}

/* --- shops --- */
function buy(cost, apply) {
  if (C.gold < cost) return;
  C.gold -= cost; apply();
  sfx("coin");
}
function shopRow(label, desc, cost, owned, onclick) {
  if (owned) return `<button disabled>✓ ${label} <span class="req">— owned</span></button>`;
  return `<button onclick="${(onclick || "").replace(/"/g, "&quot;")}" ${C.gold < cost ? "disabled" : ""}>${label} — <b>${cost}g</b> <span class="req">${desc}${C.gold < cost ? " (not enough gold)" : ""}</span></button>`;
}

function equipRow(kind, id) {
  const it = kind === "w" ? WEAPONS[id] : ARMORS[id];
  const owned = kind === "w" ? C.ownedWeapons.includes(id) : C.ownedArmors.includes(id);
  const equipped = kind === "w" ? C.weaponId === id : C.armorId === id;
  const label = (kind === "w" ? "🗡 " : "🛡 ") + it.name;
  const price = feyPrice(it.price);
  if (equipped) return `<button disabled>✦ ${label} <span class="req">— equipped. ${it.desc}</span></button>`;
  if (owned) return `<button onclick="${kind === "w" ? "equipWeapon" : "equipArmor"}('${id}');goScene('forge')">${label} <span class="req">— owned, tap to equip. ${it.desc}</span></button>`;
  return `<button onclick="buy(${price},()=>{${kind === "w" ? `C.ownedWeapons.push('${id}');equipWeapon('${id}')` : `C.ownedArmors.push('${id}');equipArmor('${id}')`}});goScene('forge')" ${C.gold < price ? "disabled" : ""}>${label} — <b>${price}g</b> <span class="req">${it.desc}${C.gold < price ? " (not enough gold)" : ""}</span></button>`;
}
function forgeScene() {
  const isWiz = C.cls.id === "wizard";
  const weaponRows = isWiz ? "" : Object.keys(WEAPONS).filter(k => WEAPONS[k].cls === C.cls.id && (!WEAPONS[k].magic || C.ownedWeapons.includes(k))).map(k => equipRow("w", k)).join("");
  const armorRows = ARMOR_PERMS[C.cls.id].filter(k => !ARMORS[k].bm).map(k => equipRow("a", k)).join("");
  const shieldRow = CAN_SHIELD[C.cls.id]
    ? (C.shield
        ? (shieldActive() ? `<button disabled>✦ 🛡 Shield <span class="req">— equipped (+2 AC)</span></button>` : `<button disabled>🛡 Shield <span class="req">— owned, but your two-handed weapon leaves no hand for it</span></button>`)
        : `<button onclick="buy(25,()=>{C.shield=true;recomputeAC();logRoll('⚒ Purchased','Shield: +2 AC with a one-handed weapon','success')});goScene('forge')" ${C.gold < 25 ? "disabled" : ""}>🛡 Shield — <b>25g</b> <span class="req">+2 AC while wielding a one-handed weapon</span></button>`)
    : "";
  scene(pArt("brannock"), "Brannock's Forge",
    [ `Brannock is a slab of a dwarf with burn-scarred forearms and no patience for browsing. "Buy something or bellows for me. Those are the options."`,
      `<i>Your arm: <b>${weaponName()}</b> · Your armor: <b>${armorDisplayName()}</b> (AC ${C.ac})</i>${durChip()}`,
      isWiz ? `<i>🧙 Brannock squints at you. "Wizard armory's a cantrip and a laundry bill. Zephyrine handles your sort — I do the ENCHANTING SURCHARGE tiers below, that's all."</i>` : `` ].filter(Boolean),
    [], `<div class="choices">
      ${weaponRows}${armorRows}${shieldRow}
      ${forgeMatRows('forge', false)}
      <div class="card-tag" style="padding:4px 2px">— Enchantment tiers (apply to whatever you wield and wear) —</div>
      ${shopRow("⚔ Masterwork " + curWeapon().name, "+1 attack & +1 damage", 100, C.weaponTier >= 1, "buy(100,()=>{C.weaponTier=1;logRoll('⚒ Purchased','Masterwork weapon: +1 atk, +1 dmg','success')});goScene('forge')")}
      ${C.weaponTier >= 1 ? shopRow("🔥 Emberforged " + curWeapon().name, "+2 attack, +1 dmg, +1d4 fire damage", 300, C.weaponTier >= 2, "buy(300,()=>{C.weaponTier=2;logRoll('⚒ Purchased','Emberforged weapon: +2 atk, +1d4 fire','success')});goScene('forge')") : `<button disabled>🔥 Emberforged weapon <span class="req">— requires Masterwork first</span></button>`}
      ${shopRow("🛡 Reinforced armor fitting", "+1 AC", 120, C.armorTier >= 1, "buy(120,()=>{C.armorTier=1;recomputeAC();logRoll('⚒ Purchased','Reinforced armor: +1 AC','success')});goScene('forge')")}
      ${C.armorTier >= 1 ? shopRow("🐉 Dragonscale reinforcement", "+1 more AC", 350, C.armorTier >= 2, "buy(350,()=>{C.armorTier=2;recomputeAC();logRoll('⚒ Purchased','Dragonscale: +1 AC','success')});goScene('forge')") : `<button disabled>🐉 Dragonscale reinforcement <span class="req">— requires Reinforced first</span></button>`}
      <button onclick="goScene('town')">← Back to the city</button>
    </div>`);
}

function curiositiesScene() {
  scene(pArt("zephyrine"), "Zephyrine's Curiosities",
    [ `The shop smells of ozone and dried lavender. Zephyrine — silver-eyed, age indeterminate — appears between shelves without quite walking there. "Ah. The one the dice talk about. Browse, browse."`,
      C.event.id === "fey" ? `<i>🦋 She peers at you, delighted. "Fey-touched! You get the FRIEND prices."</i>` : `` ].filter(Boolean),
    [], `<div class="choices">
      ${shopRow("🧪 Healing potion", "restores 2d4+4 HP", feyPrice(25), false, `buy(${feyPrice(25)},()=>{C.items.push('Healing potion');logRoll('🔮 Purchased','Healing potion','success')});goScene('curiosities')`)}
      ${shopRow("🧪 Greater healing potion", "restores 2d8+6 HP", feyPrice(60), false, `buy(${feyPrice(60)},()=>{C.items.push('Greater healing potion');logRoll('🔮 Purchased','Greater healing potion','success')});goScene('curiosities')`)}
      ${shopRow("📜 Scroll of Fireball", "once in combat: 6d6 damage to ALL enemies", feyPrice(100), false, `buy(${feyPrice(100)},()=>{C.items.push('Scroll of Fireball');logRoll('🔮 Purchased','Scroll of Fireball','success')});goScene('curiosities')`)}
      ${shopRow("🧿 Amulet of Warding", "the first hit against you each combat is halved", feyPrice(200), C.ward, `buy(${feyPrice(200)},()=>{C.ward=true;C.items.push('Amulet of Warding');logRoll('🔮 Purchased','Amulet of Warding','success')});goScene('curiosities')`)}
      ${shopRow("💍 Ring of Vigor", "+5 maximum HP, permanently", feyPrice(150), C.items.includes("Ring of Vigor"), `buy(${feyPrice(150)},()=>{C.items.push('Ring of Vigor');C.maxHp+=5;C.hp+=5;logRoll('🔮 Purchased','Ring of Vigor: +5 max HP','success')});goScene('curiosities')`)}
      ${shopRow("🍀 Lucky Charm", "once per mission, a failed skill check becomes a success", feyPrice(150), C.luckyCharm, `buy(${feyPrice(150)},()=>{C.luckyCharm=true;C.items.push('Lucky Charm');logRoll('🔮 Purchased','Lucky Charm','success')});goScene('curiosities')`)}
      ${shopRow("🩹 Field Bandages", "restore 1d4+2 HP — cheap, humble, lifesaving", feyPrice(10), false, `buy(${feyPrice(10)},()=>{C.items.push('Field Bandages');logRoll('🔮 Purchased','Field Bandages','success')});goScene('curiosities')`)}
      ${shopRow("🔥 Alchemist's Fire", "throw in combat: 2d4+2 fire damage, never misses", feyPrice(25), false, `buy(${feyPrice(25)},()=>{C.items.push("Alchemist's Fire");logRoll('🔮 Purchased',"Alchemist's Fire",'success')});goScene('curiosities')`)}
      ${C.cls.id === "wizard" ? `<div class="card-tag" style="padding:4px 2px">— Ellowyn's Annex (wizards only): cantrips &amp; spellcraft —</div>
        ${["firebolt","rayfrost","shockgrasp"].concat(C.ownedWeapons.filter(k => WEAPONS[k] && WEAPONS[k].magic && WEAPONS[k].cls === "wizard")).map(k => C.weaponId === k
          ? `<button disabled>✦ ${WEAPONS[k].magic ? "✨" : "🪄"} ${WEAPONS[k].name} <span class="req">— your current ${WEAPONS[k].magic ? "focus" : "cantrip"}. ${WEAPONS[k].desc}</span></button>`
          : `<button onclick="equipWeapon('${k}');goScene('curiosities')">${WEAPONS[k].magic ? "✨" : "🪄"} Attune to ${WEAPONS[k].name} <span class="req">(free) ${WEAPONS[k].desc}</span></button>`).join("")}
        ${["burning","sleep"].map(k => {
          const s = WIZ_SPELLS[k];
          if (C.spells.includes(k)) return `<button disabled>✓ 📖 ${s.name} <span class="req">— learned</span></button>`;
          if (C.level < s.minLevel) return `<button disabled>📖 ${s.name} <span class="req">— requires level ${s.minLevel}</span></button>`;
          return `<button onclick="buy(${feyPrice(s.price)},()=>{C.spells.push('${k}');logRoll('📖 Learned','${s.name}','crit')});goScene('curiosities')" ${C.gold < feyPrice(s.price) ? "disabled" : ""}>📖 Learn ${s.name} — <b>${feyPrice(s.price)}g</b> <span class="req">${s.desc}</span></button>`;
        }).join("")}` : ""}
      <button onclick="goScene('town')">← Back to the city</button>
    </div>`);
}
function feyPrice(p) {
  let v = C.event.id === "fey" ? p * 0.8 : p;
  if (pfx().shopDisc) v *= (1 - pfx().shopDisc);
  return Math.floor(v);
}

function trainingScene() {
  const untrained = Object.keys(SKILLS).filter(s => !C.profs.includes(s));
  scene("🎯", "The Training Yard",
    [ `Sergeant Brakka (retired, allegedly) runs drills for the city watch by morning and coin by afternoon. Sage Ellowyn tutors anything that requires a chair. Between them, most anything can be taught.`,
      `<i>Skill training: gain proficiency (+${profBonus()} to that skill's checks). Trained so far: ${C.skillsTrained}/3 skills, ${C.statsTrained}/2 ability boosts.</i>` ],
    [], `<div class="choices">
      ${C.skillsTrained < 3 ? `<button onclick="goScene('trainSkill')" ${C.gold < 80 ? "disabled" : ""}>📚 Train a new skill proficiency — <b>80g</b> <span class="req">(${untrained.length} available)</span></button>` : `<button disabled>📚 Skill training <span class="req">— you've learned all they can teach (3/3)</span></button>`}
      ${C.statsTrained < 2 ? `<button onclick="goScene('trainStat')" ${C.gold < 200 ? "disabled" : ""}>💪 Intensive ability training (+1 to a score) — <b>200g</b></button>` : `<button disabled>💪 Ability training <span class="req">— your body has reached its limit (2/2)</span></button>`}
      ${!C.initTrained ? `<button ${C.gold < 100 ? "disabled" : ""} onclick="buy(100,()=>{C.initBonus=(C.initBonus||0)+2;C.initTrained=true;logRoll('🎯 Trained','Combat reflexes: +2 initiative','success')});goScene('training')">⚡ Combat reflex drills (+2 initiative) — <b>100g</b></button>` : `<button disabled>✓ Combat reflex drills <span class="req">— owned</span></button>`}
      <button onclick="goScene('town')">← Back to the city</button>
    </div>`);
}
function trainSkillScene() {
  const untrained = Object.keys(SKILLS).filter(s => !C.profs.includes(s));
  scene("📚", "Choose Your Study",
    [ `80 gold, a week of bruises or homework, and one new proficiency. Brakka handles the sweaty ones; Ellowyn the thoughtful ones.` ],
    [], `<div class="choice-grid">` + untrained.map(s =>
      `<div class="card" onclick="buy(80,()=>{C.profs.push('${s}');C.skillsTrained++;logRoll('🎯 Trained','${s} proficiency gained (+' + profBonus() + ')','success')});goScene('training')">
        <div class="card-name">${s}</div><div class="card-tag">${SKILLS[s]}-based</div>
      </div>`).join("") + `</div><div class="choices"><button onclick="goScene('training')">← Never mind</button></div>`);
}
function trainStatScene() {
  scene("💪", "Intensive Training",
    [ `200 gold buys a month of dawn drills, foul tonics, and Ellowyn shouting conjugations at you — compressed, mercifully, into the space between missions. Choose what to hone.` ],
    [], `<div class="choice-grid">` + ABILITIES.map(a =>
      `<div class="card" onclick="buy(200,()=>{if(C.scores.${a}<20){C.scores.${a}++;C.statsTrained++;logRoll('🎯 Trained','${ABILITY_NAMES[a]} +1 (now '+C.scores.${a}+')','success')}});goScene('training')">
        <div class="card-name">${ABILITY_NAMES[a]}</div><div class="card-tag">${C.scores[a]} → ${Math.min(20, C.scores[a] + 1)}</div>
      </div>`).join("") + `</div><div class="choices"><button onclick="goScene('training')">← Never mind</button></div>`);
}


/* ============================================================
   PROLOGUE & COUNCIL HALL
   ============================================================ */
function prologueScene() {
  const originLine = {
    noble: `"Your family name reaches even here — I had dealings with your house years ago. Good people. Principled people." He says it like it costs him something, and you believe him.`,
    urchin: `"The streets, was it? I came up hard myself, though you wouldn't know it from the robes. Anyone who climbs out of the gutter has my respect twice over."`,
    farm: `"Farm-raised! Then you know what it means when the granaries empty. That's what keeps me up at night — not politics. Bread."`,
    temple: `"Raised by the Dawnmother's people? I fund three of her orphanages. Whatever you need in this city, child, you need only ask."`,
    soldier: `"A camp childhood. Then you know what discipline is worth — and what it costs. The realm sleeps soundly because people like you don't."`,
    scholar: `"A scholar's hand! Wasted on sword-work, some would say — but not me. The realm has plenty of swords. It's short on people who think."`
  }[C.origin.id];
  scene(pArt("thorne"), "Ironvale, City of the Iron Vale",
    [ `<i>${C.backstoryProse}</i>`,
      `The road ends at <b>Ironvale</b> — granite walls, banner-hung towers, the seat of good <b>King Alden</b>. But the market queues are long, the faces are tight, and the word on every lip is <i>goblins</i>.`,
      `Your reputation (or your sword-arm, or your luck) precedes you: an invitation finds you within the hour, written in a warm, looping hand, to the Gilded Griffin's best table. There sits <b>High Councilor Thaddeus Thorne</b> — silver-bearded, kind-eyed, the sort of grandfather the whole city seems to share. He stands to greet you. He remembers your name. He has already ordered you the good ale.`,
      `${originLine}`,
      `Then his face falls, and he turns his cup slowly. "I'll speak plainly, friend. Three days ago the medicine train from Duskhaven was taken on the road — fever tonics, poppy salve, all of it. The pox is in the refugee camps, and those wagons were their only hope. The garrison is stretched to breaking." He slides a purse across the table — heavy — and lowers his voice. "This is from my own purse, not the treasury. Bring back that medicine. And come back safe — the realm is poorer every time good folk don't."` ],
    [ { txt: "🤝 Take the job. People are sick, and the trail is going cold.", onclick: "C.gold += 30; logRoll('💰 Advance', '+30 gold from Thorne\\'s own purse', 'success'); startMission('m1_road')" },
      { txt: "🍺 Take the job — but first, one more of these excellent ales with the Councilor.", onclick: "C.gold += 30; flags.dranktWithThorne = true; logRoll('💰 Advance', '+30 gold from Thorne\\'s own purse', 'success'); goScene('prologue2')" } ]);
}

function prologue2Scene() {
  scene(pArt("thorne"), "One More Round",
    [ `Thorne waves for another and asks — actually asks — about your life. Where you were raised. What you're after. He listens the way few powerful men listen: leaning in, ale forgotten, laughing in the right places. When you mention ${C.motive.name.toLowerCase()}, he nods slowly. "That's a worthy road. Harder than most. If an old man's purse or an old man's ear can ever help you walk it — my door is open."`,
      `He pays for everything, tips like a guilty man, and grips your shoulder on the way out. "Safe roads, friend. I mean that."`,
      `<i>You can't remember the last time anyone in power looked at you like a person.</i>` ],
    [ { txt: "🌄 Ride out at first light", onclick: "startMission('m1_road')" } ]);
}

function councilScene() {
  const ch = flags.chapter;
  if (ch === 1) {
    scene(pArt("thorne"), "The Council Hall",
      [ `Thorne rises the moment he sees you, and the relief on his face is a whole speech. "You're on your feet. Thank the Dawnmother — when they carried you in, I..." He steadies himself, and slides the purse back across the table, still full. "The medicine is still out there, my friend. The sick are still waiting. I would send no one else."`,
        `The trail to the goblin camp is a day older, but trails keep.` ],
      [ { txt: "🌄 Ride out again — the medicine train won't recover itself", onclick: "startMission('m1_road')" },
        { txt: "🏙 Not yet — see to business in the city first", onclick: "goScene('town')" } ]);
  } else if (ch === 2) {
    scene(pArt("thorne"), "The Council Hall",
      [ `Thorne meets you on the steps, waving off two clerks. Since the medicine train, the raids have doubled — and last night the <b>Westmill grain barges</b> burned at their moorings.`,
        `"We found where they nest." He unrolls a map — the warren of <b>Craghollow Ridge</b>, marked in exacting detail: entrances, guard posts, even patrol timings. "One of Gar'Thok's lieutenants — a brute called <b>Grukk</b> — runs raids from these caves. Cut him out and we buy the valley a season of peace." He hesitates, then adds quietly: "I've marked everything my sources could gather. I'd never forgive myself if you walked in blind."`,
        `<i>The map is remarkable. You've seen royal survey work with less detail. Where does a councilor get intelligence like this?</i>` ],
      [ { txt: "⛰ March on Craghollow Ridge", onclick: "startMission('m2_gate')" },
        { txt: "🏙 Not yet — see to business in the city first", onclick: "goScene('town')" } ]);
  } else if (ch === 3) {
    scene(pArt("thorne"), "The Council Hall",
      [ `The hall is louder now — merchants shouting about the Duskway closures, a Duke's clerk reading casualty lists. Thorne draws you into his study, and for the first time he looks old.`,
        `"Craghollow was a victory — YOUR victory — but the raids haven't stopped. They've gotten <i>smarter</i>. And the city..." He rubs his eyes. "The city is a tinderbox. Which is why the council has passed the <b>Centralized Defense Act</b>. Private arms are to be collected into the city armories — for redistribution to trained defenders. A curfew, dusk to dawn. Ugly measures. Necessary ones."`,
        `He hands you a writ with your name on it. "People trust <i>you</i>. If the collection teams are led by the hero of Craghollow, it stays peaceful. If it's left to the Blackpikes..." he grimaces. "Please. Keep it gentle."`,
        `<i>Something about it sits wrong. Disarming frightened people, in a city where the watch answers to the council...</i>` ],
      [ { txt: "📜 Carry out the writ — collect the weapons, keep it gentle", onclick: "startMission('m3_comply')" },
        { txt: "✋ Refuse, to his face. You won't disarm frightened citizens.", onclick: "startMission('m3_refuse')" },
        { backstory: true, txt: "🎭 Accept the writ — but work it your own way", req: `(Deception, DC 13) <span class="win">✓ Thorne's trust AND the people's — both kept</span> · <span class="lose">✗ caught: his cold silence, and paid knives in an alley</span>`, onclick: "startMission('m3_subvert')" } ]);
  } else if (ch === 4) {
    scene("🏛", "A Royal Summons",
      [ `This time the seal on the letter is not Thorne's. It is the <b>King's</b>.`,
        `You are conducted past the council chambers — where you glimpse Thorne mid-oration, gently arguing the city <i>must</i> open its gates to the outer-village refugees, whatever the cost, because "what are we, if not our mercy?" The gallery applauds. The grain-clerks behind him look gray.`,
        `Then, the throne room — and <b>King Alden</b> himself: broad as a door, gray at the temples, a warhammer within arm's reach of the throne. He rises to clasp your forearm like a soldier. "The hero of Craghollow. Thaddeus speaks of you constantly — says you're the best steel in the valley. Good. I need steel."` ],
      [ { txt: "👑 Hear the King's charge", onclick: "goScene('m4_brief')" } ]);
  } else if (ch === 5) {
    scene("🏛", "The Empty War Room",
      [ `The Council Hall war room is half-deserted. The King rode out <b>two days ago</b> — his vanguard and his best knights with him — chasing fresh intelligence on Gar'Thok's main camp. Third such report this season. The first two camps were cold ashes.`,
        `Thorne is everywhere lately: organizing bread lines, calming the mob, quietly assuming the duties of the absent. The Blackpike company — "donated to the city's defense from my own estates" — now walks patrol beside the city watch. People cheer him in the street.`,
        `In your pocket: a beggar's whisper from the Griffin. <i>"Sera says: the wolf's camp, two nights, come armed."</i> Your old friend from Craghollow has been scouting on her own — and if anyone can put you inside Gar'Thok's war camp, it's her.` ],
      [ { txt: "🐺 Meet Sera at the treeline — it's time to cut the puppet's strings", onclick: "startMission('m5_meet')" },
        { txt: "🏙 See to business in the city first", onclick: "goScene('town')" } ]);
  } else if (ch === 6) {
    goScene("m6_stage");
  } else if (ch >= 7) {
    c2Council(ch);
  }
}

/* ============================================================
   MISSION 1 — THE MEDICINE TRAIN (Level 1)
   ============================================================ */
function m1_road() {
  scene("🛞", "The Duskhaven Road",
    [ `You find the medicine train at midday — or what's left of it. Four wagons, overturned and ransacked with unsettling efficiency. Crates of trade goods lie untouched in the mud; only the <b>medicine</b> is gone, every vial and bale of it.`,
      `A caravan guard slumps against a wheel, breathing wet and shallow. Goblin tracks — dozens — lead northwest into the pinewood.` ],
    [ !flags.m.helped ? { txt: "🩹 Tend the wounded guard first", req: `(Medicine, DC 12) <span class="win">✓ save him — and hear what the raiders let slip</span> · <span class="lose">✗ he fades, and patching him drains your supplies</span>`, onclick: "m1_guard()" } : null,
      !flags.m.tracked ? { txt: "🔍 Study the tracks and the wreck", req: `(Survival, DC 12) <span class="win">✓ read their numbers — strike the camp on your terms</span> · <span class="lose">✗ stumble into a goblin snare</span>`, onclick: "m1_tracks()" } : null,
      { txt: "🌲 Follow the trail northwest", req: "(no roll — but what you learned here travels with you)", onclick: "goScene('m1_camp')" } ].filter(Boolean));
}
function m1_guard() {
  flags.m.helped = true;
  const res = sceneCheck("Medicine", 12);
  if (res.success) flags.m.watchword = true;
  else { const cost = Math.min(10, C.gold); C.gold -= cost; flags.m.guardCost = cost; }
  scene("🩹", "The Dying Guard",
    [ res.success
        ? `You stanch the worst of it and get water into him. He grips your wrist with sudden strength. "They didn't... search. Came straight for the medicine wagon. THE one. Like they'd read the manifest." Then, quieter: "Their runner... called a word at the treeline before they charged. <b>'Iron-tusk.'</b> Twice. Like a knock on a door." He passes out — alive, and likely to stay that way. <b>(+50 XP — and you know the raiders' watchword.)</b>`
        : `You do what you can, which is more supplies than skill — salves, clean linen, the last of your road-kit poured into keeping him breathing. <b>(−${flags.m.guardCost} gold in spent supplies.)</b> Before consciousness fades he rasps: "...knew which wagon. Went straight to it..." His breathing steadies — barely. Whatever else he saw stays behind his closed eyes.`,
      `<i>Goblins that read cargo manifests. File that thought somewhere sharp.</i>` ],
    [ { txt: "← Back to the wreck", onclick: (res.success ? "grantXp(50,'aid rendered');" : "") + "goScene('m1_road')" } ]);
}
function m1_tracks() {
  flags.m.tracked = true;
  const res = sceneCheck("Survival", 12);
  if (res.success) flags.m.knowCamp = true;
  let snare = 0;
  if (!res.success) { snare = d(4); C.hp = Math.max(1, C.hp - snare); }
  scene("🔍", "Reading the Ground",
    [ res.success
        ? `The story is written plain: eight, maybe ten goblins — but moving in <b>column</b>, not the usual squabbling mob. They rested in shifts. Posted a rearguard. Someone has been drilling these creatures like soldiers. You mark their likely camp: a hollow two miles up, with one blind approach from the east. <b>(+50 XP — you'll strike on your terms.)</b>`
        : `Rain and panic have churned the ground to porridge — and your next step finds what the rain hid: a goblin snare, wire and fishhooks, that opens your calf before you tear free. <b>(−${snare} HP.)</b> The trail leads northwest; beyond that, the earth keeps its secrets, and now it's drawn blood for them.` ],
    [ { txt: "🌲 Follow the trail northwest", onclick: (res.success ? "grantXp(50,'expert tracking');" : "") + "goScene('m1_camp')" } ]);
}
function m1_camp() {
  const farmOpt = C.origin.id === "farm" && !flags.m.muleTrick;
  scene("⛺", "The Hollow",
    [ `Smoke threads up from a pine hollow. Below: campfires, stacked medicine crates, and goblins — ${flags.m.knowCamp ? "eight of them, arranged in proper watches, exactly as you predicted. From the blind eastern approach you can see it all" : "hard to count in the trees"}. Two stand sentry near the crates while a broad-shouldered captain in looted mail — all snarl and swagger — kicks a smaller one toward the cookfire.`,
      `The stolen mule team is picketed at the camp's edge, still in harness.` ],
    [ flags.m.watchword ? { backstory: true, txt: "🗣 Call out \"Iron-tusk\" at the treeline — walk in as an expected courier", req: `(no roll — earned at the dying guard's side) <span class="win">✓ inside their guard before they know better</span>`, onclick: "m1_watchword()" } : null,
      { txt: "🤫 Slip down and strike the sentries first", req: `(Stealth, DC ${flags.m.knowCamp ? 10 : 13}${flags.m.knowCamp ? " — lowered: you know their watch rotation" : ""}) <span class="win">✓ the first blow is yours</span> · <span class="lose">✗ spotted — the brawl is on their terms</span>`, onclick: `m1_approach(${flags.m.knowCamp ? 10 : 13})` },
      farmOpt ? { backstory: true, txt: "🌾 You know mules. Spook the team into a stampede through the camp", req: bkReq("Farm Child — chaos on demand"), onclick: "flags.m.muleTrick = true; goScene('m1_mules')" } : null,
      { txt: "⚔ No games — charge the camp", req: "(no roll — an honest brawl, on even terms)", onclick: "m1_fight1(false)" } ].filter(Boolean));
}
function m1_watchword() {
  grantXp(50, "the courier's trick");
  m1_fight1(true, "\"Iron-tusk!\" The sentries wave you in, bored — and the first one is still reaching for a greeting when your steel arrives. Kindness at the wreck, repaid with interest. ");
}
function m1_approach(dc) {
  const res = sceneCheck("Stealth", dc);
  if (res.success) m1_fight1(true, res.grim ? "A twig cracks underfoot — but old scars keep your nerve, and the moment passes. (Grim Resolve) " : "");
  else {
    scene("💢", "Spotted!",
      [ `A sentry's head snaps up — "OI!" — and the hollow erupts.` ],
      [ { txt: "⚔ Fight!", onclick: "m1_fight1(false)" } ]);
  }
}
function m1_mules() {
  grantXp(50, "a properly agricultural solution");
  scene("🌾", "Stampede",
    [ `You circle to the picket line, click your tongue the way every farm child learns before they learn letters, and cut the leads. Then you put a burr under the lead mule's harness.`,
      `The result is <i>magnificent</i>. Half a ton of furious mule goes through the camp like judgment itself — cookfire, tents, and two goblins flattened outright. In the chaos, no one sees you coming at all.` ],
    [ { txt: "⚔ Strike while they're scattered!", onclick: "m1_fight1(true, 'The camp is in ruins around you — the survivors barely know which way to face. ')" } ]);
}
function m1_fight1(surprise, extra) {
  startCombat(["goblin", "goblin2"], "m1_mid", { surprise, intro: (extra || "") + "Two goblin raiders scramble for their blades!" });
}
function m1_mid() {
  scene("⚔", "The Hollow, Contested",
    [ `The sentries fall — but across the camp, the captain roars something guttural and snatches up a barbed spear. The remaining goblins scatter into the trees rather than face you. The captain does not.`,
      `You have a breath, no more.` ],
    [ !flags.m.bandaged ? { txt: "🩹 Bind your wounds quickly (heal 1d4+2)", onclick: "flags.m.bandaged = true; heal(d(4)+2,'Field dressing'); goScene('m1_mid')" } : null,
      { txt: "⚔ Meet Captain Snagfang", onclick: "startCombat(['snagfang'], 'm1_loot', { intro: 'The captain spits, grins with every tooth he has left, and comes on fast.' })" } ].filter(Boolean));
}
function m1_loot() {
  scene("📦", "The Medicine, Recovered",
    [ `Snagfang goes down still snarling. The hollow falls quiet, and there it all is: every crate of fever tonic, every bale of poppy salve, unopened. Whatever this raid was for, it wasn't for <i>using</i> the medicine.`,
      `In the captain's tent you find a strongbox: <b>35 gold</b>, a roll of clean <b>field bandages</b> (goblin plunder, human make) — and, oddly, a folded schedule of the Duskhaven road's caravan departures. Printed. Official-looking.`,
      `<i>Goblins with paperwork.</i> <b>(+35 gold)</b>` ],
