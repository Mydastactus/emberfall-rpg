/* --- 4. THE HUSBAND (ch9) --- */
function folk_voss() {
  const f = folkState();
  if (f.voss === "guard") return folk_voss_night();
  scene("🗝", "The Canal Keeps No Secrets",
    [ `The report says Dain Voss, locksmith, drank himself into the canal. His widow Mara has read it forty times. "Dain didn't drink," she says. "Dain made keys. And three weeks ago he came home grey and wouldn't say why, and started sleeping with the shop shuttered."`,
      `A locksmith. In the month the "stolen treasury" rolled east in locked Blackpike wagons. <i>Somebody needed keys copied — and Dain Voss said no.</i>` ],
    [ { txt: "🔍 Work the canal bank and the shuttered shop", req: `(Investigation, DC 13${flags.evidence && flags.evidence.includes("wagonManifest") ? ", advantage — you already hold the wagon manifest" : ""}) <span class="win">✓ what Dain hid, and WHO (+4 Hearts)</span> · <span class="lose">✗ you're seen looking — and tonight, someone visits the widow</span>`, onclick: "folkVossTry()" },
      { txt: "🏮 Not now — back to the board", onclick: "goScene('folkboard')" } ]);
}
function folkVossTry() {
  const res = sceneCheck("Investigation", 13, { adv: !!(flags.evidence && flags.evidence.includes("wagonManifest")) });
  if (res.success) {
    scene("🗝", "What the Locksmith Hid",
      [ `Under the third floorboard of the shuttered shop: a wax key-mold, and a note in a locksmith's careful print. <i>"Sgt. Krell, Blackpike — wants treasury pattern copied. Refused twice. He says everyone signs eventually."</i> Dated two days before the canal.`,
        `Sergeant Krell drinks at the Broken Spoke, wears his coat open, and has stopped being careful. Everyone signs eventually — he believes that.` ],
      [ { txt: "🗣 Walk up to Krell's table and lay the mold on it", req: `(Intimidation, DC 13) <span class="win">✓ he breaks — a confession the whole taproom hears (+4 Hearts)</span> · <span class="lose">✗ he goes for steel in front of everyone</span>`, onclick: "folkVossConfront()" },
        { txt: "⚔ Skip the theater. He murdered a locksmith.", onclick: "startCombat(['blackpike'], 'folk_voss_win', { noFlee: true, intro: 'Krell stands, coat open, unbothered — right up until he recognizes the mold in your hand.' })" } ]);
  } else {
    folkState().voss = "guard";
    scene("🗝", "Seen Looking",
      [ `A window shutters across the canal as you straighten from the mud. By noon, someone in a black coat has walked past the widow's door twice, slowly, the way a man measures a thing he plans to remove.`,
        `<i>Krell knows someone's pulling the thread. Tonight, Mara Voss's door gets a visit — unless you're standing in front of it.</i>` ],
      [ { txt: "🌙 Stand the night watch at her door", onclick: "goScene('folk_voss')" },
        { txt: "🏮 Back to the board (the night is coming either way)", onclick: "goScene('folkboard')" } ]);
  }
}
function folkVossConfront() {
  const res = sceneCheck("Intimidation", 13);
  if (res.success) {
    folkState().voss = "done";
    addTruth(4, "a murder called by its name in a full taproom");
    grantXp(220, "Sergeant Krell, confessed");
    scene("🗝", "Everyone Signs Eventually",
      [ `You set the mold on Krell's table and say nothing at all. The taproom goes quiet the way rooms do when they can smell history. Krell talks — first to bluster, then to bargain, then, horribly, to <i>explain</i>, and by the time he understands what he's confessing to, forty people have heard the arithmetic of the canal.`,
        `Mara Voss buries her husband under his own name: DAIN VOSS, LOCKSMITH. HE SAID NO. The stone gets touched by strangers like a shrine.` ],
      [ { txt: "🏮 Back to the board", onclick: "goScene('folkboard')" } ]);
  } else {
    scene("🗝", "Steel in the Taproom",
      [ `Krell is quicker to the blade than to the truth. Chairs go over. The taproom clears a circle the way it does for weddings and killings.` ],
      [ { txt: "⚔ Finish it", onclick: "startCombat(['blackpike'], 'folk_voss_win', { noFlee: true, intro: 'Everyone signs eventually, Krell believes. Time to collect his.' })" } ]);
  }
}
function folk_voss_win() {
  folkState().voss = "done";
  addTruth(3, "the canal's story, corrected");
