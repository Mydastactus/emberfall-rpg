}
function m1_return() {
  scene("🎉", "A Hero's Welcome",
    [ `Word outruns you. By the time the wagons roll through Ironvale's gates, there's a crowd — cheering, weeping, pressing bread and flowers on you. Thorne is there on the steps, and the relief on his face looks bone-deep. "You magnificent creature," he says, low enough that only you hear it, and his eyes are wet. "You've saved hundreds."`,
      `He presses payment into your hands: <b>50 gold</b> — and one coin more. A strange one: heavy, bright, stamped with a <b>sunburst over crossed keys</b>. "A lucky piece from my grandfather's mint, for luck earned. I give one only to people I intend to keep."`,
      `That evening, a crier's bell: while the valley celebrated, raiders hit the <b>Grimhollow farmsteads</b>, twenty miles the OTHER direction. Burned the winter stores. No one was there to stop it.` ],
    [ { txt: "🪙 Keep the sunburst coin — something about it is worth remembering", onclick: "flags.coinKept = true; C.gold += 50; flags.chapter = 2; logRoll('🪙','You pocket Thorne\\'s sunburst coin — and 50 gold.','success'); goScene('town')" },
      { txt: "💰 A coin's a coin. Into the purse with the rest.", onclick: "C.gold += 55; flags.chapter = 2; logRoll('💰','+55 gold. The odd coin vanishes among the rest.','success'); goScene('town')" } ]);
}

/* ============================================================
   MISSION 2 — THE WARREN OF CRAGHOLLOW (Level 2)
   ============================================================ */
function m2_gate() {
  const soldierAdv = C.origin.id === "soldier";
  scene("⛰", "Craghollow Ridge",
    [ `Thorne's map proves flawless — unnervingly so. Every guard post is where the ink says. Every patrol passes when the margin-notes promise. You reach the cave mouth having not been seen once.`,
      `A single <b>hobgoblin guard</b> paces the entrance, torchlight on scavenged mail. Beyond, firelight breathes deep in the hill's throat.`,
      soldierAdv ? `<i>⚔️ The patrol timing on this map isn't scout work — it's a garrison duty roster. You'd know one anywhere. That thought will keep. Meanwhile, you know exactly when the guard's attention lapses.</i>` : `` ].filter(Boolean),
    [ { txt: "🤫 Slip past during the watch change", req: `(Stealth, DC ${soldierAdv ? 10 : 13}${soldierAdv ? " — lowered by your soldier's eye" : ""}) <span class="win">✓ enter unseen — the first blow on Grukk is yours</span> · <span class="lose">✗ the alarm — steel answers at the gate</span>`, onclick: `m2_sneak(${soldierAdv ? 10 : 13})` },
      { txt: "🎭 Stride up like you're expected", req: "(Deception, DC 14" + (C.origin.id === "noble" ? " — or Persuasion DC 11, with aristocratic certainty" : "") + `) <span class="win">✓ walk in openly, unchallenged</span> · <span class="lose">✗ the bluff collapses into a blade</span>`, onclick: "m2_bluff()" },
      { txt: "⚔ Cut the guard down", req: "(no roll — loud, honest, and Grukk will be ready)", onclick: "startCombat(['guard'], 'm2_warren', { intro: 'The hobgoblin levels its longsword and bellows an alarm that no one, deep in the feasting-din below, seems to hear.' })" } ]);
}
function m2_sneak(dc) {
  const res = sceneCheck("Stealth", dc);
  if (res.success) { flags.m.ghost = true;
    scene("🤫", "Shadow Among Shadows",
      [ `${res.grim ? "A stone turns underfoot — but hard-won calm keeps the stumble silent. <i>(Grim Resolve)</i> " : ""}You time the watch change to the heartbeat and flow past into the warren's dark. No alarm. The advantage is yours.` ],
      [ { txt: "→ Deeper", onclick: "goScene('m2_warren')" } ]);
  } else {
    scene("💢", "Spotted!", [ `Loose scree betrays you — the guard's torch whips around. "INTRUDER!"` ],
      [ { txt: "⚔ Fight!", onclick: "startCombat(['guard'], 'm2_warren', { intro: 'Steel clears its scabbard.' })" } ]);
  }
}
function m2_bluff() {
  const noble = C.origin.id === "noble";
  const res = sceneCheck(noble ? "Persuasion" : "Deception", noble ? 11 : 14);
  if (res.success) { flags.m.ghost = true;
    scene("🎭", "Silver Tongue",
      [ noble ? `You wear a lifetime of court-voice like armor: you are an <i>envoy</i>, obviously, on business Grukk would be furious to see delayed. Faced with pure aristocratic certainty, the guard steps aside. <i>(Noble Heir)</i>`
              : `"New sword-hire. Grukk's expecting me." Delivered in flawless bored-mercenary. The hobgoblin shrugs the shrug of the underpaid and waves you through.` ],
      [ { txt: "→ Deeper", onclick: "goScene('m2_warren')" } ]);
  } else {
    scene("💢", "The Bluff Collapses", [ `The guard squints. "Grukk hires no one. Grukk <i>takes</i>." The longsword comes up.` ],
      [ { txt: "⚔ Fight!", onclick: "startCombat(['guard'], 'm2_warren', { intro: 'So much for diplomacy.' })" } ]);
  }
}
function m2_warren() {
  scene("🕯", "The Warren",
    [ `Three passages, thick with smoke and the sour reek of goblin. Somewhere deep, a drum beats slow as a buried heart. From the <b>left</b>: a hoarse human voice. From the <b>right</b>: firelight on metal — a lot of metal. <b>Ahead</b>: the drum.` ],
    [ !flags.m.freed ? { txt: "⛓ Left — the voice", onclick: "goScene('m2_prisoner')" } : null,
      !flags.m.armory ? { txt: "🗡 Right — the metal", req: `(Investigation on arrival) <span class="win">✓ the maker's marks tell a story worth keeping</span> · <span class="lose">✗ clumsy searching wakes something in the dark</span>`, onclick: "goScene('m2_armory')" } : null,
      { txt: "🥁 Ahead — Grukk", onclick: "goScene('m2_grukk_talk')" } ].filter(Boolean));
}
function m2_prisoner() {
  scene(pArt("sera"), "The Holding Cell",
    [ `Behind a rusted grate: a weathered woman in trapper's leathers, who takes your measure in one glance and grins through a split lip. "Well. Rescue's better-armed than I expected. Name's <b>Sera</b> — they took me on the ridge road three days back."`,
      `She jerks her chin toward the drum. "The big one, Grukk — he gets <i>visitors</i>. Human ones. Cloaked, city boots, always at night. I hear coin change hands." She grips the bars. "Get me out. I fight better than I look."` ],
    [ C.items.includes("Lockpicks") ? { backstory: true, txt: "🔓 Pick the lock — alley skills never rust", req: bkReq("Street Urchin"), onclick: "m2_free(true)" } : null,
      { txt: "💪 Wrench the grate loose", req: `(Athletics, DC 13) <span class="win">✓ Sera fights beside you from here on</span> · <span class="lose">✗ the iron bites back — pain, and another try</span>`, onclick: "m2_freeCheck('Athletics')" },
      { txt: "🪛 Probe the lock", req: `(Sleight of Hand, DC 13) <span class="win">✓ Sera fights beside you from here on</span> · <span class="lose">✗ a slipped pick and a bleeding palm</span>`, onclick: "m2_freeCheck('Sleight of Hand')" },
      { txt: "← Back", req: "(leave her — and face Grukk without a flanker)", onclick: "goScene('m2_warren')" } ].filter(Boolean));
}
function m2_free(auto) {
  flags.m.freed = true; flags.seraFriend = true;
  scene("⛓", "Freedom",
    [ `${auto ? "The lock surrenders in eleven seconds flat." : "The grate gives way."} Sera rolls her shoulders, picks up a goblin knife like she's shaking hands with an old friend, and falls in beside you. <b>"Grukk's mine to flank. Let's ruin his evening."</b>` ],
    [ { txt: "← Back to the junction", onclick: "goScene('m2_warren')" } ]);
}
function m2_freeCheck(skill) {
  const res = sceneCheck(skill, 13);
  if (res.success) m2_free(false);
  else {
    const dmg = d(4); C.hp = Math.max(1, C.hp - dmg);
    scene("⛓", "Stubborn Iron",
      [ `The ${skill === "Athletics" ? "grate holds; something tears in your shoulder" : "pick slips and gashes your palm"}. <b>(−${dmg} HP)</b> Sera winces. "Again. Quietly."` ],
      [ { txt: "💪 Wrench it", req: "(Athletics, DC 13)", onclick: "m2_freeCheck('Athletics')" },
        { txt: "🪛 The lock again", req: "(Sleight of Hand, DC 13)", onclick: "m2_freeCheck('Sleight of Hand')" },
        { txt: "← Leave it... for now", onclick: "goScene('m2_warren')" } ]);
  }
}
function m2_armory() {
  flags.m.armory = true;
  const res = sceneCheck("Investigation", 12);
  if (!res.success) {
    scene("🗡", "The Armory Cache",
      [ `Racks of weapons — far too many, and far too good. You pull crates about, hunting meaning in the maker's marks and finding none — and your clatter finds something else instead: a goblin scavenger, asleep in the back racks with a stolen jug, now very much awake and very much between you and the coin chest.` ],
      [ { txt: "⚔ Deal with it — quickly, before the noise carries", onclick: "startCombat(['goblin2'], 'm2_armory_loot', { intro: 'It comes up swinging, jug in one hand, dagger in the other. The jug, at least, misses.' })" } ]);
    return;
  }
  scene("🗡", "The Armory Cache",
    [ `Racks of weapons — far too many, and far too good. Goblin scrap sits beside <b>fresh-forged steel</b>: matched spearheads, uniform swords, oiled and crated like a quartermaster's shipment.`,
      `You turn a blade to the torchlight and your stomach drops. Struck into the ricasso, plain as a signature: the <b>anvil-and-tower of the Ironvale city forge</b>. This steel was made INSIDE the walls you're fighting for — and shipped here in crates. <b>(EVIDENCE: forge-marked steel — you wrap a shortsword to keep.)</b>`,
      `A coin chest by the door yields <b>40 gold</b> — and a crate of wax-sealed vials Sera identifies at a sniff: <b>alchemist's fire</b>. You pocket one.` ],
    [ { txt: "← Back to the junction", onclick: `C.gold += 40; C.items.push("Alchemist's Fire"); addEvidence('forgemark'); logRoll('💰','+40 gold from the cache','success'); goScene('m2_warren')` } ]);
}
function m2_armory_loot() {
  scene("🗡", "The Cache, Quieter",
    [ `The scavenger dealt with, you take what's plain to take: <b>40 gold</b> from the coin chest and a vial of <b>alchemist's fire</b>. The strange, uniform steel stays a nagging question you can't answer — whatever its marks would have told a sharper eye rides back to Ironvale unread.` ],
    [ { txt: "← Back to the junction", onclick: `C.gold += 40; C.items.push("Alchemist's Fire"); logRoll('💰','+40 gold from the cache','success'); goScene('m2_warren')` } ]);
}
function m2_grukk_talk() {
  scene(pArt("grukk"), "The Drum-Chamber",
    [ `Goblins scatter to the walls as you enter. On a throne of stacked crates — <i>merchant crates, stamped with Ironvale trade-seals</i> — lounges a hobgoblin the size of a door: <b>Lieutenant Grukk</b>.`,
      `"The hero," he rumbles, unhurried. "Killed Snagfang. Cost me a month of medicine-profit." He rises, hefting a two-handed cleaver. "Gar'Thok says the plan needs martyrs on both sides. Guess which one you are."`,
      flags.m.freed ? `Sera has already melted into the shadows behind the crate-throne.` : `` ].filter(Boolean),
    [ C.event.id === "dragonfire" ? { backstory: true, txt: "🔥 \"I've walked out of dragonfire, little lieutenant. You are not even a spark.\"", req: bkReq("Survived Dragonfire — shake his nerve"), onclick: "flags.m.shaken = true; m2_grukk_fight()" } : null,
      { txt: "😤 \"Whose plan, Grukk? Say the name and I'll let your goblins carry you out.\"", req: "(Intimidation, DC 14 — rattle him)", onclick: "m2_intimidate()" },
      { txt: "⚔ Enough talk", onclick: "m2_grukk_fight()" } ].filter(Boolean));
}
function m2_intimidate() {
  const res = sceneCheck("Intimidation", 14);
  if (res.success) flags.m.shaken = true;
  scene(pArt("grukk"), "A Name Almost Spoken",
    [ res.success
        ? `Something crosses Grukk's face — quick, involuntary, the look of a creature that has BEEN afraid of someone. "You'll meet him soon enough," he growls, but his knuckles are white on the cleaver haft, and his first step toward you is a half-step. <i>(His attacks weaken!)</i>`
        : `Grukk laughs like rocks in a barrel. "Names? I sell raids, not names. Prices you couldn't pay."`,
      `The crate-throne topples as he comes on.` ],
    [ { txt: "⚔ Meet him!", onclick: "m2_grukk_fight()" } ]);
}
function m2_grukk_fight() {
  startCombat(["grukk"], "m2_loot", {
    surprise: !!flags.m.ghost,
    ally: flags.m.freed ? { name: "Sera", atk: 5, dmg: [1, 6, 3] } : null,
    intro: (flags.m.shaken ? "Grukk's swings carry doubt now (−2 to his attacks). " : "") + (flags.m.ghost ? "You entered unseen — the first blow is yours. " : "") + (flags.m.freed ? "Sera circles behind the throne, knife low." : "")
  });
  if (flags.m.shaken) combat.foes[0].atk -= 2;
}
function m2_loot() {
  const canMatch = flags.coinKept;
  scene("🏆", "The Lieutenant's Effects",
    [ `Grukk crashes down among his stolen crates. The surviving goblins evaporate into the deep tunnels — leaderless, and glad of it.`,
      `His belt-pouch is heavy: <b>60 gold</b>, much of it <b>fresh-minted</b> — mirror-bright, unclipped, never circulated. Coins straight from a mint's tray, in a cave in the wilderness.`,
      canMatch
        ? `You hold one next to Thorne's "lucky" sunburst coin, and the cave goes very quiet around you. <b>Same mint. Same sunburst-over-keys stamp. Same hand behind both purses.</b> <b>(EVIDENCE: the coin match.)</b>`
        : `Something about the stamp — a sunburst over crossed keys — snags briefly at your memory, but the thought slips away unproven. <i>(If only you had something to compare it against...)</i>` ],
    [ { txt: "🏰 Back to Ironvale with the news", onclick: `C.gold += 60; ${canMatch ? "addEvidence('coin');" : ""} grantXp(150,'Mission: the Warren of Craghollow'); goScene('m2_return')` } ]);
}
function m2_return() {
  flags.chapter = 3;
  scene("🏰", "Heroes and Headlines",
    [ `Ironvale roars your name. Thorne embraces you on the Council Hall steps like family — and then, before the assembled crowd, his face turns grave.`,
      `"Twice now this hero has done what the garrison could not!" he calls. "And I say this with love for our King: the crown is <i>failing</i> its people. Not from malice — from exhaustion! From advisors who tell it comfortable lies!" The crowd murmurs like a rising tide. "The council will not let this city starve while others sleep!"`,
      `The applause is thunderous. You collect <b>100 gold</b> in bounty. That night, the news finds you at the Griffin: while you were underground, the <b>Westmill granary</b> — the city's largest — burned to the stone. The main horde struck it in force. Nobody was there to stop them; every free blade in the valley had been pointed, so precisely, at Craghollow.`,
      `<i>You keep thinking about that flawless map.</i>` ],
    [ { txt: "🏙 Return to the city", onclick: "C.gold += 100; logRoll('💰 Bounty','+100 gold','success'); goScene('town')" } ]);
}

/* ============================================================
   MISSION 3 — GRAY ORDERS (Level 3) — the moral fork
