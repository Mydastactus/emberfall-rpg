/* --- consequences for fallen rescuers: latched stages resolve when the board next renders --- */
function folkResolveFallen() {
  const f = folkState();
  if (f.tessa === "fighting") f.tessa = "lastchance"; // the yard raid failed — the convoy moves
  else if (f.tessa === "lastchance_fighting") { f.tessa = "lost"; addTruth(-2, "a convoy cleared the hills"); }
  if (f.voss === "night_fighting") { f.voss = "lost"; addTruth(-2, "a widow fled the city by night"); }
  if (f.corin === "ambush_fighting") f.corin = "second"; // he saw you fall; the bridge moment keeps
}
const _folkBoardWrapped = folkBoard;
function folkboardScene() { folkResolveFallen(); _folkBoardWrapped(); }

/* the ones you helped, at the midnight bell */
function folkGateLines() {
  const f = folkState(), lines = [];
  if (f.bake === "done") lines.push("Tammis at the windlass, flour still on his forearms");
  if (f.tessa === "done") lines.push("Anna Brooke and a girl with her chin out, hauling rope side by side");
  if (f.voss === "done") lines.push("Mara Voss holding a lantern high with her husband's smallest hammer in her belt");
  if (f.corin === "done") lines.push("Corin Hessa in a stripped black cloak, putting two years of Blackpike drill into the bolts");
  if (f.cat === "done") lines.push("Widow Ottley, who could not haul anything, standing guard over everyone's coats with Maribel on her shoulder");
  if (!lines.length) return "";
  return ` And you know the hands on the bolts. ${lines.join("; ")}.`;
}
Object.assign(SCENES, {
  folkboard: folkboardScene,
  folk_cat, folk_bake, folk_bake_loud, folk_tessa, folk_tessa_win, folk_tessa2_win,
  folk_voss, folk_voss_win, folk_voss_night_win, folk_corin, folk_corin_ambushwin
});

/* ============================================================
   RED HERRINGS — false leads with real consequences
   ============================================================ */
function herringSmugglers() {
  flags.herring1Done = true;
  scene("⚓", "The Duskhaven File",
    [ `A dockhand slips you a tip that smells like money: a Duskhaven smuggling ring, flush since the raids began, running goods on the same nights the caravans burn. There's even a <b>file</b> — cargo manifests, names, dates — that "fell off" a watch-captain's desk.`,
      `It's tidy. It's damning. It's exactly what you've been looking for.`,
      `<i>Which is worth thinking about.</i>` ],
    [ { txt: "⚔ Raid the smugglers' warehouse tonight", req: `(after the fight: Investigation, DC 13) <span class="win">✓ see the file for what it truly is</span> · <span class="lose">✗ carry home "evidence" someone built for you</span>`, onclick: "startCombat(['thug','thug'], 'herring1_after', { intro: 'The smugglers keep two hired blades on the door and low expectations behind it. They fight like men defending inventory, not a conspiracy.' })" } ]);
}
function herring1_after() {
  const res = sceneCheck("Investigation", 13);
  if (res.success) {
    flags.herring1Solved = true;
    const xp = patrolXp(150);
    scene("⚓", "A Lead Too Clean",
      [ `The warehouse yields... smuggling. Ordinary, grubby, profitable smuggling — untaxed brandy and stolen wool. No goblin steel. No sunburst coin. No connection to the raids at all.`,
        `And then the detail that matters: the famous "fallen" file is written in one uniform hand on fresh paper — a <b>copy</b>, made recently, by a clerk. Files don't fall off desks. Files are <b>pushed</b>. Someone wanted the hero of Ironvale spending nights chasing brandy-runners.`,
        `You've learned something better than a lead: you've learned someone is <b>feeding you leads</b>. <b>(+${xp} XP — and you'll know the smell next time.)</b>` ],
      [ { txt: "🏙 Back to the city, warier", onclick: `grantXp(${xp},'the lead too clean'); goScene('town')` } ]);
  } else {
    addEvidence("smugglerNote");
    const xp = patrolXp(60);
    scene("⚓", "Case Closed?",
      [ `The warehouse yields crates, contraband, and confirmation enough for a tired mind: smugglers, profiting off the chaos. You pocket the cargo manifest as evidence — it fits the file perfectly.`,
        `<i>It fits the file perfectly.</i> The thought tries to snag on something, and doesn't quite. <b>(Evidence taken — unverified. +${xp} XP)</b>` ],
      [ { txt: "🏙 Back to the city", onclick: `grantXp(${xp},'the warehouse raid'); goScene('town')` } ]);
  }
}

function herringWidow() {
  flags.herringWidowDone = true;
  const auto = C.event.id === "betrayed";
  const res = auto ? { success: true } : sceneCheck("Insight", 13);
  if (res.success) {
    scene("🕯", "The Widow's Offer",
      [ `Word reaches the Ember of a defector: a clerk's widow, wronged by the Protectorate, offering payroll documents that "name every bought judge in the city." She'll meet only you, alone, at the fuller's yard at midnight.`,
        auto ? `You've been the trusting one before, at knife-cost. This has the exact shape of that night: the grief a little too articulate, the terms a little too specific, the location a little too enclosed. <i>(Betrayed by a Friend — you know a set table when you see one.)</i>` : `But the details sit wrong: her grief is word-perfect, her documents unseen, her chosen yard has one entrance and no windows. This isn't a defector. It's <b>bait</b>.`,
        `The Gray Web is fishing for the Ember. Which means the line runs both ways.` ],
      [ { txt: "🎭 Send a reply — and feed the Web a map of safehouses the Ember has never used", req: "(Deception, DC 12 — turn the sting)", onclick: "herringWidowFlip()" },
        { txt: "🚪 Simply don't show. Let them waste the night.", onclick: `grantXp(${patrolXp(80)},'the meeting that never was'); goScene('town')` } ]);
  } else {
    scene("🕯", "The Widow's Offer",
      [ `A clerk's widow, wronged by the Protectorate, offers payroll documents naming every bought judge in the city. Her grief is raw, her terms simple, her courage humbling. You go to the fuller's yard at midnight.`,
        `The documents are real paper, at least. The widow is a Gray Web actress, at least a good one, and the yard's one entrance closes behind you with the sound of professional boots.` ],
      [ { txt: "⚔ Fight out of the trap!", onclick: "startCombat(['assassin2','blackpike'], 'herringWidow_after', { intro: 'From the shadows, the widow watches with dry eyes, already composing tomorrow\\'s crier script.' })" } ]);
  }
}
function herringWidowFlip() {
  const res = sceneCheck("Deception", 12);
  if (res.success) {
    addTruth(8, "the Web wastes a month raiding empty cellars");
    const xp = patrolXp(180);
    scene("🎭", "The Line Runs Both Ways",
      [ `Your reply is a masterwork of frightened sincerity, and attached to it: a hand-drawn map of five Ember "safehouses" — a granary, two condemned cellars, a fuller's loft, and one address that happens to be a Blackpike sergeant's mother's house.`,
        `The Web spends a month kicking down empty doors and one extremely awkward one. The Ember's real cellars go untouched — and the city notices whose intelligence keeps being wrong. <b>(+${xp} XP, Truth rises)</b>` ],
      [ { txt: "🕯 Back to the Ember", onclick: `grantXp(${xp},'the flipped sting'); goScene('town')` } ]);
  } else {
    const xp = patrolXp(70);
    scene("🎭", "Too Clever By Half",
      [ `Your reply reads frightened and sincere — mostly. Somewhere in it, a phrase only a resistance quartermaster would use, and the Web's readers are paid to notice. No answer ever comes. The line goes quiet, both ways. Nothing lost — except the chance. <b>(+${xp} XP)</b>` ],
      [ { txt: "🕯 Back to the Ember", onclick: `grantXp(${xp},'a near miss'); goScene('town')` } ]);
  }
}
function herringWidow_after() {
  addTruth(-6, "criers: 'loyalist thugs assault a grieving widow'");
  addEvidence("widowPapers");
  scene("📰", "The Morning Version",
    [ `You fight clear of the fuller's yard — bruised, alive, and holding the widow's "payroll documents," which you already know better than to trust.`,
      `The criers have their version out by breakfast: <i>masked loyalist brutes, a war hero's widow, an unprovoked assault.</i> There are woodcuts. In them you have fangs. <b>(Truth falls. The papers join your satchel — unverified, and radioactive.)</b>` ],
    [ { txt: "🕯 Back to the Ember", onclick: `grantXp(${patrolXp(90)},'the sprung trap'); goScene('town')` } ]);
}

function hasFalseEvidence() { return flags.evidence.some(e => EVIDENCE[e] && EVIDENCE[e].false); }

Object.assign(SCENES, { patrol_after, herring1_after, herringWidow_after, m4_qm_accuse, m2_armory_loot });
Object.assign(EVIDENCE, {
  smugglerNote: { name: "? Smugglers' cargo manifest — unverified", weight: 0, false: true },
  reqSlip:      { name: "? Quartermaster's requisition slip — unverified", weight: 0, false: true },
  widowPapers:  { name: "? The 'widow's' payroll papers — unverified", weight: 0, false: true }
});

/* ============================================================
   PORTRAITS — parametric flat-vector busts, one consistent style
   ============================================================ */
function makePortrait(o) {
  const skin = o.skin || "#c99b72";
  const armor = o.armor || "#4a3c28";
  const trim = o.trim || "#c9a227";
  const bgTint = o.bg || "#2a2117";
  const parts = [];
  // backdrop + ring
  parts.push(`<circle cx="60" cy="60" r="58" fill="${bgTint}"/>`);
  parts.push(`<circle cx="60" cy="42" r="34" fill="#000" opacity="0.18"/>`);
  // shoulders / garb
  parts.push(`<path d="M14,122 Q26,80 60,78 Q94,80 106,122 Z" fill="${armor}"/>`);
  parts.push(`<path d="M14,122 Q26,80 60,78 Q94,80 106,122 Z" fill="none" stroke="${trim}" stroke-width="2" opacity="0.55"/>`);
  if (o.collar) parts.push(o.collar);
  // neck + head
  parts.push(`<rect x="52" y="62" width="16" height="14" rx="5" fill="${skin}"/>`);
  parts.push(`<circle cx="60" cy="48" r="21" fill="${skin}"/>`);
  // hair / headwear (behind-face pieces drawn after head where they overlap edges)
  if (o.hairBack) parts.push(o.hairBack);
  // ears hint
  parts.push(`<circle cx="39.5" cy="48" r="3.4" fill="${skin}"/><circle cx="80.5" cy="48" r="3.4" fill="${skin}"/>`);
  if (o.tusks) parts.push(`<path d="M50,60 L48,50 L54,56 Z" fill="#f0e6d0"/><path d="M70,60 L72,50 L66,56 Z" fill="#f0e6d0"/>`);
  // eyes
  const eye = o.eyes || "#241a10";
  const glow = o.glowEyes ? ` filter="url(#pglow)"` : "";
  parts.push(`<circle cx="52" cy="46" r="${o.glowEyes ? 3 : 2.3}" fill="${eye}"${glow}/><circle cx="68" cy="46" r="${o.glowEyes ? 3 : 2.3}" fill="${eye}"${glow}/>`);
  // brows
  parts.push(`<path d="M47,40 q5,-${o.stern ? 1 : 3} 10,-1" stroke="${o.hairColor || "#3a2c1a"}" stroke-width="2.4" fill="none" stroke-linecap="round"/>`);
  parts.push(`<path d="M63,${o.stern ? 38 : 39} q5,${o.stern ? 2 : -1} 10,${o.stern ? 3 : 1}" stroke="${o.hairColor || "#3a2c1a"}" stroke-width="2.4" fill="none" stroke-linecap="round"/>`);
  // nose + mouth
  parts.push(`<path d="M60,48 q2.5,5 0,8" stroke="#00000033" stroke-width="2" fill="none" stroke-linecap="round"/>`);
  if (!o.beard) parts.push(`<path d="M54,62 q6,${o.smile ? 4 : 1.5} 12,0" stroke="#00000055" stroke-width="2" fill="none" stroke-linecap="round"/>`);
  if (o.scar) parts.push(`<path d="${o.scar}" stroke="#8c5a4a" stroke-width="2" fill="none" stroke-linecap="round"/>`);
  if (o.beard) parts.push(o.beard);
  if (o.hairFront) parts.push(o.hairFront);
  if (o.extra) parts.push(o.extra);
  return `<svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" role="img">
    <defs><filter id="pglow"><feGaussianBlur stdDeviation="1.2" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
    <clipPath id="pclip"><circle cx="60" cy="60" r="58"/></clipPath></defs>
    <g clip-path="url(#pclip)">${parts.join("")}</g>
    <circle cx="60" cy="60" r="57" fill="none" stroke="#c9a227" stroke-width="2.5" opacity="0.9"/>
  </svg>`;
}

