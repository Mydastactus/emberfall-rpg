function pArt(key) {
  return PORTRAITS[key] ? `<span class="scene-portrait">${PORTRAITS[key]}</span>` : "❔";
}

/* ============================================================
   HERO SHEET & JOURNAL — overlay, no scene re-entry
   ============================================================ */
function journalEntries() {
  const ch = flags.chapter, e = [];
  const done = n => ch > n, now = n => ch === n;
  const add = (n, title, text) => { if (done(n) || now(n)) e.push({ n, title, text, current: now(n) }); };
  add(1, "The Medicine Train", done(1)
    ? `Councilor Thorne — warm, worried, generous — hired you from his own purse to recover a stolen medicine shipment. You broke Captain Snagfang's raiders and brought every crate home. ${flags.coinKept ? "You kept the odd sunburst coin he gave you. Something about it seemed worth remembering." : "He paid in gold, and one odd sunburst coin you spent without a second look."}`
    : `A medicine shipment bound for the refugee camps was taken on the Duskhaven road. Thorne has hired you to bring it back.`);
  add(2, "The Warren of Craghollow", done(2)
    ? `Thorne's flawless map led you to Lieutenant Grukk's warren. You freed the trapper Sera${flags.evidence.includes("forgemark") ? ", found Ironvale forge-marks on goblin steel," : ""} and put Grukk down — ${flags.evidence.includes("coin") ? "and matched the fresh-minted coin in his pouch to Thorne's own gift. The same purse pays both sides." : "his pouch heavy with suspiciously fresh-minted coin."} While you fought underground, the Westmill granary burned, unguarded.`
    : `Thorne has a map of the goblin warren — a map almost too good. Grukk waits below Craghollow Ridge.`);
  add(3, "Gray Orders", done(3)
    ? (flags.grayLoyal ? `You carried out the council's weapons confiscation — gently, but you carried it out. The wagons rolled to the Blackpike depot, and the poor quarter remembers who led them.`
      : flags.graySubverted ? `You took Thorne's confiscation writ and quietly betrayed it — real steel under floorboards, rusted scrap in the wagons. The poor quarter knows what you did for them. Thorne, so far, does not.`
      : `You refused the confiscation writ to Thorne's face. The Blackpikes did it without you, uglier — and paid knives found you in an alley soon after.`)
    : `The council wants the citizens disarmed "for centralized defense." The writ has your name on it.`);
  add(4, "The Poisoned Gift", done(4)
    ? `King Alden armed you with a royal writ and his father's charm, and sent you to retake Redwatch — but the goblins knew your route, known only to the war council. ${flags.evidence.includes("routeNote") ? "In Vex's tent you found your own route under a council seal." : flags.embarrassed ? "In Vex's tent you seized a planted lead and denounced an innocent quartermaster — a mistake the court remembers." : "Vex's paperwork burned unread — whatever it proved rode away with the wind."}`
    : `The King himself has charged you with retaking Redwatch fort. Only three people know your route.`);
  add(5, "The Warlord's Ledger", done(5)
    ? `You went into Gar'Thok's war camp and came out with his insurance: a ledger of every raid Thorne bought, in the warlord's own hand.`
    : `Sera can put you inside Gar'Thok's camp. Whatever ties the warlord to his paymaster lives in the great tent.`);
  add(6, "The Breaking Point", done(6)
    ? `The siege came, the Duke died in his bath, and you carried the truth to a King who loved his traitor like a brother. ${flags.thorneFate === "justice_hero" ? "The square heard the case from your own lips, and turned its back on Thorne as one body." : flags.thorneFate === "justice" ? "Alden read the ledger aloud in the torch-lit square, and Thorne left his own podium in chains." : flags.thorneFate === "wolves" ? "Thorne fled the podium — and Gar'Thok's oathband collected the debt their warlord was owed. Sunburst coins, arranged in a circle." : "In the uproar Thorne vanished into the crowd he knew better than anyone. The realm still hunts a gray man with soft hands."}`
    : `The horde is at the gates, the Duke is dead, and Thorne's podium is built. Whatever evidence you hold, tonight it must be enough.`);
  add(7, "The Exoneration", done(7)
    ? `A stacked commission declared your ledger a forgery, and Thorne took a staged knife for the King to complete his rehabilitation. ${flags.sawStaging ? "You saw the choreography in it — the blade turned flat, the step into it." : "The hall saw an old man buy a king's life with his own blood."} The Ember gathers in a tannery cellar.`
    : `Thorne is back — exonerated, beloved, and twice the martyr. Sera whispers that something bigger is coming.`);
  add(8, "The Second Siege", done(8)
    ? `Zarga's horde besieged the city on schedule. ${flags.decoyRefused ? "You refused Thorne's decoy errand and watched the King leave his own city through the catacombs, believing false intelligence." : "Thorne's 'relief column' was a decoy to move you out of the city — and it nearly worked."} By the time the dust settled: a staged miracle, a forged abdication, and Lord Protector Thorne on the balcony.`
    : `The siege tightens. Thorne wants you escorting a relief column. Sera smells a trap with two doors.`);
  add(9, "City of Lies", done(9)
    ? `From the Ember you fought the story itself${flags.bramSaved ? " — Ser Bram lifted from the gallows" : ""}${flags.opsDone && flags.opsDone.includes("B") ? ", ten questions printed in the King's own typeface" : ""}${flags.evidence.includes("wagonManifest") ? ", and the 'stolen' treasury traced to Blackpike wagons rolling east" : ""}. Vail let you walk away once, and told you where the King went.`
    : `Two operations, then the crackdown comes. Choose what the city needs most.`);
  add(10, "The King in the Wilderness", done(10)
    ? `Through the ghoul-haunted catacombs — where a dead scout still carried the false orders that moved a King — and north through the fens, you found Alden guarding a ruin and talked him back onto his feet. ${flags.zargaDeal ? "Zarga sold you Thorne's letters and a truce, payable from the traitor's estates." : "Zarga's Bone-Sworn didn't part with her insurance willingly."}`
    : `The King is somewhere past the Coldbrook fens, believing himself a coward. Find him. Rebuild him.`);
  add(11, "The Barons' Moot", done(11)
    ? `At Wrenhall, ${flags.baronsWon || 0} banner${(flags.baronsWon || 0) === 1 ? "" : "s"} dipped to the King — and the Gray Web's knives at the moot dipped the rest of the realm's doubts with them.`
    : `Three barons, three prices, one moot. The King speaks first; the case is yours to close.`);
  add(12, "The Retaking of Ironvale", done(12)
    ? `Ironvale came home. ${(flags.truth || 0) >= 65 ? "The city opened its own gates at the midnight bell." : "The east gate was stormed one last time."} ${flags.vailYielded ? "Vail yielded her duel and her testimony both." : ""}`
    : `The host stands before the walls. Hearts of the City: ${flags.truth || 0}/100. At 65, the gates open themselves.`);
  add(13, "Epilogue", `The Serpent unmasked; the Coward King uncrowned. Somewhere in the nation, the Circle's other chairs are still warm.`);
  // the small debts — the people, not the war
  if (ch >= 8 && flags.folk && Object.keys(flags.folk).length) {
    const f = flags.folk, bits = [];
    if (f.cat === "done") bits.push("Maribel sleeps on Widow Ottley's sill");
    if (f.bake === "done") bits.push("Tammis bakes for the Ember, recipe book home");
    if (f.tessa === "done") bits.push("Tessa Brooke is home — her mother sets two plates for two people");
    if (f.tessa === "lost") bits.push("the convoy cleared the hills. Anna Brooke still sets two plates");
    if (f.voss === "done") bits.push("Dain Voss is buried under his own name: HE SAID NO");
    if (f.voss === "lost") bits.push("Mara Voss left by night; the canal keeps its story");
    if (f.corin === "done") bits.push("Corin Hessa's stripped black cloak hangs on the Ember wall");
    if (f.corin === "lost") bits.push("Corin re-upped. Hessa still sets his place");
    if (bits.length) e.push({ n: 0, title: "The Small Debts", text: `Not everything on Sera's list was a war. ${bits.join(". ")}.`, current: false });
  }
  return e;
}

function heroSheetHtml() {
  const w = curWeapon();
  const perks = [
    ["Race — " + C.race.name, C.race.perk],
    ["Class — " + C.cls.name, C.cls.perk],
    ["Origin — " + C.origin.name, C.origin.perk],
    ["Event — " + C.event.name, C.event.perk],
    ["Motive — " + C.motive.name, C.motive.perk]
  ];
  const abilities = [`${C.cls.ability.name}: ${C.cls.ability.desc}`];
  if (C.breath) abilities.push("Fire Breath: 2-4d6 fire to all foes, once per combat");
  (C.spells || []).forEach(k => abilities.push(`${WIZ_SPELLS[k].name}: ${WIZ_SPELLS[k].desc}`));
  const itemCounts = {};
  C.items.forEach(i => itemCounts[i] = (itemCounts[i] || 0) + 1);
  const journal = journalEntries();
  return `
  <div id="hs-box">
    <button id="hs-close" onclick="closeHeroSheet()">✕ Close</button>
    <h2 style="color:var(--gold-bright);font-variant:small-caps;letter-spacing:2px">${PORTRAITS && PORTRAITS[C.cls.id] ? `<span class="hs-portrait">${PORTRAITS[C.cls.id]}</span>` : ""}${esc(C.name)}</h2>
    <div class="card-tag">Level ${C.level} ${C.race.name} ${C.cls.name} · ${C.origin.name} · ${C.event.name} · driven by ${C.motive.name}</div>
    <div class="sheet-block"><i>${C.backstoryProse}</i></div>
    <div class="stat-grid">${ABILITIES.map(a => `<div class="stat-box"><div class="stat-name">${a}</div><div class="stat-val">${C.scores[a]}</div><div class="stat-mod">${fmtMod(mod(C.scores[a]))}</div></div>`).join("")}</div>
    <div class="sheet-block">
      <b>HP:</b> ${C.hp}/${C.maxHp} &nbsp; <b>AC:</b> ${C.ac} <span class="card-tag">(${armorDisplayName()})</span> &nbsp; <b>Gold:</b> ${C.gold} &nbsp; <b>XP:</b> ${C.xp}${xpToNext() ? ` / ${xpToNext()} to Lv ${C.level + 1}` : " (max level)"}<br>
      <b>Weapon:</b> ${weaponName()} — ${w.dmg[0]}d${w.dmg[1]}${w.dmgB + weaponDmgBonus() ? "+" + (w.dmgB + weaponDmgBonus()) : ""} (${w.stat}${w.atk + weaponAtkBonus() ? ", " + fmtMod(w.atk + weaponAtkBonus()) + " atk" : ""})${C.weaponTier === 2 ? " +1d4 fire" : C.weaponTier === 3 ? " +1d6 fire" : ""}
      ${durChip()}
    </div>
    <div class="sheet-block"><b>Abilities & Spells:</b><br>${abilities.map(a => `<span class="tag">${a}</span>`).join("")}</div>
    <div class="sheet-block"><b>Backstory Perks:</b><br>${perks.map(p => `<span class="tag" title="${esc(p[1])}"><b>${p[0]}:</b> ${p[1]}</span>`).join("")}</div>
    ${C.perks && C.perks.length ? `<div class="sheet-block"><b>🎁 Level Perks & Traits:</b><br>${C.perks.map(id => { const p = perkDefById(id); return p ? `<span class="tag"><b>${p.name}:</b> ${p.desc}</span>` : ""; }).join("")}</div>` : ""}
    <div class="sheet-block"><b>Proficiencies</b> (+${profBonus()}): ${C.profs.map(p => `<span class="tag">${p}</span>`).join("")}</div>
    <div class="sheet-block"><b>Inventory:</b><br>${Object.keys(itemCounts).length ? Object.entries(itemCounts).map(([i, n]) => `<span class="tag">${esc(i)}${n > 1 ? " ×" + n : ""}</span>`).join("") : "<span class='card-tag'>Empty pockets</span>"}</div>
    ${flags.evidence && flags.evidence.length ? `<div class="sheet-block"><b>🧾 Evidence & Proofs:</b><br>${flags.evidence.map(id => `<span class="tag" style="${EVIDENCE[id].false ? "border-color:#8c5a4a;color:#d48a80" : "border-color:#5a7d4a;color:#a8c69a"}">${EVIDENCE[id].false ? "⚠" : "✓"} ${esc(EVIDENCE[id].name)}</span>`).join("")}${hasFalseEvidence() ? `<div class="card-tag" style="margin-top:4px;color:#d48a80">⚠ Unverified papers in the satchel — a debunked lead can sink a true case.</div>` : ""}</div>` : ""}
    <h2 style="color:var(--gold);font-variant:small-caps;letter-spacing:2px;margin-top:18px">📖 Journal</h2>
    ${journal.map(j => `<div class="sheet-block" ${j.current ? 'style="border-color:var(--gold)"' : ""}><b>${j.current ? "▶ " : j.n === 0 ? "🏮 " : "✓ "}${j.n === 0 ? j.title : `Ch. ${j.n} — ${j.title}`}</b><br><span style="font-size:.92em">${j.text}</span></div>`).join("")}
    ${flags.chapter >= 8 && flags.chapter <= 12 ? `<div class="sheet-block"><b>🗣 Hearts of the City:</b> ${flags.truth || 0}/100 — at 65+, Ironvale rises with you.</div>` : ""}
  </div>`;
}

function openHeroSheet() {
  if (!C) return;
  let ov = document.getElementById("hero-sheet-overlay");
  if (!ov) {
    ov = document.createElement("div");
    ov.id = "hero-sheet-overlay";
    ov.addEventListener("click", e => { if (e.target === ov) closeHeroSheet(); });
    document.body.appendChild(ov);
  }
  ov.innerHTML = heroSheetHtml();
  ov.style.display = "flex";
}
function closeHeroSheet() {
  const ov = document.getElementById("hero-sheet-overlay");
  if (ov) ov.style.display = "none";
}
function updateSheetBtn() {
  let b = document.getElementById("sheet-ctl");
  if (!b) {
    b = document.createElement("div");
    b.id = "sheet-ctl";
    b.innerHTML = `<button onclick="openHeroSheet()" title="Hero sheet & journal">📖</button>`;
    document.body.appendChild(b);
  }
  b.style.display = C ? "block" : "none";
}

