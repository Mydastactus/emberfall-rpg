/* ============================================================
   CAMPAIGN 2 — THE COWARD KING (chapters 7-12)
   ============================================================ */
Object.assign(CHAPTER_NAMES, {
  7: "Ch. 7 — The Exoneration", 8: "Ch. 8 — The Second Siege",
  9: "Ch. 9 — City of Lies", 10: "Ch. 10 — The King in the Wilderness",
  11: "Ch. 11 — The Barons' Moot", 12: "Ch. 12 — The Retaking of Ironvale", 13: "Epilogue"
});
Object.assign(EVIDENCE, {
  realOrders:    { name: "The royal scout's true orders — the lie that moved a King", weight: 2 },
  wagonManifest: { name: "Depot manifest: the 'stolen' treasury on Blackpike wagons", weight: 2 },
  zargaLedger:   { name: "Zarga's insurance — Thorne's letters, second verse", weight: 3 }
});
function proofCount() { return ["realOrders", "wagonManifest", "zargaLedger"].filter(e => flags.evidence.includes(e)).length; }
function addTruth(n, label) {
  flags.truth = Math.max(0, Math.min(100, (flags.truth || 0) + n));
  logRoll("🗣 Hearts of the City", `${n > 0 ? "+" : ""}${n} — ${label} (now ${flags.truth}/100)`, n > 0 ? "success" : "fail");
}

function c2Council(ch) {
  const dest = ch === 7 ? "c7_open" : ch === 8 ? "c8_brief" : ch === 9 ? "c9_ops"
    : ch === 10 ? "c10_track" : ch === 11 ? "c11_moot" : ch === 12 ? "c12_stage" : "epilogue2";
  if (dest !== "epilogue2" && missionWaylay(dest)) return;
  goScene(dest);
}

/* ---------- CHAPTER 7 — THE EXONERATION ---------- */
function c7_open() {
  flags.m = {}; flags.checkpoint = "c7_open";
  const fateLine = {
    justice: `Thaddeus Thorne went to the dungeons in chains, and Ironvale slept soundly for half a year. Then the appeals began.`,
    justice_hero: `They chanted your name the night Thorne fell — and for half a year, Ironvale healed. But gold is patient, and Thorne's gold never stopped working while he sat in his cell.`,
    flight: `They never found Thorne. Half a year of quiet — and then, one gray morning, he simply <b>returned</b>, walking through the main gate with lawyers instead of guards, "to answer these slanders like a free man of conscience."`,
    wolves: `They buried what the crossroads patrol found — and half a year later, a living Thaddeus Thorne walked through Ironvale's gate. "An assassin wearing my face," he explained sadly, of the corpse. "The realm's enemies wanted me dead so the truth would die with me." He'd even had the double's teeth arranged in advance.`
  }[flags.thorneFate || "justice"];
  scene(pArt("thorne"), "The Royal Commission",
    [ `<i>${fateLine}</i>`,
      `The Royal Commission of Inquiry sits for nine days. Its findings, read to a packed square: the wolf-hide ledger is a <b>forgery</b> — its paper milled two years after its earliest entries, its cipher "planted by parties unknown to defame a servant of the realm." Three experts swear to it. Two of them are new to the city. All of them are thorough.`,
      `You know what you carried out of that war camp. It doesn't matter. The law has spoken, and the law's paper was swapped somewhere between the evidence vault and the bench.`,
      `King Alden finds you afterward, in a corridor away from the clerks. He looks like a man who has been shouting in a dream where no sound comes out. "I know what I read that night," he says quietly. "And the law I am sworn to uphold just called it a lie. If I overrule my own commission for a friend—" he stops. "That's how HE would rule. Not me." He grips your shoulder, hard. "Watch him. That is not a request."` ],
    [ { txt: "🎭 Attend the Reconciliation Gala — if Thorne is performing, you'll be in the audience", onclick: "goScene('c7_gala')" } ]);
}
function c7_gala() {
  const res = sceneCheck("Perception", 15);
  if (res.success) { flags.sawStaging = true; }
  scene("🎭", "The Reconciliation Gala",
    [ `The great hall glitters. Thorne moves through it like forgiveness made flesh — embracing old enemies, refusing every toast in his honor, redirecting each one "to the heroes who defend us, even when they wound us." He finds you across the room and raises his cup, eyes shining with what looks — it truly looks — like grief and grace.`,
      `Then, at the height of the evening: a scream. A man bursts from the servants' line, knife high, lunging at <b>King Alden</b> — and Thaddeus Thorne, sixty years old, throws himself into the blade's path. It takes him through the shoulder. Blood on marble. Pandemonium.`,
      res.success
        ? `But you were watching. You saw the knife-man <b>check his footing</b> before the lunge — the way duelists do when the ending is choreographed. You saw the blade turn flat at the last inch. You saw Thorne step INTO it, precisely, like a dance partner. <i>(You witnessed the staging — someone else in this city can be made to confirm it.)</i>`
        : `It happens too fast to read — a blur of steel and heroism. The hall sees an old man buy a king's life with his own blood.`,
      `A second knife-man comes through the smoke of the toppled braziers — and this one is looking at YOU. Loose ends are being trimmed tonight.` ],
    [ { txt: "⚔ Fight — and try to take one alive", onclick: "startCombat(['assassin2','assassin2'], 'c7_after', { noFlee: true, ally: { name: 'Palace Guard', atk: 6, dmg: [1, 8, 3] }, intro: 'Gray Web assassins — professionals. They fight like men who are paid better if no one is left to question. A palace guardsman rallies to your side, halberd leveled.' })" } ]);
}
function c7_after() {
  scene("🏛", "The Martyr's Shoulder",
    [ `Both assassins fight to the death — literally refusing to be taken, the second one biting down on something bitter when your blade pins him. Loose ends, trimmed. <b>(+150 gold from the Web's purses)</b>`,
      `By morning the story has already been carved in stone: <i>Thorne the Shield, who took the knife meant for his King.</i> Alden — guilt-wracked, twice wrong about his friend by his own accounting — restores him to the council with an apology delivered on one knee. The square weeps. The bells ring until noon.`,
      `That night, a beggar presses a scrap into your hand. Sera's writing: <i>"Cellar under the old tannery. Come alone. It's worse than you think."</i>`,
      `In the cellar: Sera, leaner and harder, her ranger's cloak traded for gray wool. "They disbanded the rangers — 'consolidated scouting under the Blackpikes.' I've been watching the north road." She spreads a charcoal map. "Zarga — Gar'Thok's blood-heir — has been massing for months. Her horde moves like it's <b>waiting for a date</b>. And Thorne's grain barges have been quietly leaving the city for weeks." She looks up. "He's building another famine, and this time he owns the courts, the criers, and half the watch. Whatever he's planning, it's bigger than last time."` ],
    [ { txt: "🕯 Welcome to the Ember. Prepare for what's coming.", onclick: "C.gold += 150; grantXp(500,'Chapter 7: the Exoneration'); flags.seraFriend = true; flags.chapter = 8; goScene('town')" } ]);
}

/* ---------- CHAPTER 8 — THE SECOND SIEGE & THE FRAME ---------- */
function c8_brief() {
  flags.m = {}; flags.checkpoint = "c8_brief";
  scene(pArt("thorne"), "The Second Siege",
    [ `It comes exactly as Sera predicted. Warchief <b>Zarga's</b> horde pours out of the eastern hills — larger than her father's, better fed, patient. The gates close. The bread lines stretch. The siege of Ironvale begins again, and this time the granaries were already half-empty before the first arrow flew.`,
      `On the ninth day, Thorne summons you — arm still in its martyr's sling, eyes warm as ever. "My friend. The relief column from Duskhaven — food, medicine, four hundred wagons of survival — needs the one escort no goblin will dare test." He takes your hands in both of his. "I would trust no one else. Bring our people their bread."`,
      `Sera's warning burns in your pocket: <i>"He's moving YOU. Whatever he needs the city not to see, it happens while you're gone. But if the column's real and you refuse — people starve. His trap has two doors."</i>` ],
    [ { txt: "🛡 Ride with the column — if it's real, the city needs it. If it's a trap, spring it.", onclick: "goScene('c8_column')" },
      { backstory: true, txt: "🕯 Refuse quietly and vanish into the Ember — watch what he does while he thinks you're gone", req: bkReq("Sera's counsel — stay and see"), onclick: "flags.decoyRefused = true; goScene('c8_watch')" } ]);
}
function c8_column() {
  scene("🛞", "The Relief Column",
    [ `The column is real — barely. Forty wagons, not four hundred, crawling the Duskhaven road. On the second day, in a defile the maps call Widow's Gap, the "escort mission" reveals its true cargo: <b>you</b>.`,
      `They come with discipline — an orc veteran of Zarga's horde flanked by a Blackpike enforcer. Fighting <i>together</i>. The warlord's soldier and the Lord Councilor's, shoulder to shoulder, and neither finds it strange.`,
      `<i>Remember this. Make them remember it too.</i>` ],
    [ { txt: "⚔ Cut them down and ride for home", onclick: "startCombat(['orcVet','blackpike'], 'c8_return', { intro: 'The ambush closes. Orc iron and Blackpike steel — one paymaster.' })" } ]);
}
function c8_watch() {
  const res = sceneCheck("Stealth", 13);
  scene("🌙", "The Night of the Catacombs",
    [ `You send your regrets and a plausible fever, and go to ground in the Ember. Sera posts you where her instincts point: the old <b>catacomb gate</b> behind the temple quarter, the city's forgotten back door.`,
      `An hour past midnight, it opens. ${res.success ? "From deep shadow you watch them pass not ten feet away:" : "You're nearly caught by the outriders — Blackpikes sweeping the approaches — and see it only from a rooftop's distance:"} <b>King Alden</b>, cloaked, grim, moving like a man performing his own funeral — and around him his vanguard, the twelve best blades in the realm, escorting their King <i>out of his own city</i> in the dead of night.`,
      `No coercion. No struggle. Alden's own face, resolved and wretched. Whatever moved him, he <b>believes</b> it.`,
      `You are still deciding whether to follow when the Blackpike net closes on the tannery district — "routine curfew enforcement," a full company of it, herding everyone including you into a holding yard until dawn. Almost as if the night needed no witnesses loose.` ],
    [ { txt: "⚔ Dawn comes. Break out of the holding yard.", onclick: "startCombat(['blackpike','thug'], 'c8_return', { intro: 'The yard sergeant finds your face on a list he pretends not to have. His mistake is mentioning it.' })" } ]);
}
function c8_return() {
  scene(pArt("thorne"), "The Staged Miracle",
    [ `You return to a city gone mad with joy.`,
      `The siege is <b>over</b>. Zarga's entire horde struck its camps in a single night and melted into the eastern woods — unbeaten, unbought, unexplained. And on the royal balcony, before ten thousand starving, weeping citizens, stands Thaddeus Thorne, proclaiming the "miracle of Ironvale": his own Blackpike militia's daring night raid on the horde's supply caches, which "by the Dawnmother's grace, broke the monsters' will."`,
      `Then his face crumples — masterfully — and he raises a parchment heavy with the royal seal.`,
      `"My friends. I must be the one to tell you. The King... is gone. Fled in the night through the catacombs, with his picked knights and—" his voice breaks, "—and the last gold of the treasury. He leaves us this." He reads the letter. It is perfect: Alden's hand, Alden's blunt cadence, a soldier's confession of despair. <i>The city is doomed. I will not die with it. The crown lies where I drop it.</i>`,
      `Silence. Then the sound you'll hear in your sleep: ten thousand people, betrayed, beginning to boo their King. By nightfall the criers have their orders and the wall has its posters: the vanguard knights branded deserters, their families under "protective watch." And Thaddeus Thorne, "reluctantly, temporarily, only until order is restored," accepts the mantle of <b>Lord Protector of Ironvale</b>.` ],
    [ { txt: "🕯 Down to the Ember. The long war for the truth starts now.", onclick: "c8_finish()" } ]);
}
function c8_finish() {
  flags.lordProtector = true;
  flags.truth = 10 + (flags.decoyRefused ? 8 : 0) + (flags.sawStaging ? 5 : 0) + (flags.citizenRep >= 2 ? 5 : 0);
  grantXp(600, "Chapter 8: the Second Siege");
  C.gold += 100;
  logRoll("🗣 Hearts of the City", `The truth starts at ${flags.truth}/100. The lie has a week's head start and a balcony.`, "fail");
  flags.chapter = 9;
  goScene("town");
}

