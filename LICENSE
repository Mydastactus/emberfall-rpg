    [ `Krell goes down in front of witnesses, and the mold and the note go up on the Ember's wall beside the gallery of the disappeared — the first entry in that gallery to ever get an <i>answer</i>.`,
      `Mara Voss buries her husband under his own name. She sends you his good chisels. "He'd want a working hand to have them."` ],
    [ { txt: "🏮 Back to the board", onclick: "goScene('folkboard')" } ]);
}
