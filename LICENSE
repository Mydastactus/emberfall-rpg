function perkDefById(id) {
  for (const cls of Object.values(PERKS)) {
    for (const tier of cls.tiers) for (const p of tier) if (p.id === id) return p;
    for (const p of cls.traits5) if (p.id === id) return p;
    for (const p of cls.traits10) if (p.id === id) return p;
  }
  return null;
}

function recomputePerkFx() {
  const fx = { atk: 0, dmg: 0, ac: 0, acShield: 0, acTwoHand: 0, init: 0, critMin: 20, flatDR: 0, thorns: 0, thornsAlways: 0,
    regenBelow: 0, potionMult: 1, shopDisc: 0, abilityUse: 0, abilityPower: false, xpMult: 1, allyAtk: 0, bloodiedDmg: 0,
    atkVsImpaired: 0, killRefund: false, healOnAbility: false, ward: false, ward2: false, bleedCrit: false, frostCrit: false,
    shredCrit: false, stunImmune: false, poisonImmune: false, saveAdvCON: false, saveAdvDEX: false, saveAdvWIS: false,
    statusShrug: false, frostAll: false, spellExtra: false, spellExtra2: false };
  (C.perks || []).forEach(id => {
    const p = perkDefById(id);
    if (!p) return;
    for (const [k, v] of Object.entries(p.fx)) {
      if (k === "hpFlat") continue; // applied once at acquisition
      if (k === "critMin") fx.critMin = Math.min(fx.critMin, v);
      else if (typeof v === "number") {
        if (k === "potionMult" || k === "xpMult") fx[k] = Math.max(fx[k], v);
        else if (k === "shopDisc") fx[k] = Math.max(fx[k], v);
        else if (k === "regenBelow") fx[k] = Math.max(fx[k], v);
        else fx[k] += v;
      }
      else fx[k] = fx[k] || v;
    }
  });
  C.perkFx = fx;
  if (C.armorId) recomputeAC();
}
function pfx() { return (C && C.perkFx) || { critMin: 20, potionMult: 1, xpMult: 1 }; }

function perkOptionsForLevel(lv) {
  const P = PERKS[C.cls.id];
  if (!P) return [];
  if (lv === 5) return P.traits5.filter(p => !C.perks.includes(p.id));
  if (lv >= 10) return P.traits10.filter(p => !C.perks.includes(p.id));
  if (lv >= 1 && lv <= 4) return P.tiers[lv - 1].filter(p => !C.perks.includes(p.id));
  // levels 6-9: pick from perks you passed over, rotating tiers
  const leftovers = [];
  for (let t = 0; t < 4; t++) P.tiers[(lv - 6 + t) % 4].forEach(p => { if (!C.perks.includes(p.id)) leftovers.push(p); });
  return leftovers.slice(0, 3);
}

function openPerkChoice() {
  if (!C || !C.pendingPerks || !C.pendingPerks.length || (combat && !combat.over)) return;
  const lv = C.pendingPerks[0];
  const opts = perkOptionsForLevel(lv);
  if (!opts.length) { // pool exhausted — sturdy fallback
    C.pendingPerks.shift();
    C.maxHp += 3; C.hp += 3;
    logRoll("🎁 Seasoned Veteran", "No perks remained to learn — +3 max HP instead.", "success");
    return openPerkChoice();
  }
  let ov = document.getElementById("perk-overlay");
  if (!ov) { ov = document.createElement("div"); ov.id = "perk-overlay"; document.body.appendChild(ov); }
  const isTrait = lv === 5 || lv >= 10;
  ov.innerHTML = `<div id="perk-box">
    <h2 style="color:var(--gold-bright);font-variant:small-caps;letter-spacing:2px;text-align:center">${isTrait ? "🌟 Level " + lv + " — Choose Your TRAIT" : "🎁 Level " + lv + " — Choose a Perk"}</h2>
    <p class="flavor" style="text-align:center">${isTrait ? "A defining power. There is no changing this choice." : "One of three. The paths not taken may return at later levels."}</p>
    <div class="choice-grid" style="grid-template-columns:1fr">
      ${opts.map((p, i) => `<div class="card" onclick="choosePerkOption(${i})">
        <div class="card-name">${p.name}</div>
        <div class="card-desc">${p.desc}</div>
      </div>`).join("")}
    </div>
  </div>`;
  ov.style.display = "flex";
}
function choosePerkOption(i) {
  const lv = C.pendingPerks[0];
  const opts = perkOptionsForLevel(lv);
  const p = opts[i];
  if (!p) return;
  C.pendingPerks.shift();
  C.perks.push(p.id);
  if (p.fx.hpFlat) { C.maxHp += p.fx.hpFlat; C.hp += p.fx.hpFlat; }
  recomputePerkFx();
  sfx("level");
  logRoll("🎁 " + (lv === 5 || lv >= 10 ? "TRAIT" : "Perk") + " gained", p.name + " — " + p.desc, "crit");
  const ov = document.getElementById("perk-overlay");
  if (C.pendingPerks.length) openPerkChoice();
  else { if (ov) ov.style.display = "none"; autosave(); const sc = $("sidebar-col"); if (sc) sc.innerHTML = sidebar(); }
}

