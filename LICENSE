function wlChestScene(i) {
  const c = WL_CHESTS[i];
  const stakes = `(${c.skill}, DC ${c.dc}) <span class="win">✓ ${c.winTxt}</span> · <span class="lose">✗ ${c.loseTxt}</span>`;
  scene(c.art, c.title, [c.text],
    [ { txt: c.openTxt, req: stakes, onclick: `wlOpenChest(${i})` },
      { txt: "🛤 Leave it be — press on", onclick: "wlContinue()" } ]);
}
function wlOpenChest(i) {
  const c = WL_CHESTS[i];
  const res = sceneCheck(c.skill, c.dc);
  if (res.success) {
    const g = c.g[0] + d(c.g[1]);
    C.gold += g;
    (c.items || []).forEach(it => C.items.push(it));
    if (c.truth && flags.chapter >= 8 && flags.chapter <= 12) addTruth(c.truth, "a loyalist's parcel, delivered");
    // lucky hands: a small cut of chest-finds turns up something rarer
    let rare = "";
    if (i >= 2 && d(100) <= 15 && magicWeaponPool().length) {
      const pool = magicWeaponPool();
      const w = grantMagicWeapon(pool[rand(pool.length)], "found wrapped in oilcloth");
      rare = ` And beneath everything, wrapped with a care the rest of the hoard never got: <b>✨ ${w.name}</b> — <i>${w.desc}</i>`;
    } else if (d(100) <= 12) {
      const left = UNIQUE_DROPS.filter(u => !(flags.uniquesFound || []).includes(u.id));
      if (left.length) { const u = left[rand(left.length)]; grantUnique(u); rare = ` And beneath the coin, something better: <b>${u.name}</b> — <i>${u.desc}</i>.`; }
    }
    sfx("coin");
    scene(c.art, c.title + " — Opened", [ `${c.winScene}. Inside: <b>${g} gold</b>${(c.items || []).length ? " and <b>" + c.items.join("</b>, <b>") + "</b>" : ""}.${rare}` ],
      [ { txt: "🛤 Press on to where you were headed", onclick: "wlContinue()" } ]);
  } else if (c.trap) {
    const dmg = Math.round(roll(c.trap[0], c.trap[1]).total * (1 + 0.35 * (lootTier() - 1)));
    C.hp = Math.max(1, C.hp - dmg);
    sfx("thud");
    logRoll("🪤 Trap!", `${c.trap[0]}d${c.trap[1]} = ${dmg} damage`, "fail");
    scene(c.art, c.title + " — Sprung", [ `${c.loseScene}. <b>(−${dmg} HP)</b> Whatever waits inside keeps waiting — forcing it now would cost more than it holds.` ],
      [ { txt: "🛤 Press on, poorer in blood", onclick: "wlContinue()" } ]);
  } else {
    scene(c.art, c.title + " — Empty-Handed", [ `${c.loseScene}. The road, at least, is still where you left it.` ],
      [ { txt: "🛤 Press on to where you were headed", onclick: "wlContinue()" } ]);
  }
}
function wlMimicScene(monId) {
  const elder = monId === "mimicElder";
  scene("🧰", elder ? "A Chest, Alone, Again" : "A Chest, Alone",
    [ elder
      ? `In the middle of an emptied guard post sits a magnificent iron-strapped chest nobody bothered to loot. After the last one, you know exactly what that means — but this one is bigger, and whatever it has swallowed to grow this size is presumably still in there.`
      : `A handsome traveling chest sits at the roadside, upright and unguarded, as if it fell from a wagon and landed politely. The brass is bright. The lock is, on closer look, faintly <i>wet</i>.`,
      `<i>There is no version of this that isn't worth checking. That's how it gets you.</i>` ],
    [ { txt: "🗝 Open it", req: `<span class="win">✓ whatever's inside</span> · <span class="lose">✗ whatever's inside objects</span>`,
        onclick: `startCombat(['${monId}'], 'waylay_loot', { fleeScene: 'waylay_fled', intro: ${JSON.stringify("The lid comes up on its own — on a ridge of teeth. The chest unfolds into hunger, and the lock you touched licks its lips.")} })` },
      { txt: "🛤 Too tidy. Leave it — press on", onclick: "wlContinue()" } ]);
}

