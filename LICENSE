function m3_comply() {
  flags.grayLoyal = true; flags.thorneTrust += 2; flags.citizenRep -= 2;
  const res = sceneCheck("Insight", 13);
  scene("📜", "The Collection Teams",
    [ `You lead the collection teams for a week, and you keep it gentle — gentler, certainly, than the Blackpikes would. But gentle doesn't change what it is. A fletcher surrenders his grandfather's boar-spear with shaking hands. A widow gives up the crossbow that guards her shop, and her look follows you down the street. The curfew bell rings each dusk like a lid closing.`,
      `Thorne is effusive: "You have no idea what bloodshed you've prevented." The pay is generous. <b>(+80 gold)</b>`,
      res.success
        ? `But on the last day, checking the manifest, you notice: the confiscated arms aren't going to the city armories at all. The crates are stenciled for the <b>Blackpike depot</b> — Thorne's private barracks. When you ask, the clerk's smile doesn't reach his eyes: "Consolidated storage. Councilor's orders."`
        : `The wagons roll off to the armories — or wherever wagons go. You're paid too well to follow them.` ],
    [ { txt: "🏙 Finish the writ and return", onclick: `C.gold += 80; ${res.success ? "flags.sawDepot = true;" : ""} grantXp(150,'Mission: Gray Orders'); flags.chapter = 4; goScene('town')` } ]);
}
function m3_refuse() {
  flags.grayDefied = true; flags.thorneTrust -= 2; flags.citizenRep += 2;
  scene("✋", "Conscience, Publicly",
    [ `You refuse — in the open hall, where clerks and merchants can hear. Disarming frightened people behind city walls isn't defense; it's something else wearing defense's coat.`,
      `Thorne doesn't flare. That's the unsettling thing. He deflates, nods slowly, and takes your hand in both of his. "Then I've asked too much, and I'm sorry. Conscience like yours is why I wanted you. Never lose it — whatever this city comes to." He seems to mean every word.`,
      `The Act proceeds without you — Blackpikes on the collection wagons, and it does NOT stay gentle. But in the poor quarters, word spreads that the hero of Craghollow told the council <i>no</i>. Strangers touch their brows to you in the street.`,
      `Three nights later, walking home from the Griffin, you hear boots in the alley behind you. Several pairs. "Nothing personal, hero," says a voice. "Somebody paid for a lesson."` ],
    [ { txt: "⚔ They picked the wrong lesson", onclick: "startCombat(['thug','thug'], 'm3_afterThugs', { intro: 'Two hired blades step from the shadows, cudgels first, knives held back and low. Professionals.' })" } ]);
}
function m3_subvert() {
  const res = sceneCheck("Deception", 13);
  if (res.success) {
    flags.graySubverted = true; flags.thorneTrust += 1; flags.citizenRep += 2;
    scene("🎭", "The Long Game",
      [ `You take the writ with a hero's solemn face — and then you run the collection your own way. Rusted stock and broken hafts go into the wagons, carefully catalogued. The real steel goes under floorboards and into hay-lofts, house by house, with a whispered "you didn't get this back from me."`,
        `The manifests balance. Thorne, reading them, pats your shoulder: "Gentle AND efficient. I chose well." <b>(+60 gold, and the poor quarter knows exactly what you did for them.)</b>`,
        `You keep one observation for yourself: the collection crates were stenciled for the <b>Blackpike depot</b>, not the city armories. Thorne's private barracks are swallowing the city's weapons.` ],
      [ { txt: "🏙 Bank the trust — his and theirs", onclick: "C.gold += 60; flags.sawDepot = true; grantXp(180,'Mission: Gray Orders, subverted'); flags.chapter = 4; goScene('town')" } ]);
  } else {
    flags.grayDefied = true; flags.thorneTrust -= 2; flags.citizenRep += 1;
    scene("💢", "Caught in the Act",
      [ `A Blackpike sergeant finds the third false-bottomed wagon, and the game is up. Thorne handles it in private, which is somehow worse: no anger, just a long, wounded silence. "You could have simply told me no," he says finally, and dismisses you with a tired wave.`,
        `The poor quarter still got half its steel back. And three nights later, boots follow you from the Griffin — "Nothing personal, hero. Somebody paid for a lesson."` ],
      [ { txt: "⚔ They picked the wrong lesson", onclick: "startCombat(['thug','thug'], 'm3_afterThugs', { intro: 'Two hired blades step from the shadows, cudgels first. Professionals.' })" } ]);
  }
}
