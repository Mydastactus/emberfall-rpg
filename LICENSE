    const xp = patrolXp(70);
    scene("🕯", "The Wayside Shrine", [ res.success
      ? `A Dawnmother shrine stands neglected at the crossroads. You clear the leaves, right the candle, and say the old words properly. Warmth settles into your bones like a debt being repaid. <b>(Fully healed. +${xp} XP)</b>`
      : `You tidy the crossroads shrine as best you remember how. The Dawnmother, presumably, grades on effort. <b>(Healed a little. +${patrolXp(35)} XP)</b>` ],
      [ res.success
        ? { txt: "🏙 Back to the city", onclick: `C.hp = C.maxHp; grantXp(${xp},'the old words'); goScene('town')` }
        : { txt: "🏙 Back to the city", onclick: `heal(d(6)+2,'wayside blessing'); grantXp(${patrolXp(35)},'the old words, roughly'); goScene('town')` } ]);
  }
];
