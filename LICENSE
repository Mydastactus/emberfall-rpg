/* ============================================================
   ROADS OF CHANCE — mission waylays, chests & caches, loot drops
   ============================================================ */
function lootTier() { const ch = flags.chapter || 1; return ch <= 2 ? 1 : ch <= 4 ? 2 : ch <= 6 ? 3 : ch <= 10 ? 4 : 5; }

/* --- rare unique drops: found once per save, never sold in shops --- */
const UNIQUE_DROPS = [
  { id: "whetstone", name: "⚔ Whetstone of Old Wars", desc: "+1 damage on every hit, permanently", apply: () => { C.dmgBonus++; } },
  { id: "boots",     name: "🥾 Wayfarer's Boots", desc: "+2 initiative, permanently", apply: () => { C.initBonus = (C.initBonus || 0) + 2; } },
  { id: "locket",    name: "💗 Ironheart Locket", desc: "+6 maximum HP, permanently", apply: () => { C.maxHp += 6; C.hp += 6; } },
  { id: "band",      name: "💍 Duelist's Band", desc: "+1 to attack rolls, permanently", apply: () => { C.atkBonus++; } }
];
function grantUnique(u) {
  flags.uniquesFound = flags.uniquesFound || [];
  flags.uniquesFound.push(u.id);
  u.apply();
  C.items.push(u.name);
  sfx("level");
  logRoll("🌟 RARE FIND", `${u.name} — ${u.desc}!`, "crit");
}

/* --- random spoils after any combat victory --- */
function rollLootDrop() {
  if (!combat || combat.fled) return;
  if (d(100) > 55) return; // pockets come up empty
  const t = lootTier();
  const lines = [];
  const g = 2 + d(6) * t;
  C.gold += g;
  lines.push(`<b>${g} gold</b>`);
  const c = d(100);
  if (c <= 30) {
    const table = t <= 2 ? ["Healing potion", "Field Bandages", "Alchemist's Fire", "Smith's Kit"]
      : t <= 4 ? ["Healing potion", "Greater healing potion", "Alchemist's Fire", "Field Bandages", "Scroll of Fireball", "Smith's Kit"]
      : ["Greater healing potion", "Superior healing potion", "Alchemist's Fire", "Scroll of Fireball", "Smith's Kit"];
    const item = table[rand(table.length)];
    C.items.push(item);
    lines.push(`<b>${item}</b>`);
  } else if (c <= 34) {
    const left = UNIQUE_DROPS.filter(u => !(flags.uniquesFound || []).includes(u.id));
    if (left.length) {
      const u = left[rand(left.length)];
      grantUnique(u);
      clog(`🌟 <b>RARE FIND!</b> Among the spoils: <b>${u.name}</b> — ${u.desc}.`, "sys");
    } else { C.items.push("Superior healing potion"); lines.push("<b>Superior healing potion</b>"); }
  }
  sfx("coin");
  clog(`💰 <b>Spoils of the fight:</b> ${lines.join(", ")}.`, "sys");
  logRoll("💰 Spoils", lines.join(", ").replace(/<[^>]+>/g, ""), "success");
}

/* --- waylays: once per chapter, ~1 ride in 3 doesn't go to plan --- */
function missionWaylay(dest) {
  flags.wlDone = flags.wlDone || {};
  if (flags.noWaylay || flags.wlDone[flags.chapter] || d(3) !== 1) return false;
  flags.wlDone[flags.chapter] = true;
  flags.waylayDest = dest;
  const tier = WAYLAYS[lootTier() - 1];
  tier[rand(tier.length)]();
  setAmbientForScene("waylay");
  return true;
}
function wlContinue() { goScene(flags.waylayDest || "town"); }

function wlFight(art, title, text, foes, intro) {
  scene(art, title, [text, `<i>The road you need runs straight through them.</i>`],
    [ { txt: "⚔ Engage!", onclick: `startCombat(${JSON.stringify(foes)}, 'waylay_loot', { fleeScene: 'waylay_fled', intro: ${JSON.stringify(intro)} })` } ]);
}
function waylayLootScene() {
  const g = 8 + d(8) * lootTier();
  C.gold += g;
  scene("🛤", "The Road, Reclaimed",
    [ `The trouble is settled and the road is yours again. Going through the fallen's pockets turns up <b>${g} gold</b> — hazard pay, collected at the source.` ],
    [ { txt: "🛤 Press on to where you were headed", onclick: "wlContinue()" } ]);
}
function waylayFledScene() {
  scene("🏃", "The Long Way Around",
    [ `You break off and loop wide through the brush, trading an hour of daylight for an unbled hide. The road rejoins itself eventually. So do you.` ],
    [ { txt: "🛤 Press on to where you were headed", onclick: "wlContinue()" } ]);
}

