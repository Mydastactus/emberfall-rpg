/* ---------- CHAPTER 9 — CITY OF LIES ---------- */
function c9_ops() {
  flags.m = {}; flags.checkpoint = "c9_ops";
  flags.opsDone = flags.opsDone || [];
  const done = flags.opsDone;
  if (done.length >= 2) return goScene("c9_crackdown");
  scene("🗺", "The War Table",
    [ `Sera lays out three operations, chalk-marked on the tannery wall. "We have safe-cover for <b>two</b>. After the second, Vail's counter-intelligence will have our pattern, and whatever's left undone stays undone. Choose like it matters — it does."`,
      done.length ? `<i>One op complete. The Blackpikes are stirring — one more, then we go to ground.</i>` : `` ].filter(Boolean),
    [ !done.includes("A") ? { txt: "⛓ OP: GALLOWS — Ser Bram of the vanguard was caught returning to his family. He hangs at dawn as a 'deserter.'", req: "(rescue the knight — truth +20, and a blade for the endgame)", onclick: "goScene('c9_opA')" } : null,
      !done.includes("B") ? { txt: "📰 OP: BROADSHEET — the criers read Thorne's script. Master-printer Aldous used to print the King's proclamations... and keeps his old typeset", req: "(turn the propaganda machine — truth +15)", onclick: "goScene('c9_opB')" } : null,
      !done.includes("C") ? { txt: "📦 OP: MANIFEST — the 'stolen' treasury gold was seen loaded at the Blackpike depot the night of the 'theft'", req: "(follow the money — a proof, truth +10)", onclick: "goScene('c9_opC')" } : null
    ].filter(Boolean));
