<script>
"use strict";
const SUPPORT_URL = ""; // set to your Ko-fi/BuyMeACoffee link to show the in-game support button

/* ---- autosave (feature-detected; save codes remain the manual backup) ---- */
const Store = (() => {
  try {
    const t = "__ef_test__";
    window.localStorage.setItem(t, "1");
    window.localStorage.removeItem(t);
    return {
      ok: true,
      get: k => { try { return window.localStorage.getItem(k); } catch (e) { return null; } },
      set: (k, v) => { try { window.localStorage.setItem(k, v); } catch (e) {} },
      del: k => { try { window.localStorage.removeItem(k); } catch (e) {} }
    };
  } catch (e) {
    return { ok: false, get: () => null, set: () => {}, del: () => {} };
  }
})();
const AUTOSAVE_KEY = "emberfall_autosave";
function autosave() {
  if (!Store.ok || !C || (combat && !combat.over)) return;
  try {
    Store.set(AUTOSAVE_KEY, makeSaveCode());
    Store.set(AUTOSAVE_KEY + "_meta", JSON.stringify({ name: C.name, level: C.level, chapter: flags.chapter, cls: C.cls.name }));
  } catch (e) {}
}
function autosaveMeta() {
  if (!Store.ok) return null;
  try { const m = Store.get(AUTOSAVE_KEY + "_meta"); return m ? JSON.parse(m) : null; } catch (e) { return null; }
}
/* ============================================================
   AUDIO — synthesized SFX & adaptive ambience (no files, no loading)
   ============================================================ */
const AMBIENT_B64 = "";
const AudioSys = {
  ctx: null, master: null, musicBus: null, sfxOn: true, musicOn: true,
  mode: null, drones: [], schedTimer: null, nextNote: 0, nextKick: 0, nextBass: 0, bassStep: 0,

  supported() { return typeof window !== "undefined" && (window.AudioContext || window.webkitAudioContext); },

  init() {
    if (this.ctx || !this.supported()) return;
    try {
      const AC = window.AudioContext || window.webkitAudioContext;
      this.ctx = new AC();
      this.master = this.ctx.createGain(); this.master.gain.value = 0.72;
      this.master.connect(this.ctx.destination);
      this.musicBus = this.ctx.createGain(); this.musicBus.gain.value = 1;
      this.musicBus.connect(this.master);
      this.loadTrack();
      this.setAmbient(this.pendingMode || "town");
    } catch (e) { this.ctx = null; }
  },
  resume() { if (this.ctx && this.ctx.state === "suspended") this.ctx.resume(); },

  /* ---- licensed ambient track (embedded, with synth fallback) ---- */
  loadTrack() {
    if (this.musicBuf !== undefined) return;
    this.musicBuf = null;
    try {
      const bin = atob(AMBIENT_B64);
      const arr = new Uint8Array(bin.length);
      for (let i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);
      this.ctx.decodeAudioData(arr.buffer, buf => {
        this.musicBuf = buf;
        if (this.musicOn) this.startTrack();
        const m = this.mode; this.mode = null; this.setAmbient(m || "town");
      }, () => { this.musicBuf = null; });
    } catch (e) { this.musicBuf = null; }
  },
  startTrack() {
    if (!this.musicBuf || this.trackSrc || !this.ctx) return;
    if (!this.trackGain) { this.trackGain = this.ctx.createGain(); this.trackGain.gain.value = 0.0001; this.trackGain.connect(this.musicBus); }
    const s = this.ctx.createBufferSource();
    s.buffer = this.musicBuf; s.loop = true;
    s.connect(this.trackGain);
    s.start();
    this.trackSrc = s;
  },
  stopTrack() { if (this.trackSrc) { try { this.trackSrc.stop(); } catch (e) {} this.trackSrc = null; } },

  /* ---- tiny synth helpers ---- */
  tone(freq, dur, { type = "sine", gain = 0.1, glide = null, delay = 0, bus = null } = {}) {
    if (!this.ctx) return;
    const t = this.ctx.currentTime + delay;
    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
    o.type = type; o.frequency.setValueAtTime(freq, t);
    if (glide) o.frequency.exponentialRampToValueAtTime(Math.max(20, glide), t + dur);
    g.gain.setValueAtTime(0.0001, t);
    g.gain.exponentialRampToValueAtTime(gain, t + 0.015);
    g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
    o.connect(g); g.connect(bus || this.master);
    o.start(t); o.stop(t + dur + 0.05);
  },
  noise(dur, { freq = 1200, q = 1, gain = 0.15, delay = 0, ftype = "bandpass", sweepTo = null } = {}) {
    if (!this.ctx) return;
    const t = this.ctx.currentTime + delay;
    const len = Math.max(1, Math.floor(this.ctx.sampleRate * dur));
    const buf = this.ctx.createBuffer(1, len, this.ctx.sampleRate);
    const d = buf.getChannelData(0);
    for (let i = 0; i < len; i++) d[i] = Math.random() * 2 - 1;
    const src = this.ctx.createBufferSource(); src.buffer = buf;
    const f = this.ctx.createBiquadFilter(); f.type = ftype; f.frequency.setValueAtTime(freq, t); f.Q.value = q;
    if (sweepTo) f.frequency.exponentialRampToValueAtTime(Math.max(40, sweepTo), t + dur);
    const g = this.ctx.createGain();
    g.gain.setValueAtTime(0.0001, t);
    g.gain.exponentialRampToValueAtTime(gain, t + 0.01);
    g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
    src.connect(f); f.connect(g); g.connect(this.master);
    src.start(t); src.stop(t + dur + 0.05);
  },

  /* ---- sound effects ---- */
  play(name) {
    if (!this.ctx || !this.sfxOn) return;
    const S = this;
    ({
      dice() { // a proper clatter: woody bounces settling to rest
        const bounces = [0, 0.06, 0.13, 0.21, 0.30, 0.41, 0.54];
        bounces.forEach((d, i) => {
          const f = 950 - i * 70 + Math.random() * 120;
          S.tone(f, 0.045, { type: "triangle", gain: 0.22 - i * 0.02, glide: f * 0.6, delay: d });
          S.noise(0.03, { freq: 2600, q: 3, gain: 0.12 - i * 0.012, delay: d });
        });
        S.tone(420, 0.09, { type: "triangle", gain: 0.12, glide: 300, delay: 0.62 }); // final settle
      },
      hit() { S.noise(0.09, { freq: 1800, gain: 0.2 }); S.tone(190, 0.15, { type: "triangle", gain: 0.18, glide: 120 }); },
      crit() { S.noise(0.13, { freq: 2200, gain: 0.24 }); S.tone(300, 0.3, { type: "sawtooth", gain: 0.14, glide: 950 }); S.tone(150, 0.22, { type: "triangle", gain: 0.18, glide: 78 }); },
      miss() { S.noise(0.24, { freq: 1500, q: 2, gain: 0.12, sweepTo: 280 }); },
      thud() { S.tone(95, 0.2, { type: "sine", gain: 0.26, glide: 52 }); S.noise(0.07, { freq: 600, gain: 0.13 }); },
      heal() { [523, 659, 784].forEach((f, i) => S.tone(f, 0.26, { gain: 0.11, delay: i * 0.09 })); },
      level() { [523, 659, 784, 1047].forEach((f, i) => S.tone(f, 0.4, { type: "triangle", gain: 0.15, delay: i * 0.13 })); [523, 659, 784, 1047].forEach((f, i) => S.tone(f * 1.5, 0.3, { gain: 0.06, delay: 0.55 + i * 0.06 })); S.noise(0.6, { freq: 4500, q: 0.7, gain: 0.05, delay: 0.4 }); },
      coin() { S.tone(1250, 0.08, { type: "square", gain: 0.09, delay: 0 }); S.tone(1870, 0.11, { type: "square", gain: 0.08, delay: 0.07 }); S.tone(2340, 0.09, { type: "sine", gain: 0.05, delay: 0.13 }); },
      spell() { S.tone(440, 0.42, { type: "sine", gain: 0.11, glide: 1400 }); S.tone(447, 0.42, { type: "sine", gain: 0.09, glide: 1420, delay: 0.02 }); S.noise(0.3, { freq: 5200, q: 1.4, gain: 0.05, delay: 0.15 }); },
      fire() { S.noise(0.55, { freq: 950, q: 0.6, gain: 0.22, sweepTo: 190, ftype: "lowpass" }); S.tone(70, 0.5, { type: "sawtooth", gain: 0.12, glide: 44 }); },
      clang() { S.tone(820, 0.28, { type: "square", gain: 0.14, glide: 770 }); S.tone(1130, 0.2, { type: "square", gain: 0.1, delay: 0.01 }); S.noise(0.06, { freq: 3200, gain: 0.14 }); },
      growl() { S.tone(75, 0.65, { type: "sawtooth", gain: 0.2, glide: 46 }); S.noise(0.55, { freq: 320, q: 0.8, gain: 0.1, ftype: "lowpass", sweepTo: 110 }); },
      flee() { [660, 520, 400].forEach((f, i) => S.tone(f, 0.09, { type: "triangle", gain: 0.09, delay: i * 0.08 })); },
      victory() { [392, 494, 587, 784].forEach((f, i) => S.tone(f, 0.34, { type: "triangle", gain: 0.14, delay: i * 0.11 })); [494, 587, 784, 988].forEach((f, i) => S.tone(f, 0.26, { gain: 0.07, delay: 0.5 + i * 0.08 })); },
      death() { [220, 185, 147].forEach((f, i) => S.tone(f, 0.6, { type: "triangle", gain: 0.14, delay: i * 0.3 })); },
      chime() { S.tone(659, 0.32, { gain: 0.11 }); S.tone(880, 0.5, { gain: 0.11, delay: 0.14 }); },
      sleep() { S.tone(520, 0.75, { type: "sine", gain: 0.09, glide: 230 }); },
      sting() { S.tone(147, 0.42, { type: "sawtooth", gain: 0.12, glide: 108 }); S.tone(156, 0.42, { type: "sawtooth", gain: 0.1, glide: 114, delay: 0.02 }); }
    }[name] || (() => {}))();
  },

  /* ---- adaptive ambience ---- */
  MODES: {
    town: { // jubilant bard-loop: bright major pentatonic, walking bass, little runs
      drone: [110, 164.8], dgain: 0.03,
      scale: [220, 246.9, 277.2, 329.6, 370, 440, 493.9, 554.4], wave: "triangle",
      noteGap: [0.5, 1.1], pgain: 0.075, runChance: 0.35, harmonyChance: 0.3,
      bass: { notes: [110, 164.8, 138.6, 164.8], interval: 0.55, gain: 0.07 }, kick: 0, trackGain: 0.95
    },
    explore: {
      drone: [98, 147], dgain: 0.03,
      scale: [196, 220, 261.6, 293.7, 349.2, 392], wave: "sine",
      noteGap: [1.6, 3.2], pgain: 0.06, runChance: 0.12, harmonyChance: 0.15,
      bass: { notes: [98, 147], interval: 1.4, gain: 0.045 }, kick: 0, trackGain: 0.7
    },
    battle: {
      drone: [73.4, 110], dgain: 0.036,
      scale: [146.8, 174.6, 196, 220, 261.6], wave: "sine",
      noteGap: [1.1, 2.2], pgain: 0.06, runChance: 0.15, harmonyChance: 0,
      bass: null, kick: 0.78, trackGain: 0.32
    },
    boss: {
      drone: [55, 82.4], dgain: 0.044,
      scale: [110, 130.8, 146.8, 164.8, 196], wave: "sine",
      noteGap: [0.9, 1.8], pgain: 0.065, runChance: 0.2, harmonyChance: 0,
      bass: null, kick: 0.62, trackGain: 0.26
    }
  },
  setAmbient(mode) {
    if (!this.ctx) { this.pendingMode = mode; return; }
    if (this.mode === mode) return;
    this.mode = mode;
    this.drones.forEach(d => { try { d.g.gain.linearRampToValueAtTime(0.0001, this.ctx.currentTime + 0.8); d.o.stop(this.ctx.currentTime + 1); } catch (e) {} });
    this.drones = [];
    if (!this.musicOn) return;
    const cfg = this.MODES[mode] || this.MODES.explore;
    if (this.musicBuf) {
      this.startTrack();
      if (this.trackGain) {
        this.trackGain.gain.cancelScheduledValues(this.ctx.currentTime);
        this.trackGain.gain.linearRampToValueAtTime(cfg.trackGain != null ? cfg.trackGain : 0.6, this.ctx.currentTime + 1.4);
      }
    }
    if (this.musicBuf && !cfg.kick) { /* the licensed track carries calm scenes alone */ } else cfg.drone.forEach((f, i) => {
      const o = this.ctx.createOscillator(), g = this.ctx.createGain(), fl = this.ctx.createBiquadFilter();
      o.type = "triangle"; o.frequency.value = f * (i ? 1.002 : 1);
      fl.type = "lowpass"; fl.frequency.value = 440;
      g.gain.setValueAtTime(0.0001, this.ctx.currentTime);
      g.gain.linearRampToValueAtTime(cfg.dgain, this.ctx.currentTime + 1.4);
      o.connect(fl); fl.connect(g); g.connect(this.musicBus);
      o.start();
      this.drones.push({ o, g });
    });
    this.bassStep = 0;
    if (!this.schedTimer) {
      this.nextNote = this.ctx.currentTime + 0.6;
      this.nextKick = this.ctx.currentTime + 0.5;
      this.nextBass = this.ctx.currentTime + 0.4;
      this.schedTimer = setInterval(() => this.schedule(), 200);
    }
  },
  schedule() {
    if (!this.ctx || !this.musicOn || !this.mode) return;
    const cfg = this.MODES[this.mode] || this.MODES.explore;
    const now = this.ctx.currentTime;
    if (this.musicBuf) { this.nextNote = now + 0.5; this.nextBass = now + 0.5; }
    while (this.nextNote < now + 0.5) {
      const idx = rand(cfg.scale.length);
      const oct = Math.random() < 0.2 ? 2 : 1;
      const delay = Math.max(0, this.nextNote - now);
      const pluck = (f, d, g) => {
        this.tone(f, 1.3, { type: cfg.wave, gain: g, delay: d, bus: this.musicBus });
        this.tone(f, 1.3, { type: "sine", gain: g * 0.6, delay: d, bus: this.musicBus });
      };
      pluck(cfg.scale[idx] * oct, delay, cfg.pgain);
      if (Math.random() < (cfg.harmonyChance || 0) && cfg.scale[idx + 2]) pluck(cfg.scale[idx + 2] * oct, delay, cfg.pgain * 0.55);
      if (Math.random() < (cfg.runChance || 0)) { // quick ascending run
        for (let s = 1; s <= 2; s++) {
          const ni = Math.min(cfg.scale.length - 1, idx + s);
          pluck(cfg.scale[ni] * oct, delay + s * 0.16, cfg.pgain * 0.8);
        }
        this.nextNote += 0.36;
      }
      this.nextNote += cfg.noteGap[0] + Math.random() * (cfg.noteGap[1] - cfg.noteGap[0]);
    }
    if (cfg.bass) {
      while (this.nextBass < now + 0.5) {
        const delay = Math.max(0, this.nextBass - now);
        const f = cfg.bass.notes[this.bassStep % cfg.bass.notes.length];
        this.tone(f, 0.5, { type: "triangle", gain: cfg.bass.gain, delay, bus: this.musicBus });
        this.bassStep++;
        this.nextBass += cfg.bass.interval;
      }
    } else this.nextBass = now + 0.5;
    if (cfg.kick) {
      while (this.nextKick < now + 0.5) {
        const delay = Math.max(0, this.nextKick - now);
        this.tone(100, 0.14, { type: "sine", gain: 0.12, glide: 40, delay, bus: this.musicBus });
        this.noise(0.03, { freq: 5000, q: 1.5, gain: 0.03, delay: delay + cfg.kick / 2 });
        this.nextKick += cfg.kick;
      }
    } else this.nextKick = now + 0.5;
  },
  toggleSfx() { this.sfxOn = !this.sfxOn; this.updateCtl(); },
  toggleMusic() {
    this.musicOn = !this.musicOn;
    if (!this.musicOn) {
      this.stopTrack();
      this.drones.forEach(d => { try { d.g.gain.linearRampToValueAtTime(0.0001, this.ctx.currentTime + 0.4); d.o.stop(this.ctx.currentTime + 0.6); } catch (e) {} }); this.drones = [];
    } else { this.startTrack(); const m = this.mode; this.mode = null; this.setAmbient(m || "town"); }
    this.updateCtl();
  },
  updateCtl() {
    const el = document.getElementById("audio-ctl");
    if (el) el.innerHTML = `<button onclick="AudioSys.userInit();AudioSys.toggleSfx()" title="Sound effects">${this.sfxOn ? "🔊" : "🔇"}</button>
      <button onclick="AudioSys.userInit();AudioSys.toggleMusic()" title="Music">${this.musicOn ? "🎵" : "🎵̶"}</button>`;
  },
  userInit() { this.init(); this.resume(); }
};
function sfx(name) { try { AudioSys.play(name); } catch (e) {} }
function setAmbientForScene(id) {
  try {
    const townish = ["town", "council", "forge", "curiosities", "training", "trainSkill", "trainStat", "blackmarket", "surface", "prologue2", "epilogue", "epilogue2"];
    AudioSys.setAmbient(townish.includes(id) ? "town" : "explore");
  } catch (e) {}
}
if (typeof document !== "undefined") {
  const boot = () => { AudioSys.userInit(); };
  document.addEventListener("pointerdown", boot);
  document.addEventListener("keydown", boot);
  setTimeout(() => { try { AudioSys.updateCtl(); } catch (e) {} }, 0);
}

/* ---------------- DICE & RULES CORE ---------------- */
const rand = n => Math.floor(Math.random() * n);
const d = sides => rand(sides) + 1;
const roll = (num, sides) => { let t = 0, rolls = []; for (let i = 0; i < num; i++) { const r = d(sides); rolls.push(r); t += r; } return { total: t, rolls }; };
const mod = score => Math.floor((score - 10) / 2);
const fmtMod = m => (m >= 0 ? "+" + m : "" + m);
const profBonus = () => (C ? (C.level >= 9 ? 4 : C.level >= 5 ? 3 : 2) : 2);

/* ---------------- LEVELING ---------------- */
const XP_LEVELS = [0, 0, 150, 500, 1100, 2000, 3200, 5200, 7700, 10600, 14400]; // index = level
const MAX_LEVEL = 10;
function xpToNext() { return C.level >= MAX_LEVEL ? null : XP_LEVELS[C.level + 1]; }
function grantXp(amount, label) {
  amount = Math.round(amount * ((pfx().xpMult) || 1));
  C.xp += amount;
  if (label) logRoll("⭐ XP", `+${amount} — ${label} (total ${C.xp})`, "success");
  while (C.level < MAX_LEVEL && C.xp >= XP_LEVELS[C.level + 1]) levelUp();
}
function levelUp() {
  C.level++;
  const hpGain = Math.floor(C.cls.hitDie / 2) + 1 + mod(C.scores.CON);
  C.maxHp += Math.max(1, hpGain);
  let statNote = "";
  if (C.level === 3 || C.level === 5 || C.level === 7 || C.level === 9) {
    const prime = C.cls.statPriority[0];
    if (C.scores[prime] < 20) { C.scores[prime] += 1; statNote = ` ${ABILITY_NAMES[prime]} +1!`; }
  }
  C.hp = C.maxHp;
  if (C.armorId) recomputeAC();
  sfx("level");
  diceFloat("⬆️");
  logRoll(`⬆️ LEVEL ${C.level}!`, `+${Math.max(1, hpGain)} max HP (now ${C.maxHp}), fully healed.${statNote}${C.level === 5 ? " Proficiency bonus is now +3!" : C.level === 9 ? " Proficiency bonus is now +4!" : ""}`, "crit");
  C.pendingPerks = C.pendingPerks || [];
  C.pendingPerks.push(C.level);
  if (!combat || combat.over) setTimeout(openPerkChoice, 650);
}

