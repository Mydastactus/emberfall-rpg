    desc: "1d6 at +1 to hit, +1d4 radiant fire on every blow. Self-Mending: it blesses its own fittings — a night's rest restores 3 durability." },
  penitent:   { cls: "cleric", magic: true, rarity: "uncommon", name: "Penitent's Flail", dmg: [1, 10], stat: "STR", hands: 1, atk: 0, dmgB: 0, tag: "melee", price: 100, bleedCrit: true, durPerk: "everbright",
    desc: "1d10 with none of the common flail's clumsiness; crits scourge the target (1d4 bleed, 3 rounds). Everbright: half of all battles cost it nothing." },
  winterwand: { cls: "wizard", magic: true, rarity: "uncommon", name: "Wand of the Winter Court", dmg: [1, 8], stat: "INT", hands: 1, atk: 1, dmgB: 0, tag: "ranged", price: 100, effect: "frost",
    desc: "A courtier's gift: Ray of Frost at +1 to hit through a wand that remembers older winters. Arcane: never wears." },
  emberrod:   { cls: "wizard", magic: true, rarity: "uncommon", name: "Emberglass Rod", dmg: [1, 10], stat: "INT", hands: 1, atk: 0, dmgB: 1, tag: "ranged", price: 100, rider: "fire",
    desc: "Fire Bolt drawn through emberglass: 1d10+1, +1d4 fire on every hit. Arcane: never wears." }
};
Object.keys(WEAPONS).forEach(k => WEAPONS[k].id = k);
const RIDER_FX = { fire: { emoji: "🔥", word: "fire" }, shock: { emoji: "⚡", word: "lightning" }, radiant: { emoji: "🌅", word: "radiant fire" } };
function magicWeaponPool() {
  return Object.keys(WEAPONS).filter(k => {
    const w = WEAPONS[k];
    return w.magic && w.cls === C.cls.id && !C.ownedWeapons.includes(k) && w.rarity === "uncommon"; // future tiers: gate by lootTier()
  });
}
function grantMagicWeapon(id, how) {
  const w = WEAPONS[id];
  C.ownedWeapons.push(id);
  if (gearTracksDur()) { C.weaponMats[id] = "iron"; C.weaponDurs[id] = MATERIALS.iron.dur; }
  sfx("level");
  logRoll("✨ MAGIC WEAPON", `${w.name} — ${how}. Equip it at the forge${w.cls === "wizard" ? " or Zephyrine's annex" : ""}.`, "crit");
  return w;
}
function rollMagicDrop() {
  if (!combat || combat.fled) return;
  if (!combat.foes.some(f => !f.fled && f.xp >= 250)) return; // champions & horrors only
  if (d(100) > 35) return;
  const pool = magicWeaponPool();
  if (!pool.length) return;
  const w = grantMagicWeapon(pool[rand(pool.length)], "claimed from the fallen");
  clog(`✨ <b>MAGIC WEAPON!</b> Among the spoils, wrapped and humming faintly: <b>${w.name}</b>. <i>${w.desc}</i>`, "sys");
}
const DEFAULT_WEAPON = { fighter: "longsword", ranger: "longbow", cleric: "mace", rogue: "rapier", wizard: "firebolt" };

const ARMORS = {
  clothing: { name: "Traveling Clothes", base: 10, dexCap: 9, weight: "none", price: 0, desc: "Dignity, pockets, and whatever DEX you bring." },
  leather:  { name: "Leather Armor", base: 11, dexCap: 3, weight: "light", price: 25, desc: "Light: 11 + DEX (max +3). Quiet as skin." },
  studded:  { name: "Studded Leather", base: 12, dexCap: 2, weight: "light", price: 45, desc: "Light: 12 + DEX (max +2)." },
  scale:    { name: "Scale Mail", base: 14, dexCap: 1, weight: "medium", price: 75, desc: "Medium: 14 + DEX (max +1). Jingles with authority." },
  chain:    { name: "Chain Mail", base: 16, dexCap: 0, weight: "heavy", price: 110, desc: "Heavy: AC 16 flat. Subtlety sold separately." },
  plate:    { name: "Plate Armor", base: 17, dexCap: 0, weight: "heavy", price: 400, bm: true, desc: "Heavy: AC 17 flat. The black market's finest, serial numbers filed off." }
};
const ARMOR_PERMS = {
  fighter: ["clothing", "leather", "studded", "scale", "chain", "plate"],
  ranger:  ["clothing", "leather", "studded", "scale"],
  cleric:  ["clothing", "leather", "studded", "scale"],
  rogue:   ["clothing", "leather", "studded", "scale"],
  wizard:  ["clothing", "leather"]
};
const CAN_SHIELD = { fighter: true, cleric: true };
const DEFAULT_ARMOR = { fighter: "chain", ranger: "studded", cleric: "scale", rogue: "leather", wizard: "clothing" };

const WIZ_SPELLS = {
  burning:   { name: "Burning Hands", desc: "A fan of flame: 3d6 to ALL enemies (4d6 at level 7+). Once per combat.", price: 150, minLevel: 3 },
  sleep:     { name: "Sleep", desc: "One lesser enemy falls asleep for 2 rounds (attacks against it have advantage; damage wakes it). Bosses resist. Once per combat.", price: 250, minLevel: 5 },
  lightning: { name: "Lightning Bolt", desc: "8d6 to a single enemy. Once per combat. The classic argument-ender.", price: 400, minLevel: 8, bm: true }
};

function curWeapon() {
  return WEAPONS[C.weaponId] || WEAPONS[DEFAULT_WEAPON[C.cls.id]];
}
function curArmor() { return ARMORS[C.armorId] || ARMORS[DEFAULT_ARMOR[C.cls.id]]; }
function shieldActive() { return !!(C.shield && CAN_SHIELD[C.cls.id] && curWeapon().hands === 1); }
function recomputeAC() {
  const a = curArmor();
  let ac = a.base + Math.max(0, Math.min(mod(C.scores.DEX), a.dexCap));
  if (C.cls.id === "wizard") {
    const mage = 13 + Math.max(0, Math.min(mod(C.scores.DEX), 3));
    if (mage > ac) { ac = mage; C.mageArmorOn = true; } else C.mageArmorOn = false;
  }
  if (shieldActive()) ac += 2 + (pfx().acShield || 0);
  if (curWeapon().hands === 2) ac += (pfx().acTwoHand || 0);
  ac += (C.armorTier || 0) + (flags.wyrmCharm ? 1 : 0) + (pfx().ac || 0);
  if (armorDulled()) ac -= 1;
  C.ac = ac;
}
function equipWeapon(id) {
  C.weaponId = id;
  ensureGearEntry("w", id);
  logRoll("🗡 Equipped", WEAPONS[id].name, "success");
  recomputeAC(); // hands may enable/disable shield
}
function equipArmor(id) {
  C.armorId = id;
  ensureGearEntry("a", id);
  logRoll("🛡 Equipped", ARMORS[id].name, "success");
  recomputeAC();
}

/* ============================================================
   MATERIALS & DURABILITY — bronze/iron/steel; same damage, different lifespan
   ============================================================ */
const MATERIALS = {
  bronze: { name: "Bronze", dur: 8,  repair: 8,  up: 0 },
  iron:   { name: "Iron",   dur: 16, repair: 15, up: 1 },
  steel:  { name: "Steel",  dur: 30, repair: 25, up: 2 }
};
const MAT_ORDER = ["bronze", "iron", "steel"];
function matUpPrice(mat, base) { return mat === "iron" ? 40 + Math.floor(base / 2) : 120 + base; }
function gearTracksDur() { return !!(C && C.weaponDurs && C.armorDurs); } // old sims / mid-migration guard

function ensureGearEntry(kind, id) {
  if (!gearTracksDur()) return;
  if (kind === "w") { if (!C.weaponMats[id]) { const m = WEAPONS[id] && WEAPONS[id].magic ? "iron" : "bronze"; C.weaponMats[id] = m; C.weaponDurs[id] = MATERIALS[m].dur; } }
  else { if (!C.armorMats[id]) { C.armorMats[id] = "bronze"; C.armorDurs[id] = MATERIALS.bronze.dur; } }
}
function weaponMat() { return (gearTracksDur() && C.weaponMats[C.weaponId]) || "bronze"; }
function armorMat() { return (gearTracksDur() && C.armorMats[C.armorId]) || "bronze"; }
/* exemptions: wizard cantrips don't dull, clothing doesn't wear, Kingsteel/Dragonplate are beyond maintenance */
function weaponWears() { return gearTracksDur() && curWeapon().cls !== "wizard" && C.weaponTier < 3; }
function armorWears() { return gearTracksDur() && C.armorId !== "clothing" && !(C.cls.id === "wizard" && C.mageArmorOn) && C.armorTier < 3; }
function weaponDur() { return weaponWears() ? (C.weaponDurs[C.weaponId] !== undefined ? C.weaponDurs[C.weaponId] : MATERIALS[weaponMat()].dur) : null; }
function armorDur() { return armorWears() ? (C.armorDurs[C.armorId] !== undefined ? C.armorDurs[C.armorId] : MATERIALS[armorMat()].dur) : null; }
function weaponDulled() { return weaponWears() && weaponDur() <= 0; }
function armorDulled() { return armorWears() && armorDur() <= 0; }

/* one notch of wear per battle survived */
function wearGear() {
  if (!gearTracksDur()) return;
  if (weaponWears()) {
    ensureGearEntry("w", C.weaponId);
    const dp = curWeapon().durPerk;
    if (dp === "heatSealed" && combat && (combat.pcCrit || combat.slewFoe)) {
      clog(`✨ The ${curWeapon().name}'s heat-seals re-knit in the blood of the fight — <b>no wear this battle</b>.`, "sys");
    } else if (dp === "everbright" && d(2) === 1) {
      clog(`✨ The ${curWeapon().name} catches a kinder light — <b>no wear this battle</b>.`, "sys");
    } else {
    const before = C.weaponDurs[C.weaponId];
    C.weaponDurs[C.weaponId] = Math.max(0, before - 1);
    if (before === 1) { clog(`⚒ <b>Your ${curWeapon().name.toLowerCase()} has gone DULL</b> — −2 to attacks until Brannock hones it.`, "sys"); logRoll("⚒ Weapon dulled", `${weaponName()} needs the forge (−2 attack until repaired)`, "fail"); }
    else if (before === 3) clog(`⚒ Your ${curWeapon().name.toLowerCase()}'s edge is going — <b>2 battles of bite left</b>.`, "sys");
    }
  }
  if (armorWears()) {
    ensureGearEntry("a", C.armorId);
    const before = C.armorDurs[C.armorId];
    C.armorDurs[C.armorId] = Math.max(0, before - 1);
    if (before === 1) { clog(`🛡 <b>Your ${curArmor().name.toLowerCase()} is BATTERED loose</b> — −1 AC until refitted.`, "sys"); logRoll("🛡 Armor battered", `${curArmor().name} needs the forge (−1 AC until repaired)`, "fail"); recomputeAC(); }
    else if (before === 3) clog(`🛡 Straps and plates are working loose — <b>2 battles left</b> in this armor.`, "sys");
  }
}
function repairAllCost() {
  let cost = 0;
  if (weaponWears() && weaponDur() < MATERIALS[weaponMat()].dur) cost += MATERIALS[weaponMat()].repair;
  if (armorWears() && armorDur() < MATERIALS[armorMat()].dur) cost += MATERIALS[armorMat()].repair;
  return cost;
}
function repairAll() {
  const cost = feyPrice(repairAllCost());
  if (!cost || C.gold < cost) return;
  C.gold -= cost;
  if (weaponWears()) C.weaponDurs[C.weaponId] = MATERIALS[weaponMat()].dur;
  if (armorWears()) C.armorDurs[C.armorId] = MATERIALS[armorMat()].dur;
  recomputeAC();
  sfx("coin");
  logRoll("🔨 Repaired & honed", `Edge and fittings restored to full (−${cost} gold)`, "success");
}
function reforge(kind, mat) {
  const id = kind === "w" ? C.weaponId : C.armorId;
  const base = kind === "w" ? curWeapon().price : curArmor().price;
  const cost = feyPrice(matUpPrice(mat, base));
  if (C.gold < cost) return;
  C.gold -= cost;
  if (kind === "w") { C.weaponMats[id] = mat; C.weaponDurs[id] = MATERIALS[mat].dur; }
  else { C.armorMats[id] = mat; C.armorDurs[id] = MATERIALS[mat].dur; recomputeAC(); }
  sfx("coin");
  logRoll("⬆ Reforged", `${MATERIALS[mat].name} ${kind === "w" ? curWeapon().name : curArmor().name} — same bite, ${MATERIALS[mat].dur} battles of endurance`, "crit");
}
function useSmithKit() {
  if (combat && !combat.over) return;
  const i = C.items.indexOf("Smith's Kit");
  if (i === -1) return;
  C.items.splice(i, 1);
  if (weaponWears()) C.weaponDurs[C.weaponId] = Math.min(MATERIALS[weaponMat()].dur, (weaponDur() || 0) + 5);
  if (armorWears()) C.armorDurs[C.armorId] = Math.min(MATERIALS[armorMat()].dur, (armorDur() || 0) + 5);
  recomputeAC();
  logRoll("🧰 Smith's Kit", "+5 durability to blade and armor — field maintenance, done properly", "success");
  const sc = $("sidebar-col"); if (sc) sc.innerHTML = sidebar();
}
function gearNeedsKit() { return (weaponWears() && weaponDur() < MATERIALS[weaponMat()].dur - 1) || (armorWears() && armorDur() < MATERIALS[armorMat()].dur - 1); }
function restMend() { // self-mending weapons knit while you sleep
  if (!gearTracksDur() || curWeapon().durPerk !== "selfMending" || !weaponWears()) return;
  const max = MATERIALS[weaponMat()].dur, cur = weaponDur();
  if (cur >= max) return;
  C.weaponDurs[C.weaponId] = Math.min(max, cur + 3);
  logRoll("✨ Self-Mending", `The ${curWeapon().name} knits its own edge overnight (+3 durability)`, "success");
}
function durChip() {
  if (!gearTracksDur()) return "";
  const bits = [];
  if (weaponWears()) { const d = weaponDur(), m = MATERIALS[weaponMat()].dur; bits.push(`⚔ ${d <= 0 ? "<b style='color:#e88'>DULL</b>" : d + "/" + m}${d > 0 && d <= 2 ? " ⚠" : ""}`); }
  if (armorWears()) { const d = armorDur(), m = MATERIALS[armorMat()].dur; bits.push(`🛡 ${d <= 0 ? "<b style='color:#e88'>BATTERED</b>" : d + "/" + m}${d > 0 && d <= 2 ? " ⚠" : ""}`); }
  return bits.length ? `<div style="font-size:.75em;color:var(--ink-dim);margin-top:2px">Durability: ${bits.join(" · ")}</div>` : "";
}
const MAT_GATE = { iron: 2, steel: 4 };
function reforgeRow(kind, m, backScene, ignoreGate) {
  const wears = kind === "w" ? weaponWears() : armorWears();
  if (!wears) return "";
  const mat = kind === "w" ? weaponMat() : armorMat();
  if (MATERIALS[m].up <= MATERIALS[mat].up) return "";
  const name = kind === "w" ? curWeapon().name : curArmor().name;
  const base = kind === "w" ? curWeapon().price : curArmor().price;
  const cost = feyPrice(matUpPrice(m, base));
  const icon = m === "iron" ? "⛓" : "🗡";
  if (!ignoreGate && flags.chapter < MAT_GATE[m])
    return `<button disabled>${icon} ${MATERIALS[m].name} ${name} <span class="req">— Brannock's ${m} stock arrives Chapter ${MAT_GATE[m]}</span></button>`;
  return `<button onclick="reforge('${kind}','${m}');goScene('${backScene}')" ${C.gold < cost ? "disabled" : ""}>${icon} Reforge in ${MATERIALS[m].name}: ${name} — <b>${cost}g</b> <span class="req">same damage, <b>${MATERIALS[m].dur}</b> battles of endurance (now ${MATERIALS[mat].name}: ${MATERIALS[mat].dur})${C.gold < cost ? " (not enough gold)" : ""}</span></button>`;
}
function forgeMatRows(backScene, ignoreGate) {
  if (!gearTracksDur() || (!weaponWears() && !armorWears())) return "";
  const rows = [`<div class="card-tag" style="padding:4px 2px">— Materials &amp; maintenance: same damage, tougher metal lasts longer —</div>`];
  const rc = feyPrice(repairAllCost());
  if (rc > 0) rows.push(`<button onclick="repairAll();goScene('${backScene}')" ${C.gold < rc ? "disabled" : ""}>🔨 Repair &amp; hone your gear — <b>${rc}g</b> <span class="req">restores edge and fittings to full${C.gold < rc ? " (not enough gold)" : ""}</span></button>`);
  ["iron", "steel"].forEach(m => { rows.push(reforgeRow("w", m, backScene, ignoreGate)); rows.push(reforgeRow("a", m, backScene, ignoreGate)); });
  rows.push(shopRow("🧰 Smith's Kit", "+5 durability to blade & armor — field maintenance for the road", feyPrice(15), false, `buy(${feyPrice(15)},()=>{C.items.push(&quot;Smith's Kit&quot;);logRoll('⚒ Purchased',&quot;Smith's Kit&quot;,'success')});goScene('${backScene}')`));
  return rows.filter(Boolean).join("");
}

function armorDisplayName() {
  const a = curArmor();
  let n = (C.cls.id === "wizard" && C.mageArmorOn) ? "Mage Armor (arcane ward)" : a.name;
  if (armorWears() && !(C.cls.id === "wizard" && C.mageArmorOn)) n = MATERIALS[armorMat()].name + " " + n;
  if (shieldActive()) n += " + shield";
  if (C.armorTier) n += ` +${C.armorTier}`;
  if (armorDulled()) n += " (battered)";
  return n;
}

