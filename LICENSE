/* ============================================================
   RANDOM ENCOUNTERS — patrols, road trouble & red herrings
   ============================================================ */
function patrolFatigue() {
  if (flags.lastPatrolChapter !== flags.chapter) { flags.lastPatrolChapter = flags.chapter; flags.patrolC = 0; }
  return flags.patrolC || 0;
}
function patrolXp(base) {
  const n = patrolFatigue();
  return n >= 3 ? Math.floor(base / 2) : base;
}

function patrolRoll() {
  flags.m = {};
  const n = patrolFatigue();
  flags.patrolC = (flags.patrolC || 0) + 1;
  if (C.gold >= 5) { C.gold -= 5; logRoll("🐎 Patrol", "Supplies and stabling: −5 gold." + (n >= 3 ? " The roads grow quiet — pickings are thinner (half XP)." : ""), "success"); }
  const ch = flags.chapter;
  // red herrings fire on the first patrol of their window, once
  if (ch >= 2 && ch <= 4 && !flags.herring1Done) return herringSmugglers();
  if (ch >= 9 && ch <= 10 && !flags.herringWidowDone) return herringWidow();
  const table = ch <= 2 ? T1_ENCOUNTERS : ch <= 4 ? T2_ENCOUNTERS : ch <= 6 ? T3_ENCOUNTERS : ch <= 10 ? T4_ENCOUNTERS : T5_ENCOUNTERS;
  table[rand(table.length)]();
}

function patrolFightIntro(title, text, foes, intro) {
  scene("🐎", title, [text],
    [ { txt: "⚔ Engage!", onclick: `startCombat(${JSON.stringify(foes)}, 'patrol_after', { fleeScene: 'town', intro: ${JSON.stringify(intro)} })` } ]);
}
function patrol_after() {
  const g = 10 + d(20);
  C.gold += g;
  scene("🐎", "The Road, Quieter",
    [ `The trouble is dealt with, and the road breathes easier for it. You recover <b>${g} gold</b> from the fallen — and the valley owes you one more small, uncounted debt.` ],
    [ { txt: "🏙 Back to the city", onclick: "goScene('town')" } ]);
}

