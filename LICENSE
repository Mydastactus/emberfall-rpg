      { txt: "⚔ Take the fort", onclick: "startCombat(['vex','hobgoblin'], 'm4_tent', { intro: 'Vex signals; a soldier moves to flank. This one has actual discipline.' })" } ].filter(Boolean));
}
function m4_tent() {
  const canMatch = flags.coinKept && !flags.evidence.includes("coin");
  const inv = flags.m.tentInv || (flags.m.tentInv = sceneCheck("Investigation", 12).success ? "true" : "false");
  if (inv === "false") return m4_tent_herring(canMatch);
  scene("⛺", "The Commander's Tent",
    [ `Vex's tent is a quartermaster's office in miniature — and the paperwork is <i>damning</i>. Topmost: a copy of <b>your route</b>, the one from the Royal Writ, in a clean clerk's hand — under a wax seal bearing the <b>Ironvale council's own sigil</b>. <b>(EVIDENCE: the route note.)</b>`,
      `A strongbox holds <b>80 gold</b>, much of it fresh-minted sunburst coin, beside a field-surgeon's kit of clean <b>bandages</b> and a vial of <b>alchemist's fire</b>.`,
      canMatch
        ? `You lay Thorne's "lucky" coin beside them. <b>Same mint, same stamp, same hand.</b> The gift he pressed on you with wet eyes came from the same purse that pays the creatures burning this valley. <b>(EVIDENCE: the coin match.)</b>`
        : flags.evidence.includes("coin")
        ? `More of the sunburst mint — the same coin you've already matched to Thorne's gift. The purse never changes.`
        : `More of that mirror-bright sunburst mint. It nags at you — but without a comparison coin, a stamp proves nothing on its own.` ],
    [ { txt: "🏰 Ride hard for Ironvale", onclick: `addEvidence('routeNote'); ${canMatch ? "addEvidence('coin');" : ""} C.gold += 80; C.items.push('Field Bandages',"Alchemist's Fire"); grantXp(250,'Mission: Redwatch retaken'); goScene('m4_return')` } ]);
}
function m4_tent_herring(canMatch) {
  scene("⛺", "The Commander's Tent",
    [ `Vex's tent is a quartermaster's office in miniature, and in the paper blizzard you seize the topmost damning thing: a <b>requisition slip</b> for "route escort provisions," counter-signed by the <b>Marshal's own quartermaster</b>. There's your leak — a greedy supply officer selling routes to the horde.`,
      `It's a clean answer. It fits in one sentence. <i>Somewhere beneath it, in the pile you didn't finish searching, other papers stay unread.</i>`,
      `A strongbox holds <b>80 gold</b>, a surgeon's kit of <b>bandages</b> and a vial of <b>alchemist's fire</b>.` ],
    [ { txt: "⚖ Ride back and denounce the quartermaster to the war council", req: "(act on the lead as it stands)", onclick: `addEvidence('reqSlip'); C.gold += 80; C.items.push('Field Bandages',"Alchemist's Fire"); grantXp(200,'Redwatch retaken — a lead in hand'); goScene('m4_qm_accuse')` },
      { txt: "🔍 Something's too tidy. Tear the tent apart properly before you ride.", req: "(Insight, DC 12 — question the convenient answer)", onclick: `C.gold += 80; C.items.push('Field Bandages',"Alchemist's Fire"); m4_qm_verify(${canMatch})` } ]);
}
function m4_qm_verify(canMatch) {
  const res = sceneCheck("Insight", 12);
  if (res.success) {
    scene("⛺", "The Second Look",
      [ `You sit with the slip a moment — and it curdles. A quartermaster selling routes doesn't leave his own counter-signature lying <i>on top of the pile</i>. Placed. Findable. You dig properly this time — and there, folded beneath the false bottom of the map chest, is the real thing: <b>your route, in a clean clerk's hand, under the Ironvale council's own seal.</b> <b>(EVIDENCE: the route note.)</b>`,
        `Someone dressed this tent for visitors. Remember that.` ],
      [ { txt: "🏰 Ride hard for Ironvale — with the true lead", onclick: `addEvidence('routeNote'); ${canMatch ? "addEvidence('coin');" : ""} grantXp(120,'the second look'); goScene('m4_return')` } ]);
  } else {
    scene("⛺", "Nothing More",
      [ `You turn the tent over twice and find only camp-clutter. The slip is what you have, and the slip is what you'll carry. <i>(Evidence taken — unverified.)</i>` ],
      [ { txt: "🏰 Ride hard for Ironvale", onclick: "addEvidence('reqSlip'); grantXp(60,'a thorough, fruitless search'); goScene('m4_return')" } ]);
  }
}
function m4_qm_accuse() {
  flags.embarrassed = true;
  flags.citizenRep = (flags.citizenRep || 0) - 1;
  scene("⚖", "The Wrong Man",
    [ `The war council convenes; the quartermaster — a stammering, decent, terrified man — is arrested at his supper. It takes the Marshal's clerks two days to prove what better paperwork would have shown you in one: the "requisition slip" is written on stock the quartermaster's office has never used, in a hand that isn't his.`,
      `He is released with apologies he'll never quite believe. Thorne, magnificently, defends YOU: "an honest error, from our most valiant friend — we are all stretched thin." The court nods. The gallery remembers the accusation, not the retraction.`,
      `<i>Someone built that slip to be found — and you carried it home for them. The false lead is spent; whoever set it now knows exactly how you can be steered.</i> <b>(Reputation dented. The council will weigh your next accusation more skeptically.)</b>` ],
    [ { txt: "🤐 Learn the lesson that expensive", onclick: "goScene('m4_return')" } ]);
}
function m4_return() {
  const w = evidenceWeight();
  scene("🏰", "What Do You Tell a King?",
    [ `Redwatch is retaken; the east road breathes again. The city cheers — but you ride through the gates with a route note under a council seal burning a hole in your saddlebag.`,
      `The war council numbered three: the King, the marshal... and Thorne. You could lay it before the King tonight.`,
      `<i>Your evidence so far carries weight ${w}. Accusing the King's oldest friend is a door that only opens once.</i>` ],
    [ { txt: "🗣 Go to the King now, with what you have", req: `(evidence weight ${w} — a king's love will demand much)`, onclick: "m4_accuse()" },
      { txt: "🤐 Not yet. Build the case until it cannot be argued with.", onclick: "flags.chapter = 5; goScene('town')" } ]);
}
function m4_accuse() {
  const w = evidenceWeight();
  if (w >= 4 && hasFalseEvidence()) {
    flags.accusedEarly = true;
    scene(pArt("alden"), "The Chain Breaks at Its Weakest Link",
      [ `You lay out the case — and it begins well. The coins. The seals. Alden's face grows graver by the minute... until his examiner reaches the ${flags.evidence.includes("smugglerNote") ? "smugglers' manifest" : "unverified papers"} in your stack, and takes it apart in four sentences.`,
        `"Forged stock. Copied hand. Planted, sire — and swallowed." The examiner does not look up. Neither, now, does the King.`,
        `"You bring me true things and false things in the same satchel," Alden says at last, wearily, "and ask me to behead a friendship on the difference. <b>Come back when you know which is which.</b>" You are escorted out. The good evidence went down with the bad — that is what false leads are FOR.` ],
      [ { txt: "🤐 Purge the false papers and rebuild the case", onclick: "flags.evidence = flags.evidence.filter(e => !EVIDENCE[e].false); logRoll('🧾 Purged','You burn the planted evidence. Only the true case remains.','fail'); flags.chapter = 5; goScene('town')" } ]);
    return;
  }
  if (w >= 4) {
    flags.kingDoubt = true;
    scene(pArt("alden"), "The Seed of Doubt",
      [ `Alden listens in absolute stillness — the coin match, the forge-marks, the sealed route. When you finish, the silence stretches so long you hear the torches burn.`,
        `"Thaddeus held my son at his naming," he says at last, quietly. "He talked me out of two wars and into three hospitals. What you're describing isn't a traitor. It's a lifetime." He looks up, and his eyes are terrible. "And yet I cannot make your coins unmatch, or that seal unstamp itself."`,
        `"Bring me his HAND, adventurer. His ledger, his letters, his cipher — something no rival could have forged to ruin a good man. Bring me that, and I will do what a king must. Until then—" his voice cracks, very slightly, "—I beg you, be wrong."` ],
      [ { txt: "🐺 Then you'll bring him the warlord's own ledger", onclick: "flags.chapter = 5; goScene('town')" } ]);
  } else {
    flags.accusedEarly = true;
    scene(pArt("alden"), "The Lion Defends the Snake",
      [ `You lay out what you have. It sounds thinner in the throne room than it did in your head — a stamp here, a rumor there.`,
        `Alden's face closes like a portcullis. "Thaddeus Thorne? The man who funded our hospitals? Who sat vigil at my queen's deathbed?" He rises from the throne, and the room shrinks. "<b>Do not insult my councilor again, adventurers.</b> The next accusation you bring against him had best carry proof heavy enough to crack stone — or it will be YOUR name this court remembers, and not kindly."`,
        `You are escorted out. Politely. Barely.` ],
      [ { txt: "🤐 Heavy enough to crack stone. So be it.", onclick: "flags.chapter = 5; goScene('town')" } ]);
  }
}

/* ============================================================
   MISSION 5 — THE WARLORD'S LEDGER (Level 5)
   ============================================================ */
function m5_meet() {
  scene(pArt("sera"), "The Treeline",
    [ `Sera is exactly where the whisper promised, cross-legged on a deadfall, cleaning her nails with a skinning knife. ${flags.seraFriend ? `"Took you long enough," she says, but she's grinning. She clasps your forearm like a comrade.` : `She looks you over once. "The Craghollow hero. Good — I don't work with amateurs."`}`,
      `"Gar'Thok's war camp is two valleys east. Four hundred spears and growing — and here's the meat of it: I watched a <b>cloaked rider</b> come up from the city road by night, twice. City boots. Soft hands. Gold going in, orders coming out." She sketches the camp in the dirt: pickets, horse-lines, and a great central tent. "Whatever ties the warlord to his paymaster, it lives in <b>that tent</b>. I can get you to the wire. After that, it's your show."` ],
    [ { txt: "🎭 Walk in disguised as a sellsword come to sign on", req: "(Deception, DC 13" + (C.origin.id === "soldier" ? " — advantage: you can wear a war-camp like a uniform" : "") + `) <span class="win">✓ stroll to the tent unchallenged</span> · <span class="lose">✗ named a spy — fight through an alerted camp</span>`, onclick: `m5_disguise(${C.origin.id === "soldier" ? "true" : "false"})` },
      { txt: "🌙 Go over the wire in the dead watch", req: "(Stealth, DC 13" + (C.origin.id === "urchin" ? " — advantage: you grew up not being seen" : "") + `) <span class="win">✓ ghost to the tent between the watch-fires</span> · <span class="lose">✗ a worg's nose doesn't care how quiet you are</span>`, onclick: `m5_sneak(${C.origin.id === "urchin" ? "true" : "false"})` },
      { txt: "🔥 Have Sera fire the horse-lines — go in loud through the chaos", req: `(no roll — but the tent's guards hold their post: a hard fight, with Sera at your side)`, onclick: "m5_loud()" } ]);
}
function m5_disguise(adv) {
  const res = sceneCheck("Deception", 13, { adv });
  if (res.success) {
    scene("🎭", "One More Sword",
      [ `You walk in through the front gate under a mercenary's slouch, and the camp swallows you whole. Orc quartermasters sign you to a mess line; a bored hobgoblin points you toward the fighting pits "for assessment, later." No one looks at your face twice. Sellswords, it seems, arrive weekly.`,
        `By dusk you've drifted, unhurried, to the shadow of the great tent.` ],
      [ { txt: "⛺ Slip inside", onclick: "goScene('m5_tent')" } ]);
  } else {
    scene("💢", "The Wrong Password",
      [ `A scarred orc sergeant asks who recruited you. You name no one he knows — because there IS no one. His eyes narrow. "Spy," he says, almost happily, and reaches for the axe.` ],
      [ { txt: "⚔ Fight your way to the tent!", onclick: "startCombat(['orcBrute','eliteGuard'], 'm5_tent', { intro: 'The sergeant and a Blackpike-drilled elite close in. You need this finished before the whole camp wakes.' })" } ]);
  }
}
function m5_sneak(adv) {
  const res = sceneCheck("Stealth", 13, { adv });
  if (res.success) {
    scene("🌙", "The Dead Watch",
      [ `${res.grim ? "Halfway over the wire your boot finds a picket-bell line — and freezes a hair short, held by pure scar-taught patience. <i>(Grim Resolve)</i> " : ""}You go over the wire in the hollow hour when even sentries dream. Tent-shadow to tent-shadow, past a snoring worg the size of a cart, to the black bulk of the command tent.` ],
      [ { txt: "⛺ Slip inside", onclick: "goScene('m5_tent')" } ]);
  } else {
    scene("💢", "The Worg Wakes",
      [ `You're ghost-quiet — but a worg's nose doesn't care. It comes up out of sleep with a howl that rips the night open.` ],
      [ { txt: "⚔ Kill it fast, before the camp rallies!", onclick: "startCombat(['worg','gobArcher'], 'm5_tent', { intro: 'The worg lunges; somewhere behind it a sentry fumbles for a horn.' })" } ]);
  }
}
function m5_loud() {
  scene("🔥", "Chaos, To Order",
    [ `An hour past midnight, the eastern horse-lines bloom into flame. Sera's work is art: three fires, staggered, each discovered just as the last is contained. Half the camp stampedes east, cursing in three languages.`,
      `You walk into the emptied heart of the camp — where the command tent's last two guards have NOT left their post. Gar'Thok picks his bodyguards well.` ],
    [ { txt: "⚔ Through them, then", onclick: "startCombat(['eliteGuard','eliteGuard'], 'm5_tent', { ally: { name: 'Sera', atk: 5, dmg: [1, 6, 3] }, intro: 'Sera materializes at your shoulder, knife already wet. \"Fires won\\'t hold them long. Go loud, go fast.\"' })" } ]);
}
function m5_tent() {
  scene("⛺", "The Warlord's Tent",
    [ `Maps. War-plans. A camp-throne of lashed spears. And on the great table, held down by a dagger like a paperweight: a <b>ledger</b>, bound in wolf-hide.`,
      `You crack it and your breath stops. Column after column in a crabbed war-scribe hand: <i>dates, targets, payments</i>. The medicine train — 200 gold. Westmill granary — 350. The Grimhollow farms. The Duskway. Each entry marked paid in sunburst coin, and pinned to the back board, a sheaf of <b>letters in a courtly cipher</b> — the sender too careful to sign, but the ledger's margin note is not careful at all: "<i>the gray man in the city pays double for burnt grain</i>."`,
      `Voices outside — Gar'Thok's own, a growl like siege-stone: "...tell the gray man the price rises again. And tell him I keep his letters safe. Snakes bite the hand that feeds — but not the hand that holds their SECRETS." A laugh like a rockslide. He knows exactly what his paymaster is. He's been keeping insurance.`,
      `<b>(EVIDENCE: Gar'Thok's ledger — proof in his own hand, heavy enough to crack stone.)</b>` ],
    [ { txt: "🌙 Take everything and ghost away", req: `(Stealth, DC 12) <span class="win">✓ gone before the camp knows it's been robbed</span> · <span class="lose">✗ horns in the dark — cut your way to the treeline</span>`, onclick: "m5_escape()" },
      { txt: "🔥 Take everything and burn the tent behind you — let the warlord feel it", onclick: "addEvidence('ledger'); startCombat(['eliteGuard','gobArcher'], 'm5_return', { intro: 'The tent goes up like a torch. The first guards through the smoke find you waiting.' })" } ]);
}
function m5_escape() {
  addEvidence("ledger");
  const res = sceneCheck("Stealth", 12);
  if (res.success) {
    scene("🌙", "Gone Like Smoke",
      [ `You are past the wire before the camp knows it has been robbed. Sera falls in beside you at the treeline, matches your pace, and glances at the wolf-hide bundle under your arm. "That what I think it is?" She whistles, low. "Then run faster."` ],
      [ { txt: "🏰 Ride for Ironvale", onclick: "goScene('m5_return')" } ]);
  } else {
    scene("💢", "The Alarm",
      [ `A sentry horn splits the night — some sharp-eyed picket found your rope. Torches converge. Two shapes cut off the treeline path.` ],
      [ { txt: "⚔ Cut through — the ledger MUST reach the city", onclick: "startCombat(['eliteGuard','worg'], 'm5_return', { intro: 'Between you and safety: one elite and a worg with your scent.' })" } ]);
  }
}
function m5_return() {
  flags.chapter = 6;
  scene("🐎", "The Ride Home",
    [ `You ride through the night with the most dangerous object in the realm strapped to your chest: a warlord's honest bookkeeping.`,
      `Dawn shows you Ironvale — and your blood goes cold. <b>Smoke over the outer districts. Bells. And on the horizon behind you, dust: an army marching.</b> Gar'Thok isn't waiting to discover his ledger is gone. The siege has begun ahead of schedule... or exactly ON schedule.`,
      `<i>Everything Thorne needs is in place. The King humiliated by false hunts. The city starving, disarmed, garrisoned by Blackpikes. All that's left is the crisis — and its savior.</i>`,
      `<b>(+350 XP — the case is complete.)</b>` ],
    [ { txt: "🏰 Ride like the realm depends on it", onclick: "grantXp(350,'Mission: the ledger'); goScene('m6_stage')" } ]);
}

/* ============================================================
   MISSION 6 — THE BREAKING POINT (Level 6, finale)
   ============================================================ */
function m6_stage() {
  flags.inFinale = true; flags.m = flags.m || {};
  flags.checkpoint = "m6_stage";
  scene("🔥", "The City on the Brink",
    [ `Ironvale is chaos. Gar'Thok's horde blackens the eastern fields; the gates are barred; the walls are thin with defenders. And the news runs mad through the streets: <b>Duke Meredith is dead</b> — found in his bath at dawn, wrists opened, a confession of "failures" beside him in handwriting his own valet swears is wrong.`,
      `In the Grand Square, carpenters hammer at a podium. Blackpike companies form up in parade order — hundreds more than anyone knew were in the city. At dusk, criers announce, High Councilor Thorne will address the people "on the salvation of Ironvale."`,
      `The trap is closing exactly as designed. You have hours — and a wolf-hide ledger.` ],
    [ { txt: "👑 To the King — end the lie first, or nothing else matters", onclick: "goScene('m6_king')" } ]);
}
function m6_king() {
  if (flags.kingBelieved) return goScene("m6_gate");
  const w = evidenceWeight();
  if (w >= 5 && hasFalseEvidence()) {
    scene(pArt("alden"), "One Bad Coin Spoils the Purse",
      [ `You find Alden armoring for the walls and lay out everything — and everything is nearly enough. Then his examiner reaches the unverified papers in your satchel and pulls the thread, and you watch a fortress of proof develop one visible crack.`,
        `"The rest may be gold," the King says, quiet and terrible, "but you handed me a counterfeit WITH it, and tonight of all nights I cannot afford one." His hand closes on the ledger anyway — wanting to believe. "Prove you know true from false. Then we finish this."`,
        `<i>(Purge the false evidence — the Chronicler's Quill can't help you here; only the night can.)</i>` ],
      [ { txt: "🔥 Burn the planted papers and keep watch over the King tonight", onclick: "flags.evidence = flags.evidence.filter(e => !EVIDENCE[e].false); logRoll('🧾 Purged','The false leads go into the brazier.','fail'); m6_assassins()" } ]);
    return;
  }
  if (w >= 5) {
    flags.kingBelieved = true;
    scene(pArt("alden"), "The Breaking Point",
      [ `You find Alden armoring for the walls, and you put the wolf-hide ledger in his hands.`,
        `He reads standing. Then sitting. The war-noise outside fades to nothing. You watch a big man get smaller, page by page — the medicine train, the granary, the burnt farms, each with its price in sunburst coin. When he reaches the ciphered letters he stops needing the cipher; kings learn their friends' hands young. ${flags.kingDoubt ? "\"You warned me,\" he says, to no one. \"You warned me and I begged you to be wrong.\"" : ""}`,
        `"Forty years." His voice is gravel and glass. "He carried my father's shield at the Fords. He held my SON at his naming, adventurer." The King of Ironvale closes the ledger with the gentleness of a man closing a coffin lid. When he looks up, the grief has been forged into something with an edge.`,
        `"The snake wants my city panicked and my sword abroad. He will have neither. You gave me the truth — now stand with me while I spend it. <b>The wall first. Then the podium.</b>"` ],
      [ { txt: "⚔ To the wall, beside the King", onclick: "goScene('m6_gate')" } ]);
  } else if (w >= 2 && !flags.accusedEarly) {
    scene(pArt("alden"), "Not Enough — Almost",
      [ `Alden turns your evidence over with hands that want to disbelieve it. "Stamps. Seals. A merchant's grief." He shakes his head slowly. "Against forty years, it's smoke. Show me his HAND, and I'll show you the King's justice — but I will not behead my oldest friendship on smoke." ${flags.accusedEarly ? "\"And you have spent your second chance already,\" he adds, not unkindly." : ""}`,
        `That night, you keep watch near the royal wing anyway — because if you're right, the King's continued breathing is an obstacle to somebody's schedule.`,
        `An hour past midnight, two shadows detach from the servants' stair, moving with rehearsed silence toward the King's chamber. <b>You were right.</b>` ],
      [ { txt: "⚔ Intercept the assassins!", onclick: "m6_assassins()" } ]);
  } else {
    scene(pArt("alden"), "Thrown from the Hall",
      [ `"<b>Do not insult my councilor again.</b>" The King's voice could crack the flagstones. With the city besieged and his Duke dead, your half-formed accusations read as madness — or malice. Guards walk you out.`,
        `So you do the only thing left: you watch. All night, from the shadows by the royal wing — because if you're right, the King is now the last obstacle on somebody's list.`,
        `An hour past midnight, two shadows slip up the servants' stair toward the King's chamber, knives held low. <b>You were right. Being right is about to get loud.</b>` ],
      [ { txt: "⚔ Intercept the assassins!", onclick: "m6_assassins()" } ]);
  }
}
function m6_assassins() {
  startCombat(["assassin", "assassin"], "m6_afterAssassins", {
    ally: flags.kingBelieved ? null : { name: "King Alden", atk: 8, dmg: [1, 10, 5] },
    intro: "Your shout wakes the corridor. The first assassin turns, blade gleaming — behind him, the King's door bursts open and Alden fills the frame, warhammer in hand, nightshirt and fury. \"MY OWN HOUSE?!\""
  });
}
function m6_afterAssassins() {
  flags.kingBelieved = true;
  scene(pArt("alden"), "The Scales Fall",
    [ `The second assassin dies with a Blackpike-issue blade still in his grip, and a purse of <b>sunburst-minted coin</b> spills across the King's carpet. Alden stares at it for a long, long moment. Coins. Boots. Blades. He is a proud man, but he has never been a fool — merely a loyal one.`,
      `"Forty years," he says quietly, and picks up one bright coin. "You tried to tell me. The court will remember it was YOU who tried to tell me." He is already reaching for his armor. "The snake timed his theater for dusk. The wall first, adventurer — my city will not fall while I settle my accounts. <b>Then the podium.</b>"` ],
    [ { txt: "⚔ To the wall, beside the King", onclick: "C.gold += 40; logRoll('💰','+40 gold from the assassins\\' purses','success'); goScene('m6_gate')" } ]);
}
function m6_gate() {
  scene("🏰", "The East Gate",
    [ `The east gate is failing when you reach it — a <b>siege ogre</b> with a ship's-mast ram against splintering oak, hobgoblin shock troops in its shadow. Militiamen scatter from the barbican.`,
      flags.kingBelieved ? `Then the King's banner breaks out overhead and the wall itself seems to straighten. "HOLD, IRONVALE!" Alden roars, taking the stair three at a time beside you. "YOUR KING HOLDS WITH YOU!"` : `Sera finds you in the press, bloody and grinning. "Figured you'd be where it's worst."`,
      `The gate bursts.` ],
    [ { txt: "⚔ Hold the breach!", onclick: "m6_gateFight()" } ]);
}
function m6_gateFight() {
  startCombat(["ogre", "hobgoblin"], "m6_garthok_talk", {
    ally: flags.kingBelieved ? { name: "King Alden", atk: 8, dmg: [1, 10, 5] } : { name: "Sera", atk: 5, dmg: [1, 6, 3] },
    intro: "The ogre comes through the ruined gate first, dragging its ram like a club."
  });
}
function m6_garthok_talk() {
  const hasLedger = flags.evidence.includes("ledger");
  scene(pArt("garthok"), "The Warlord at the Breach",
    [ `The breach holds — barely — and the horde's charge breaks against it. Then the drums change, and the press of bodies parts like water.`,
      `<b>Warlord Gar'Thok</b> walks through the ruined gate alone, because he can. Seven feet of scarred muscle under black iron, a greataxe over one shoulder still wet from the wall's defenders. He looks at the carnage, at you, and — unhurried — takes your measure.`,
      `"The ledger-thief." His voice is a landslide with opinions. "You cost me my insurance. So I came to collect it back — with the city attached."` ],
    [ hasLedger ? { backstory: true, txt: "📖 \"Your paymaster sold you too, Gar'Thok. The 'gray man' has your death already scheduled — right after yours stops being useful. Want to hear his name shouted from a podium tonight?\"", req: "(Persuasion, DC 13 — turn the cat's paw against the puppeteer)", onclick: "m6_doubleCross()" } : null,
      { txt: "⚔ \"Come collect it, then.\"", onclick: "m6_garthokFight(false)" } ].filter(Boolean));
}
function m6_doubleCross() {
  const res = sceneCheck("Persuasion", 13);
  if (res.success) {
    flags.garthokTold = true;
    scene(pArt("garthok"), "Honor Among Thieves — Almost",
      [ `Gar'Thok goes very still. "The gray man," he rumbles, "promised the gate guard would be BOUGHT tonight. It was not. Promised the King would be ABROAD. He is not." His eyes, small and shrewd, weigh you like coin. "And now his errand-blade tells me my name is next on his ledger. That, I believe. Snakes are only ever consistent about their nature."`,
        `He raises one fist. Across the field, the drums stop. "I will deal with you, thief — because you fight like something worth killing. But when we are done here, whatever is left of me marches on a PODIUM." He grins, and it is a terrible thing. "Two debts, one night."`,
        `Then the axe comes off his shoulder, and the world narrows.` ],
      [ { txt: "⚔ Finish it — warlord to hero", onclick: "m6_garthokFight(true)" } ]);
  } else {
    scene(pArt("garthok"), "Not For Sale",
      [ `Gar'Thok laughs — an avalanche with a sense of humor. "You think I don't KNOW what he is? Snake pays in good coin. Dead snake pays nothing." The axe comes off his shoulder. "Kill the thief. Sack the city. Collect from the snake at leisure. My bookkeeping is SIMPLE."` ],
      [ { txt: "⚔ Then it ends here", onclick: "m6_garthokFight(false)" } ]);
  }
}
function m6_garthokFight(weakened) {
  const foe = weakened ? "garthokWounded" : "garthok";
  startCombat([foe], "m6_podium", {
    ally: flags.kingBelieved ? { name: "King Alden", atk: 8, dmg: [1, 10, 5] } : { name: "Sera", atk: 5, dmg: [1, 6, 3] },
    intro: weakened
      ? "Gar'Thok fights with half his mind already on the podium — the fury is real, but the caution is gone (he battles wounded by his own rage)."
      : "Gar'Thok fights like the siege made flesh — every swing an argument, every step a claim on the city."
  });
}
function m6_podium() {
  scene("🏆", "The Warlord Falls",
    [ `Gar'Thok drops to one knee, then to both, the greataxe ringing on the flagstones. He looks up at you with something that is almost respect. "Good... bookkeeping," he manages — and the siege of Ironvale dies with him. Leaderless, the horde breaks against the walls it nearly owned, and scatters into the dusk.`,
      `But across the city, torchlight blooms in the Grand Square. The podium. The speech. <b>Thorne's moment</b> — arriving precisely on schedule, before word of the wall can outrun him.`,
      `${flags.kingBelieved ? "Beside you, the King wipes his father's warhammer clean. \"Now,\" Alden says quietly, \"the podium.\"" : "Sera hauls you upright. \"Square. NOW. Before the snake crowns himself.\""}` ],
    [ { txt: "🏛 To the Grand Square", onclick: "grantXp(400,'the siege is broken'); goScene('m6_confront')" } ]);
}
function m6_confront() {
  const w = evidenceWeight();
  const believed = flags.kingBelieved;
  const hasLedger = flags.evidence.includes("ledger");
  scene(pArt("thorne"), "The Podium",
    [ `The Grand Square is a sea of frightened torchlight. And there he is — silver-bearded, grave, grandfatherly — hands raised over HIS city. "...and though it breaks my heart, the crown has FAILED us, and so it falls to US, the people, to—"`,
      `He sees you. Mid-sentence. Sees the King's banner behind you, and the wolf-hide bundle under your arm.`,
      `To his credit — his single, final credit — High Councilor Thaddeus Thorne does not run. He smiles the warm smile from the Gilded Griffin, the one that remembers everyone's name, and he says, gently, to the whole square: "My friends. It seems even our heroes have been touched by the madness of these days."` ],
    believed && hasLedger ? [
      { txt: "📖 Let the King read the ledger aloud — every date, every price, every burnt farm", onclick: "m6_ending('justice')" },
      { txt: "🗣 Speak first yourself — you carried this case; let the people hear it from the one who bled for it", req: "(Persuasion, DC 12 — with the ledger and the King at your back)", onclick: "m6_speak()" }
    ] : believed ? [
      { txt: "👑 Stand aside — the King's word and the assassins' sunburst coin will have to be proof enough", onclick: "m6_ending('flight')" }
    ] : [
      { txt: "⚔ You have no King and no crowd — only the truth and a blade. Take him yourself, past his champion.", onclick: "m6_vailFight()" }
    ]);
}
function m6_speak() {
  const res = sceneCheck("Persuasion", 12);
  m6_ending(res.success ? "justice_hero" : "justice");
}
function m6_vailFight() {
  startCombat(["vail"], "m6_vailAfter", {
    ally: { name: "Sera", atk: 5, dmg: [1, 6, 3] },
    intro: "The crowd screams and parts. Thorne's duelist — Captain Vail of the Blackpikes, all lazy grace and razor steel — steps between you and the podium. \"The Councilor pays me by the corpse,\" she says pleasantly. \"You're worth three.\""
  });
}
function m6_vailAfter() {
  m6_ending(flags.garthokTold ? "wolves" : "flight");
}
function m6_ending(kind) {
  flags.thorneFate = kind;
  flags.chapter = 7;
  goScene("epilogue");
}

/* ============================================================
   EPILOGUE
   ============================================================ */
function epilogueScene() {
  const fate = {
    justice: `In the torch-lit square, King Alden reads the ledger aloud — every date, every burnt farm, every price in sunburst coin — in the flat, terrible voice of a man reading his friend's confession. The crowd's silence is worse than any roar. Thorne listens to all of it with folded hands and, at the end, says only: "I would have been GOOD at it." The Blackpikes, sensing the wind, lay down their arms. The grandfatherly councilor leaves his podium in chains, and Ironvale learns that its kindest face was its hungriest.`,
    justice_hero: `It's you the square hears first — the medicine train, the granary, the coins pressed warmly into trusting hands — the whole shape of the machine, laid out by the one who bled tracing it. When you hold up the sunburst coin, a hundred hands rise holding its twins: wages, gifts, charity, every one of them a link in the chain. By the time the King reads the ledger, the crowd isn't listening in shock but in FURY. Thorne leaves his own podium in chains, under the eyes of the people he built it to fool — and it is your name, not his, that Ironvale chants into the night.`,
    flight: `In the uproar, the grandfatherly smile finally fails — and Thorne is simply GONE, folded into the crowd he knew better than anyone, leaving an empty podium and a city full of questions. The Blackpikes surrender by dawn; the ciphered letters damn him in absentia. Somewhere on a dark road, a gray man with soft hands is learning what it is to be hunted. The King's word stands like a wall — but you'll sleep lighter when the road gives him up. Roads usually do.`,
    wolves: `Thorne vanishes from the podium in the chaos — but Gar'Thok's oathband remembered their warlord's last order, and they know the wilds better than any city man. Nine days later, a merchant patrol finds what's left of High Councilor Thaddeus Thorne at a crossroads shrine, his purse untouched save that every coin has been placed, with great deliberateness, in a circle around him. Sunburst up. The realm calls it banditry. You know better: it was bookkeeping.`
  }[flags.thorneFate || "justice"];

  const realmLines = [];
  realmLines.push(flags.kingBelieved
    ? `<b>King Alden</b> endures — grayer, harder, and wiser about the price of trust. He names you Shield of Ironvale before the assembled court, and means every syllable.`
    : `<b>King Alden</b> endures, though the court still whispers about how close the realm came, and about the adventurer who saw it first.`);
  if (flags.citizenRep >= 2) realmLines.push(`In the poor quarters they still tell of the hero who told the council <i>no</i>. You cannot buy your own drinks in Ironvale, possibly ever again.`);
  else if (flags.citizenRep <= -2) realmLines.push(`Some in the poor quarters remember the collection wagons you led, and their look follows you yet. Heroism, you've learned, keeps complicated books of its own.`);
  if (flags.seraFriend) realmLines.push(`<b>Sera</b> takes the King's coin as huntmaster of the new Rangers — "someone has to teach your soldiers to see" — and stands you a drink each time your roads cross.`);
  realmLines.push(`The medicine reached the camps. The granaries are guarded by people who own their own weapons again. The roads east run full of wagons.`);

  const ep = {
    revenge: `You came to Ironvale carrying one name carved in your heart — and you leave having learned the anatomy of betrayal itself: how it smiles, how it remembers your name, how it buys the drinks. The hunt that drives you is sharper now, and colder, and immeasurably better informed. Whoever they are, wherever they sleep — they should not sleep well.`,
    glory: `They sing about the breach at the east gate now, and the ledger-thief who out-schemed a councilor and out-fought a warlord in the same night. The song has nine verses and you're in seven of them. It is, you concede, a solid first ballad. The second one is out there somewhere, waiting for you to commit it.`,
    knowledge: `You keep a copy of the cipher. Of course you keep a copy. Because the question under all of it is still open: Thorne built a five-year conspiracy with nothing but patience, warmth, and other people's blindness — and somewhere out there, others are running the same design. You intend to learn every variation. Knowledge, as ever, is the only armor that fits everything.`,
    wealth: `Final accounting: bounties, salvage, the gratitude of a crown, and a modest fee for consulting on the treasury's new anti-fraud stamps (your idea — they pay well for irony). A healthy fortune. But the real asset is the lesson: the most dangerous coin in any purse is the one given warmly. You bite every gift now. Fortune favors the bold — and audits the friendly.`,
    protector: `The four hundred refugees under the aqueduct arches eat from full granaries this morning. The widow got her crossbow back; you carried it to her yourself. That's the whole treasure, as far as you're concerned. You stay until the walls are mended and the watch answers to the city again — and then you shoulder your pack, because somewhere down the road there's another kind face working a quiet ruin. There always is. And now they have you.`,
    wanderlust: `You leave on the third morning, when the road-itch gets unbearable, with the King's letter of passage and Sera's hand-drawn map of everywhere she's never managed to reach. East past the ridge, they say, there's a drowned city that surfaces one week a year. You're walking before the gate-guard finishes saluting. Ironvale waves until you're out of sight — the horizon, as always, waves you onward.`
  }[C.motive.id];

  scene("🌅", "Epilogue — The Serpent Unmasked",
    [ `<i>${fate}</i>`,
      realmLines.join(" "),
      `<i>${ep}</i>` ],
    [],
    `<div class="panel epilogue center" style="margin-top:14px">
      <h3>⚔ ${esc(C.name)}'s Legend ⚔</h3>
      <p>Level ${C.level} ${C.race.name} ${C.cls.name} · ${C.origin.name} · ${C.event.name} · ${C.motive.name}</p>
      <p><b>XP:</b> ${C.xp} &nbsp; <b>Gold:</b> ${C.gold} &nbsp; <b>Evidence gathered:</b> ${flags.evidence.length}/5 (weight ${evidenceWeight()})</p>
      <p class="flavor">The serpent of Ironvale is unmasked. But Emberfall is wide, its councils are many, and the dice are never done rolling.</p>
      <div class="action-row" style="margin-top:10px">
        <button class="primary" onclick="goScene('c7_open')">🐍 Continue the Tale — Campaign 2: The Coward King</button>
        <button onclick="showSaveScreen()">🪶 Keep this hero's save code</button>
        <button onclick="restartAll()">📖 Forge a New Hero</button>
      </div>
    </div>`);
}

